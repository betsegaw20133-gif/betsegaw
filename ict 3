<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-select=none">
    <title>Ethiopia National ICT Portal - Titan Apex</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;800;900&display=swap');

        :root {
            --primary: #0f3460; 
            --secondary: #e94560;
            --success: #27ae60; 
            --ethiopia-gold: #febd11; 
            --ethiopia-green: #138808;
            --ethiopia-red: #e74c3c;
            --glass-bg: rgba(255, 255, 255, 0.1);
            --glass-border: rgba(255, 255, 255, 0.2);
            --text: #ffffff;
            --dark-bg: #1a1a2e;
        }

        body {
            font-family: 'Poppins', sans-serif; 
            background: linear-gradient(-45deg, #0f3460, #1a1a2e, #16213e, #0f3460);
            background-size: 400% 400%;
            animation: gradientBG 15s ease infinite;
            color: var(--text);
            margin: 0; 
            display: flex; 
            flex-direction: column; 
            align-items: center; 
            min-height: 100vh; 
            overflow-x: hidden;
        }

        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Glassmorphism Titan Class */
        .glass {
            background: var(--glass-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--glass-border);
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
            border-radius: 20px;
        }

        header {
            width: 100%; 
            padding: 25px 0 15px 0; 
            text-align: center;
            border-bottom: 4px solid var(--ethiopia-gold);
            border-radius: 0 0 30px 30px;
            position: relative;
            background: rgba(15, 52, 96, 0.6);
            backdrop-filter: blur(10px);
            z-index: 10;
        }

        .header-controls {
            position: absolute;
            top: 15px;
            right: 20px;
            display: flex;
            gap: 10px;
        }

        .lang-btn {
            background: rgba(255,255,255,0.15);
            border: 1px solid var(--glass-border);
            padding: 5px 12px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
            color: var(--text);
            transition: 0.3s;
        }
        .lang-btn:hover { background: var(--ethiopia-gold); color: #000; }

        .logo-container {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 20px;
            margin-bottom: 15px;
        }

        .logo { 
            width: 75px; height: 75px; 
            object-fit: contain; 
            border-radius: 50%; 
            border: 3px solid var(--ethiopia-green); 
            background: white;
            padding: 3px;
            box-shadow: 0 0 15px var(--ethiopia-green);
        }

        .sos-logo {
            height: 55px;
            background: white;
            padding: 5px 15px;
            border-radius: 12px;
            border: 2px solid var(--ethiopia-red);
            box-shadow: 0 0 15px var(--ethiopia-red);
        }

        .dev-tag { font-size: 0.9rem; color: var(--ethiopia-gold); font-weight: 900; letter-spacing: 3px; text-shadow: 2px 2px 4px rgba(0,0,0,0.5); }
        
        .main-title { margin: 5px 0; font-size: 2.2rem; font-weight: 900; text-transform: uppercase; text-shadow: 2px 2px 5px rgba(0,0,0,0.5); }
        
        .dashboard {
            display: flex;
            gap: 20px;
            margin: 20px 0;
            width: 95%;
            max-width: 900px;
        }

        .side-panel {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .game-container { 
            flex: 2.5;
            padding: 25px; 
            display: flex; 
            flex-direction: column; 
            align-items: center; 
            position: relative;
        }
        
        .action-btn { 
            padding: 12px 20px; 
            color: white; 
            border-radius: 10px; 
            text-decoration: none; 
            font-size: 0.9rem; 
            font-weight: bold; 
            display: flex; 
            align-items: center; 
            justify-content: center;
            gap: 8px;
            border: none;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            text-transform: uppercase;
            width: 100%;
            box-sizing: border-box;
        }
        .action-btn:hover { transform: translateY(-3px); box-shadow: 0 5px 15px rgba(0,0,0,0.4); }
        .btn-blue { background: linear-gradient(45deg, #2980b9, #3498db); }
        .btn-red { background: linear-gradient(45deg, var(--secondary), #ff6b81); }
        
        .stats { 
            display: grid; grid-template-columns: 1fr 1fr; gap: 15px; width: 100%; 
            padding: 15px; margin-bottom: 20px; 
            font-weight: 800; text-align: center; font-size: 1.1rem;
            box-sizing: border-box;
        }

        .btn-group { margin-bottom: 20px; display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; }
        .btn { 
            padding: 8px 18px; border: 2px solid var(--ethiopia-gold); 
            background: transparent; color: var(--ethiopia-gold); 
            border-radius: 8px; cursor: pointer; font-weight: 800; 
            transition: 0.3s; font-size: 0.9rem; 
        }
        .btn.active, .btn:hover { background: var(--ethiopia-gold); color: #000; }

        /* Mode Switcher */
        .mode-switcher {
            display: flex; width: 100%; margin-bottom: 20px; border-radius: 10px; overflow: hidden; border: 1px solid var(--glass-border);
        }
        .mode-tab {
            flex: 1; padding: 12px; background: rgba(0,0,0,0.2); color: white; border: none; font-weight: bold; cursor: pointer; transition: 0.3s; font-size: 1rem;
        }
        .mode-tab.active { background: var(--secondary); }

        /* Views */
        #view-wordsearch, #view-quiz { width: 100%; display: none; flex-direction: column; align-items: center; }
        #view-wordsearch.active, #view-quiz.active { display: flex; animation: fadeIn 0.5s; }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        /* Grid */
        #grid {
            display: grid; padding: 15px;
            user-select: none; touch-action: none; margin: 0 auto;
            border: 4px solid var(--ethiopia-green);
            background: rgba(0,0,0,0.4);
            border-radius: 12px;
        }
        .cell {
            width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;
            font-weight: 900; font-size: 1.2rem; cursor: pointer; border-radius: 6px; color: white;
            transition: 0.2s; text-shadow: 1px 1px 2px rgba(0,0,0,0.8);
        }
        .cell.highlighted { background: var(--ethiopia-gold); color: black; transform: scale(1.1); box-shadow: 0 0 10px var(--ethiopia-gold); }
        .cell.found { background: var(--success) !important; color: white !important; box-shadow: 0 0 10px var(--success); }

        .word-bank {
            margin-top: 20px; padding: 15px; width: 100%; display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; box-sizing: border-box; background: rgba(0,0,0,0.2); border-radius: 10px;
        }
        .word-tag { padding: 8px 16px; background: rgba(255,255,255,0.1); border-radius: 50px; font-size: 0.9rem; font-weight: 800; color: white; border: 1px solid rgba(255,255,255,0.3); transition: 0.3s; }
        .word-tag.found { background: var(--success); color: white; text-decoration: line-through; border-color: #219a52; transform: scale(0.95); opacity: 0.7; }

        /* Quiz UI */
        .quiz-question { font-size: 1.4rem; font-weight: bold; text-align: center; margin-bottom: 20px; padding: 20px; background: rgba(0,0,0,0.3); border-radius: 10px; width: 100%; box-sizing: border-box; border-left: 5px solid var(--ethiopia-gold); }
        .quiz-options { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; width: 100%; }
        .quiz-btn { padding: 15px; font-size: 1rem; font-weight: bold; border-radius: 10px; border: 1px solid rgba(255,255,255,0.2); background: rgba(255,255,255,0.1); color: white; cursor: pointer; transition: 0.2s; }
        .quiz-btn:hover { background: rgba(255,255,255,0.2); transform: translateY(-2px); }
        .quiz-btn.correct { background: var(--success); border-color: var(--success); }
        .quiz-btn.wrong { background: var(--ethiopia-red); border-color: var(--ethiopia-red); }

        /* Leaderboard ticker */
        .ticker-wrap { width: 100%; background: rgba(0,0,0,0.5); overflow: hidden; height: 35px; display: flex; align-items: center; border-bottom: 1px solid rgba(255,255,255,0.1); }
        .ticker { display: inline-block; white-space: nowrap; padding-right: 100%; box-sizing: content-box; animation: ticker 20s linear infinite; color: var(--ethiopia-gold); font-weight: bold; font-size: 0.9rem; }
        @keyframes ticker { 0% { transform: translate3d(0, 0, 0); } 100% { transform: translate3d(-100%, 0, 0); } }

        /* Modals */
        .modal-overlay {
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.85); align-items: center; justify-content: center; z-index: 1000; backdrop-filter: blur(5px);
        }
        .cert-card { 
            padding: 40px; border: 8px double var(--ethiopia-gold); text-align: center; 
            max-width: 450px; width: 85%; border-radius: 15px; position: relative;
            background: linear-gradient(135deg, #ffffff, #f1f2f6); color: #2c3e50;
        }
        .cert-ribbon { position: absolute; top: -30px; right: -20px; font-size: 4rem; filter: drop-shadow(0 5px 5px rgba(0,0,0,0.3)); }

        footer { margin-top: auto; padding: 20px; color: rgba(255,255,255,0.6); font-size: 0.85rem; text-align: center; font-weight: bold; width: 100%; }

        @media (max-width: 768px) {
            .dashboard { flex-direction: column; }
            .cell { width: 30px; height: 30px; font-size: 1rem; }
            .quiz-options { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

<header class="glass">
    <div class="header-controls">
        <button class="lang-btn" onclick="setLang('en')">EN</button>
        <button class="lang-btn" onclick="setLang('af')">AF</button>
        <button class="lang-btn" onclick="setLang('am')">አማ</button>
    </div>
    <div class="logo-container">
        <img src="https://tse1.mm.bing.net/th/id/OIP.fG7NxAje_24iai2j6IQR_gAAAA?rs=1&pid=ImgDetMain&o=7&rm=3" alt="MoE Logo" class="logo">
        <img src="https://upload.wikimedia.org/wikipedia/en/thumb/0/05/SOS_Children%27s_Villages_Logo.svg/200px-SOS_Children%27s_Villages_Logo.svg.png" alt="SOS Children's Villages" class="sos-logo">
    </div>
    <div class="dev-tag">ENGINEERED BY BETSEGAW TEKA</div>
    <h1 id="main-header" class="main-title">Ethiopia National ICT Portal</h1>
</header>

<div class="ticker-wrap">
    <div class="ticker">
        🟢 LIVE GLOBAL LEADERBOARD: 1. Dawit_A (Addis Ababa) - Level 10 | 2. Samira_H (Bedele) - Level 9 | 3. Bereket_M (Dire Dawa) - Level 8 | 4. Abel_T (Hawassa) - Level 7 | 🏆 Server: Online
    </div>
</div>

<div class="dashboard">
    <div class="side-panel">
        <div class="glass" style="padding: 20px; text-align: center;">
            <h3 style="margin-top:0; color: var(--ethiopia-gold);">Resource Center</h3>
            <a href="https://camaraethiopia.org.et/OromiaPrimary/CEE_MoE_Plasma/content/ICT/Primary/ICTSBG7.pdf" class="action-btn btn-blue" target="_blank" style="margin-bottom: 10px;">📥 Grade 7 Textbook</a>
            <a href="https://camaraethiopia.org.et/OromiaPrimary/CEE_MoE_Plasma/content/ICT/Primary/ICTSBG8.pdf" class="action-btn btn-blue" target="_blank" style="margin-bottom: 10px;">📥 Grade 8 Textbook</a>
            <button class="action-btn btn-red" onclick="alert('Student Analytics Syncing with National Database...')">📊 Student Profile</button>
        </div>
        
        <div class="glass" style="padding: 20px;">
            <h4 style="margin-top:0; color: var(--success); text-align: center;">Upcoming Modules</h4>
            <ul style="font-size: 0.85rem; color: #ddd; padding-left: 20px;">
                <li>Trilingual Typing Engine</li>
                <li>Amharic Quest: Reading & Writing</li>
                <li>Amharic Quest: Speaking & Listening</li>
            </ul>
        </div>
    </div>

    <div class="game-container glass">
        <div class="mode-switcher">
            <button class="mode-tab active" onclick="switchMode('wordsearch', this)">🔍 Word Search</button>
            <button class="mode-tab" onclick="switchMode('quiz', this)">📝 ICT Quiz Challenge</button>
        </div>

        <div class="stats glass">
            <span>🏆 Level: <span id="lvl" style="color: var(--ethiopia-gold);">1</span></span>
            <span>❤️ Lives: <span id="lives">❤️❤️❤️</span></span>
            <span>⏱ Time: <span id="timer" style="color: var(--secondary);">00:00</span></span>
            <span>📈 Score: <span id="score" style="color: var(--success);">0</span></span>
        </div>

        <div id="view-wordsearch" class="active">
            <div class="btn-group">
                <button class="btn active" id="btn-easy" onclick="setDiff('easy')">Easy</button>
                <button class="btn" id="btn-medium" onclick="setDiff('medium')">Medium</button>
                <button class="btn" id="btn-hard" onclick="setDiff('hard')">Hard</button>
                <button class="btn" style="border-color: #3498db; color: #3498db;" onclick="giveHint()">💡 Hint</button>
            </div>
            <div id="grid"></div>
            <div class="word-bank" id="bank"></div>
        </div>

        <div id="view-quiz">
            <div class="quiz-question" id="quiz-q">Loading Curriculum...</div>
            <div class="quiz-options" id="quiz-opts">
                </div>
        </div>
    </div>
</div>

<div id="cert-modal" class="modal-overlay">
    <div class="cert-card">
        <div class="cert-ribbon">🎖️</div>
        <h2 style="color: var(--ethiopia-green); font-size: 1.8rem; margin-top: 0; font-weight: 900;">CERTIFICATE OF EXCELLENCE</h2>
        <p style="font-size: 1rem; font-weight: 600; color: #555;">Awarded for mastering the Grade 7 & 8 National ICT Curriculum framework.</p>
        <hr style="border: 1px solid var(--ethiopia-gold); margin: 15px 0;">
        <p style="font-weight: 800; text-transform: uppercase; margin:0;">Total Score</p>
        <h3 id="final-score" style="color: var(--ethiopia-red); font-size: 3rem; margin: 0;">0</h3>
        <p style="font-weight: bold;">Completion Time: <span id="final-time" style="color: var(--primary);">00:00</span></p>
        <p style="color: #7f8c8d; font-size: 0.8rem; font-style: italic; margin-top: 15px;">Official Software Platform Developed by Betsegaw Teka<br>In Association with SOS School</p>
        <button class="action-btn btn-blue" style="margin: 20px auto 0; padding: 12px 25px;" onclick="location.reload()">START NEW SESSION</button>
    </div>
</div>

<footer>BETSEGAW TEKA © 2026 | NATIONAL ICT RESOURCE CENTER</footer>

<script>
    // --- LANGUAGE SYSTEM ---
    const titles = {
        'en': 'Ethiopia National ICT Portal',
        'am': 'የኢትዮጵያ ብሔራዊ የመረጃ እና ግንኙነት ቴክኖሎጂ ፖርታል',
        'af': 'Portaalii Biyyaalessaa ICT Itoophiyaa'
    };
    function setLang(lang) {
        document.getElementById('main-header').innerText = titles[lang];
    }

    // --- GLOBAL VARIABLES ---
    let level = 1, lives = 3, score = 0, startTime, timerInterval;
    let currentMode = 'wordsearch';
    const sfxFound = new Audio('https://assets.mixkit.co/active_storage/sfx/2000/2000-preview.mp3');
    const sfxError = new Audio('https://assets.mixkit.co/active_storage/sfx/2955/2955-preview.mp3');

    function updateStats() {
        document.getElementById('lvl').innerText = level;
        document.getElementById('lives').innerText = "❤️".repeat(Math.max(0, lives));
        document.getElementById('score').innerText = score;
    }

    function startTimer() {
        startTime = Date.now(); 
        clearInterval(timerInterval); 
        timerInterval = setInterval(() => {
            let sec = Math.floor((Date.now() - startTime)/1000);
            document.getElementById('timer').innerText = `${Math.floor(sec/60).toString().padStart(2,'0')}:${(sec%60).toString().padStart(2,'0')}`;
        }, 1000);
    }

    function switchMode(mode, btn) {
        document.querySelectorAll('.mode-tab').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('view-wordsearch').classList.remove('active');
        document.getElementById('view-quiz').classList.remove('active');
        document.getElementById('view-' + mode).classList.add('active');
        currentMode = mode;
        if(mode === 'quiz' && quizIndex === 0) loadQuiz();
    }

    // --- WORD SEARCH LOGIC ---
    const WORDS = {
        easy: ["MOUSE", "WIFI", "CLICK", "DATA", "ICON", "FILE", "RAM", "WEB", "MODEM", "USER"],
        medium: ["MONITOR", "BATTERY", "TABLET", "ROUTER", "MEMORY", "WINDOWS", "BROWSER", "HARDWARE"],
        hard: ["PROCESSOR", "DATABASE", "SECURITY", "NETWORK", "FIREWALL", "GRAPHICS", "COMPILER"]
    };
    let diff = 'easy', targetWords = [], found = [], selected = [], isDown = false, startPos = null;

    function setDiff(val) {
        diff = val; level = 1; lives = 3; score = 0;
        document.querySelectorAll('.btn-group .btn').forEach(b => b.classList.remove('active'));
        document.getElementById('btn-'+val).classList.add('active');
        initWordSearch();
    }

    function initWordSearch() {
        updateStats();
        if(level === 1) startTimer();
        const size = diff === 'easy' ? 10 : (diff === 'medium' ? 12 : 14);
        targetWords = [...WORDS[diff]].sort(() => 0.5 - Math.random()).slice(0, 5);
        found = [];
        
        let grid = Array(size).fill().map(() => Array(size).fill(''));
        targetWords.forEach(word => {
            let placed = false;
            while (!placed) {
                let dir = Math.floor(Math.random() * (diff === 'easy' ? 2 : (diff === 'medium' ? 3 : 4))); 
                let r = Math.floor(Math.random() * size), c = Math.floor(Math.random() * size);
                let dr = 0, dc = 0;
                let w = word;

                if (dir === 0) dc = 1; 
                if (dir === 1) dr = 1; 
                if (dir === 2) { dr = 1; dc = 1; } 
                if (dir === 3) { w = w.split('').reverse().join(''); dc = 1; } 

                if (r + dr * w.length <= size && c + dc * w.length <= size) {
                    let ok = true;
                    for (let i=0; i<w.length; i++) if (grid[r+i*dr][c+i*dc] !== '' && grid[r+i*dr][c+i*dc] !== w[i]) ok = false;
                    if (ok) { for (let i=0; i<w.length; i++) grid[r+i*dr][c+i*dc] = w[i]; placed = true; }
                }
            }
        });

        const gridEl = document.getElementById('grid');
        gridEl.innerHTML = ''; gridEl.style.gridTemplateColumns = `repeat(${size}, 1fr)`;
        for (let r=0; r<size; r++) {
            for (let c=0; c<size; c++) {
                const el = document.createElement('div');
                el.className = 'cell'; el.innerText = grid[r][c] || "ABCDEFGHIJKLMNOPQRSTUVWXYZ"[Math.floor(Math.random()*26)];
                el.dataset.r = r; el.dataset.c = c;
                el.onmousedown = () => startSelection(r, c);
                el.onmouseenter = () => moveSelection(r, c);
                el.ontouchstart = (e) => { e.preventDefault(); startSelection(r, c); };
                el.ontouchmove = (e) => {
                    let t = e.touches[0];
                    let target = document.elementFromPoint(t.clientX, t.clientY);
                    if (target && target.dataset.r) moveSelection(parseInt(target.dataset.r), parseInt(target.dataset.c));
                };
                gridEl.appendChild(el);
            }
        }
        const bank = document.getElementById('bank'); bank.innerHTML = '';
        targetWords.forEach(w => bank.innerHTML += `<span class="word-tag" id="w-${w}">${w}</span>`);
    }

    function startSelection(r, c) { isDown = true; startPos = {r, c}; selected = [{r, c}]; highlight(); }
    function moveSelection(r, c) {
        if (!isDown) return;
        let dr = r - startPos.r, dc = c - startPos.c;
        if (dr === 0 || dc === 0 || Math.abs(dr) === Math.abs(dc)) {
            selected = [];
            let steps = Math.max(Math.abs(dr), Math.abs(dc));
            let rStep = dr === 0 ? 0 : dr/steps, cStep = dc === 0 ? 0 : dc/steps;
            for(let i=0; i<=steps; i++) selected.push({r: startPos.r + i*rStep, c: startPos.c + i*cStep});
            highlight();
        }
    }
    function highlight() {
        document.querySelectorAll('.cell').forEach(c => c.classList.remove('highlighted'));
        selected.forEach(p => document.querySelector(`.cell[data-r="${p.r}"][data-c="${p.c}"]`)?.classList.add('highlighted'));
    }

    function endSelection() {
        if (!isDown) return;
        isDown = false;
        let cells = selected.map(p => document.querySelector(`.cell[data-r="${p.r}"][data-c="${p.c}"]`));
        let str = cells.filter(c => c).map(c => c.innerText).join('');
        let rev = str.split('').reverse().join('');
        let match = targetWords.find(w => w === str || w === rev);
        
        if (match && !found.includes(match)) {
            found.push(match); score += 100; updateStats();
            sfxFound.play().catch(()=>{});
            document.getElementById('w-'+match).classList.add('found');
            cells.forEach(c => c && c.classList.add('found'));
            
            if (found.length === 5) {
                if(level < 5) { 
                    level++; setTimeout(() => { alert("LEVEL " + level + " UNLOCKED!"); initWordSearch(); }, 300); 
                } else {
                    triggerCert();
                }
            }
        } else if (selected.length > 2) {
            lives--; updateStats(); sfxError.play().catch(()=>{});
            if(lives <= 0) { alert("SYSTEM FAILURE! Restarting."); level = 1; lives = 3; score = 0; initWordSearch(); }
        }
        document.querySelectorAll('.cell').forEach(c => c.classList.remove('highlighted'));
    }

    function giveHint() {
        let w = targetWords.find(word => !found.includes(word));
        if (w) alert(`HINT: Find the word starting with '${w[0]}' and ending with '${w[w.length-1]}'`);
    }

    // --- QUIZ LOGIC ---
    const quizData = [
        { q: "What does HTML stand for?", opts: ["Hyper Text Markup Language", "Home Tool Markup", "Hyperlinks Text Language", "Hyper Tool Multi Language"], ans: 0 },
        { q: "Which component is known as the 'Brain' of the computer?", opts: ["Hard Drive", "RAM", "CPU", "Motherboard"], ans: 2 },
        { q: "What is the primary function of an Operating System?", opts: ["Play Games", "Manage Hardware & Software", "Browse Web", "Type Documents"], ans: 1 },
        { q: "In binary, what number represents 'ON'?", opts: ["2", "10", "0", "1"], ans: 3 },
        { q: "Which of these is an Input Device?", opts: ["Monitor", "Printer", "Keyboard", "Speaker"], ans: 2 }
    ];
    let quizIndex = 0;

    function loadQuiz() {
        if(quizIndex >= quizData.length) { triggerCert(); return; }
        const qObj = quizData[quizIndex];
        document.getElementById('quiz-q').innerText = `Q${quizIndex+1}: ${qObj.q}`;
        const optContainer = document.getElementById('quiz-opts');
        optContainer.innerHTML = '';
        qObj.opts.forEach((opt, idx) => {
            let btn = document.createElement('button');
            btn.className = 'quiz-btn'; btn.innerText = opt;
            btn.onclick = () => checkQuiz(idx, qObj.ans, btn);
            optContainer.appendChild(btn);
        });
    }

    function checkQuiz(selected, correct, btn) {
        document.querySelectorAll('.quiz-btn').forEach(b => b.disabled = true);
        if(selected === correct) {
            btn.classList.add('correct'); score += 200; sfxFound.play().catch(()=>{});
            setTimeout(() => { quizIndex++; level++; updateStats(); loadQuiz(); }, 1000);
        } else {
            btn.classList.add('wrong'); lives--; updateStats(); sfxError.play().catch(()=>{});
            document.querySelectorAll('.quiz-btn')[correct].classList.add('correct');
            if(lives <= 0) { setTimeout(()=>{ alert("QUIZ FAILED! Restarting."); lives = 3; score = 0; quizIndex = 0; updateStats(); loadQuiz(); }, 1000); }
            else { setTimeout(() => { quizIndex++; loadQuiz(); }, 1500); }
        }
    }

    function triggerCert() {
        clearInterval(timerInterval);
        document.getElementById('final-score').innerText = score;
        document.getElementById('final-time').innerText = document.getElementById('timer').innerText;
        document.getElementById('cert-modal').style.display = 'flex';
    }

    window.onmouseup = endSelection; window.ontouchend = endSelection;
    initWordSearch();
</script>
</body>
</html>
