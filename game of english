<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ultimate Learning Kingdom</title>
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #6c5ce7;
            --secondary: #00cec9;
            --accent: #fdcb6e;
            --danger: #ff7675;
            --success: #00b894;
            --text: #2d3436;
            --glass: rgba(255, 255, 255, 0.9);
            --glass-border: rgba(255, 255, 255, 0.5);
            --shadow: 0 12px 40px rgba(0,0,0,0.12);
        }

        body {
            font-family: 'Fredoka', sans-serif;
            background: linear-gradient(135deg, #a29bfe 0%, #74b9ff 100%);
            margin: 0; height: 100vh; display: flex; justify-content: center; align-items: center;
            overflow: hidden; transition: background 1s ease;
        }

        body.theme-jungle { background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); }
        body.theme-sunset { background: linear-gradient(135deg, #ee0979 0%, #ff6a00 100%); }
        body.theme-ocean { background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%); }

        .particle {
            position: absolute; border-radius: 50%; background: rgba(255, 255, 255, 0.2);
            pointer-events: none; animation: float 15s infinite linear; z-index: 0;
        }

        @keyframes float {
            0% { transform: translateY(0) rotate(0deg); opacity: 0; }
            50% { opacity: 0.5; }
            100% { transform: translateY(-100vh) rotate(360deg); opacity: 0; }
        }

        #app {
            width: 95%; max-width: 480px; height: 92vh;
            background: var(--glass); backdrop-filter: blur(15px);
            border-radius: 40px; border: 4px solid white;
            box-shadow: var(--shadow); display: flex; flex-direction: column;
            position: relative; z-index: 10; overflow: hidden;
        }

        .hud {
            display: flex; justify-content: space-between; align-items: center;
            padding: 15px 20px; background: rgba(255,255,255,0.4);
        }

        .stat-group { display: flex; gap: 8px; }
        .stat-badge {
            background: white; padding: 6px 10px; border-radius: 12px;
            font-weight: 700; font-size: 0.85rem; box-shadow: 0 3px 0 #eee;
        }

        .screen {
            flex: 1; display: flex; flex-direction: column; align-items: center;
            padding: 20px; position: absolute; top: 70px; bottom: 0; left: 0; right: 0;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            overflow-y: auto;
        }

        .hidden { opacity: 0; transform: translateX(50px); pointer-events: none; }
        .active { opacity: 1; transform: translateX(0); }

        .big-btn {
            width: 100%; padding: 18px; margin: 8px 0; border: none;
            border-radius: 20px; font-family: 'Fredoka'; font-size: 1.2rem;
            font-weight: 700; color: white; cursor: pointer;
            box-shadow: 0 6px 0 rgba(0,0,0,0.1); transition: all 0.1s;
        }

        .big-btn:active { transform: translateY(3px); box-shadow: 0 3px 0 rgba(0,0,0,0.1); }
        .btn-abc { background: var(--primary); }
        .btn-math { background: var(--success); }
        .btn-shop { background: var(--accent); color: #2d3436; }

        .card-question {
            background: white; width: 85%; padding: 25px; border-radius: 30px;
            text-align: center; box-shadow: 0 10px 20px rgba(0,0,0,0.05);
            margin-bottom: 20px; border: 2px solid #f0f0f0;
        }

        .q-display { font-size: 4rem; color: var(--primary); margin: 0; line-height: 1; }
        
        .ans-btn {
            background: white; border: 2px solid #eee; border-radius: 20px;
            height: 70px; font-size: 1.6rem; cursor: pointer;
            transition: all 0.2s; box-shadow: 0 5px 0 #eee; font-family: 'Fredoka';
        }

        .correct { background: var(--success) !important; color: white !important; border-color: var(--success) !important; transform: scale(1.05); }
        .wrong { background: var(--danger) !important; color: white !important; animation: shake 0.4s; }

        @keyframes shake { 0%,100%{transform:translateX(0)} 25%{transform:translateX(-10px)} 75%{transform:translateX(10px)} }

        .library-grid {
            display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; width: 100%;
        }
        .lib-item {
            background: white; padding: 10px; border-radius: 15px; text-align: center;
            font-size: 1.2rem; border: 2px solid #eee;
        }

        .footer-tag {
            position: absolute; bottom: 8px; width: 100%; text-align: center;
            font-size: 0.65rem; color: #b2bec3; font-weight: 600; text-transform: uppercase;
        }

        .confetti {
            position: absolute; width: 10px; height: 10px; z-index: 100;
            animation: confettiFall 2s ease-out forwards;
        }
        @keyframes confettiFall {
            0% { transform: translateY(0) rotate(0); opacity: 1; }
            100% { transform: translateY(500px) rotate(720deg); opacity: 0; }
        }
    </style>
</head>
<body>

<div id="app">
    <div class="hud">
        <button onclick="goHome()" style="border:none; background:none; font-size:1.5rem; cursor:pointer;">🏰</button>
        <div class="stat-group">
            <div class="stat-badge">⭐ LVL <span id="val-lvl">1</span></div>
            <div class="stat-badge" style="color:#d63031">❤️ <span id="val-life">3</span></div>
            <div class="stat-badge" style="color:#e67e22">🪙 <span id="val-coin">0</span></div>
        </div>
    </div>

    <!-- Home Screen -->
    <div id="scr-home" class="screen active">
        <h1 style="margin-top:0; font-size:2rem; text-align:center;">Learning Kingdom</h1>
        <img src="https://cdn-icons-png.flaticon.com/512/3074/3074058.png" width="80" style="margin-bottom:20px;">
        <button class="big-btn btn-abc" onclick="selectMode('abc')">🔤 Alphabet Quest</button>
        <button class="big-btn btn-math" onclick="selectMode('math')">🔢 Math Magic</button>
        <button class="big-btn btn-shop" onclick="showScreen('scr-shop')">🛒 Royal Market</button>
    </div>

    <!-- Submenu Screen -->
    <div id="scr-submenu" class="screen hidden">
        <h2 id="submenu-title">World</h2>
        <div style="width: 100%;">
            <button class="big-btn" style="background:#00b894" onclick="startGame()">▶ Start Training</button>
            <button class="big-btn" style="background:#0984e3" onclick="goToTutorial()">🎓 View Library</button>
            <button class="big-btn" style="background:#dfe6e9; color:#636e72;" onclick="goHome()">Back</button>
        </div>
    </div>

    <!-- Game Screen -->
    <div id="scr-game" class="screen hidden">
        <div class="card-question">
            <div class="q-display" id="q-content">?</div>
            <div style="font-weight:600; color:#636e72; margin-top:10px;" id="q-text">Ready?</div>
        </div>
        <div style="display:grid; grid-template-columns: 1fr 1fr; gap:15px; width:100%;" id="grid-answers"></div>
    </div>

    <!-- Shop Screen -->
    <div id="scr-shop" class="screen hidden">
        <h2>Marketplace</h2>
        <div style="width:100%">
            <button class="big-btn" style="background:#ff7675" onclick="buy('heart')">❤️ Extra Life (50🪙)</button>
            <button class="big-btn" style="background:#11998e" onclick="buy('jungle')">🌴 Jungle Theme (100🪙)</button>
            <button class="big-btn" style="background:#2193b0" onclick="buy('ocean')">🌊 Ocean Theme (100🪙)</button>
            <button class="big-btn" style="background:#ee0979" onclick="buy('sunset')">🌅 Sunset Theme (150🪙)</button>
        </div>
        <button class="big-btn" style="background:#dfe6e9; color:#636e72;" onclick="goHome()">Go Back</button>
    </div>

    <!-- Library Screen -->
    <div id="scr-tutorial" class="screen hidden">
        <h2 id="lib-title">Royal Library</h2>
        <div class="library-grid" id="lib-container"></div>
        <button class="big-btn" style="background:#dfe6e9; color:#636e72; margin-top:20px;" onclick="showScreen('scr-submenu')">Back</button>
    </div>

    <div class="footer-tag">Made by Betsegaw Teka</div>
</div>

<script>
    const abcData = [
        {l:'A', w:'Apple', i:'🍎'}, {l:'B', w:'Ball', i:'⚽'}, {l:'C', w:'Cat', i:'🐱'},
        {l:'D', w:'Dog', i:'🐶'}, {l:'E', w:'Elephant', i:'🐘'}, {l:'F', w:'Fish', i:'🐟'},
        {l:'G', w:'Grapes', i:'🍇'}, {l:'H', w:'House', i:'🏠'}, {l:'I', w:'Ice Cream', i:'🍦'},
        {l:'J', w:'Jellyfish', i:'🪼'}, {l:'K', w:'Kite', i:'🪁'}, {l:'L', w:'Lion', i:'🦁'},
        {l:'M', w:'Monkey', i:'🐒'}, {l:'N', w:'Nose', i:'👃'}, {l:'O', w:'Orange', i:'🍊'},
        {l:'P', w:'Pizza', i:'🍕'}, {l:'Q', w:'Queen', i:'👸'}, {l:'R', w:'Rabbit', i:'🐰'},
        {l:'S', w:'Star', i:'⭐'}, {l:'T', w:'Tree', i:'🌳'}, {l:'U', w:'Umbrella', i:'☂️'},
        {l:'V', w:'Van', i:'🚐'}, {l:'W', w:'Watermelon', i:'🍉'}, {l:'X', w:'Xylophone', i:'🪘'},
        {l:'Y', w:'Yo-yo', i:'🪀'}, {l:'Z', w:'Zebra', i:'🦓'}
    ];

    let state = {
        coins: 0, lives: 3, xp: 0, lvl: 1,
        mode: 'abc', isBusy: false
    };

    function speak(text) {
        window.speechSynthesis.cancel();
        const u = new SpeechSynthesisUtterance(text);
        u.rate = 1.0;
        window.speechSynthesis.speak(u);
    }

    function showScreen(id) {
        document.querySelectorAll('.screen').forEach(s => {
            s.classList.remove('active');
            s.classList.add('hidden');
        });
        const target = document.getElementById(id);
        target.classList.remove('hidden');
        target.classList.add('active');
        updateHUD();
    }

    function updateHUD() {
        document.getElementById('val-coin').innerText = state.coins;
        document.getElementById('val-life').innerText = state.lives;
        document.getElementById('val-lvl').innerText = state.lvl;
    }

    function selectMode(m) {
        state.mode = m;
        document.getElementById('submenu-title').innerText = m === 'abc' ? "Alphabet Kingdom" : "Math Kingdom";
        showScreen('scr-submenu');
        speak(m === 'abc' ? "Alphabet Kingdom" : "Math Kingdom");
    }

    function goToTutorial() {
        const container = document.getElementById('lib-container');
        container.innerHTML = '';
        if(state.mode === 'abc') {
            abcData.forEach(item => {
                const div = document.createElement('div');
                div.className = 'lib-item';
                div.innerHTML = `<b>${item.l}</b><br>${item.i}`;
                div.onclick = () => speak(`${item.l} is for ${item.w}`);
                container.appendChild(div);
            });
        } else {
            for(let i=1; i<=10; i++) {
                const div = document.createElement('div');
                div.className = 'lib-item';
                div.innerHTML = `<b>${i}</b>`;
                div.onclick = () => speak(i.toString());
                container.appendChild(div);
            }
        }
        showScreen('scr-tutorial');
    }

    function startGame() {
        if(state.lives <= 0) {
            speak("You need more hearts!");
            showScreen('scr-shop');
            return;
        }
        showScreen('scr-game');
        nextRound();
    }

    function nextRound() {
        state.isBusy = false;
        const grid = document.getElementById('grid-answers');
        grid.innerHTML = '';
        if(state.mode === 'abc') generateABCQuestion();
        else generateMathQuestion();
    }

    function generateABCQuestion() {
        const correct = abcData[Math.floor(Math.random() * abcData.length)];
        const type = Math.floor(Math.random() * 2); 
        
        let options = [correct];
        while(options.length < 4) {
            let r = abcData[Math.floor(Math.random() * abcData.length)];
            if(!options.includes(r)) options.push(r);
        }
        options.sort(() => Math.random() - 0.5);

        if(type === 0) {
            document.getElementById('q-content').innerText = correct.i;
            document.getElementById('q-text').innerText = "What starts with this?";
            speak("What starts with " + correct.w);
            options.forEach(opt => createBtn(opt.l, opt === correct));
        } else {
            document.getElementById('q-content').innerText = correct.l;
            document.getElementById('q-text').innerText = "Find the picture!";
            speak("Find the " + correct.w);
            options.forEach(opt => createBtn(opt.i, opt === correct));
        }
    }

    function generateMathQuestion() {
        // Difficulty scales with Level
        const maxNum = Math.min(5 + state.lvl, 20);
        const a = Math.floor(Math.random() * maxNum) + 1;
        const b = Math.floor(Math.random() * maxNum) + 1;
        const isPlus = Math.random() > 0.3 || state.lvl < 3;
        
        let question, answer;
        if(isPlus) {
            question = `${a} + ${b}`;
            answer = a + b;
        } else {
            const big = Math.max(a, b);
            const small = Math.min(a, b);
            question = `${big} - ${small}`;
            answer = big - small;
        }

        document.getElementById('q-content').innerText = question;
        document.getElementById('q-text').innerText = "What is the total?";
        speak(`What is ${isPlus ? a + " plus " + b : Math.max(a,b) + " minus " + Math.min(a,b)}`);

        let options = [answer];
        while(options.length < 4) {
            let off = Math.floor(Math.random() * 5) - 2;
            let fake = answer + off;
            if(fake >= 0 && !options.includes(fake)) options.push(fake);
            else if(!options.includes(answer + 5)) options.push(answer + 5);
        }
        options.sort(() => Math.random() - 0.5);
        options.forEach(opt => createBtn(opt, opt === answer));
    }

    function createBtn(text, isCorrect) {
        const btn = document.createElement('button');
        btn.className = 'ans-btn';
        btn.innerHTML = text;
        btn.onclick = () => {
            if(state.isBusy) return;
            state.isBusy = true;
            if(isCorrect) {
                btn.classList.add('correct');
                state.coins += 10;
                state.xp += 34; // 3 correct answers = 1 level roughly
                checkLevelUp();
                spawnConfetti();
                speak("Great job!");
                setTimeout(nextRound, 1200);
            } else {
                btn.classList.add('wrong');
                state.lives--;
                speak("Oops, try again!");
                if(state.lives <= 0) {
                    setTimeout(() => { alert("Out of lives! Visit the market."); goHome(); }, 600);
                } else {
                    setTimeout(() => { btn.classList.remove('wrong'); state.isBusy = false; updateHUD(); }, 600);
                }
            }
            updateHUD();
        };
        document.getElementById('grid-answers').appendChild(btn);
    }

    function checkLevelUp() {
        let nextLvlXp = state.lvl * 100;
        if(state.xp >= nextLvlXp) {
            state.lvl++;
            speak("Level up! You are now level " + state.lvl);
            // Visual feedback for level up
            document.getElementById('val-lvl').parentElement.style.transform = "scale(1.5)";
            setTimeout(() => document.getElementById('val-lvl').parentElement.style.transform = "scale(1)", 500);
        }
    }

    function spawnConfetti() {
        for(let i=0; i<15; i++) {
            const c = document.createElement('div');
            c.className = 'confetti';
            c.style.left = Math.random() * 100 + "%";
            c.style.top = "40%";
            c.style.background = ["#6c5ce7", "#00cec9", "#fdcb6e", "#ff7675"][Math.floor(Math.random()*4)];
            document.body.appendChild(c);
            setTimeout(() => c.remove(), 2000);
        }
    }

    function goHome() { showScreen('scr-home'); }

    function buy(item) {
        let costs = { heart: 50, jungle: 100, ocean: 100, sunset: 150 };
        if(state.coins >= costs[item]) {
            state.coins -= costs[item];
            if(item === 'heart') {
                state.lives++;
                speak("One more life added!");
            } else {
                document.body.className = 'theme-' + item;
                speak("New theme applied!");
            }
            updateHUD();
        } else {
            speak("You need more coins. Play more games!");
        }
    }

    // Initialize particles
    for(let i=0; i<8; i++) {
        const p = document.createElement('div');
        p.className = 'particle';
        p.style.width = p.style.height = Math.random() * 40 + 20 + "px";
        p.style.left = Math.random() * 100 + "%";
        p.style.bottom = "-50px";
        p.style.animationDelay = Math.random() * 10 + "s";
        document.body.appendChild(p);
    }
</script>
</body>
</html>
