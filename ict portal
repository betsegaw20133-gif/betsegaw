    <!-- NEW: Settings + Profile shortcuts -->
    <button class="btn" style="padding:10px 16px;" onclick="openModal('modal-settings'); playSound('click');">⚙️ Settings</button>
    <button class="btn" style="padding:10px 16px;" onclick="openModal('modal-profile'); playSound('click');">🧑‍🎓 Profile</button>

    <button class="btn btn-market" onclick="openModal('modal-market'); playSound('click');">🛒 SHOP</button>
  </div>

  <div id="app-container">

    <!-- WELCOME -->
