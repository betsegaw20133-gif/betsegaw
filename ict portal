      // NEW: capture quest streak completion state before claiming
      const completedAll = missions.every(m=>{
        const it = state.daily.items[m.type];
        return it && it.completed;
      });

      const mult = getQuestStreakMultiplier();

      missions.forEach(m=>{
        const item = state.daily.items[m.type];
        if(item && item.completed && !item.claimed){
          item.claimed = true;
          gainedCoins += Math.floor(m.reward.coins * mult);
          gainedXP += Math.floor(m.reward.xp * mult);
          claimedAny = true;
        }
      });

      if(!claimedAny){
        playSound('lose');
        vibrate(25);
        alert("No completed missions ready to claim.");
        return;
      }

      playSound('win');
      vibrate(25);

      state.coins += gainedCoins;
      state.xp += gainedXP;

      // NEW: quest streak update (3rd consecutive day type)
      if(completedAll){
        const tKey = todayKey();
        const last = state.flags.lastQuestCompleteDate || "";
        if(!last){
          state.flags.questStreak = 1;
        }else{
          const lastDate = new Date(last);
          const curDate = new Date(tKey);
          const diffDays = Math.round((curDate - lastDate) / (1000*60*60*24));
          if(diffDays === 1) state.flags.questStreak = (state.flags.questStreak || 0) + 1;
          else state.flags.questStreak = 1; // reset if not consecutive
        }
        state.flags.lastQuestCompleteDate = tKey;
      }else{
        // if not all done, streak remains
      }

      levelUpCheck();
      updateHUD();

      alert(`🎉 Daily Rewards Claimed!\n+${gainedCoins} Coins • +${gainedXP} XP`);

      // NEW: toast version of reward
      toast("Daily Rewards Claimed!", `+${gainedCoins} coins • +${gainedXP} XP`, settings.toasts);

      saveState();
      refreshDailyUI(false);
    }

