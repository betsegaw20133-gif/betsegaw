  <!-- NEW: Toast container -->
  <div id="toast-wrap" aria-live="polite" aria-atomic="true"></div>

  <script>
    /***********************
     * BUG-SAFETY LAYER (NEW #20)
     ***********************/
    window.addEventListener('error', function(e){
      try{
        const msg = e && e.message ? e.message : 'Unexpected error';
        showErrorModal(msg);
      }catch(_){}
    });
    window.addEventListener('unhandledrejection', function(e){
      try{
        const msg = e && e.reason && e.reason.message ? e.reason.message : 'Unexpected promise error';
        showErrorModal(msg);
      }catch(_){}
    });

    function showErrorModal(message){
      const el = document.getElementById('modal-error');
      if(el){
        document.getElementById('err-text').innerText = String(message).slice(0,220);
        openModal('modal-error');
      }
    }

    /***********************
     * AUDIO ENGINE
     ***********************/
    const AudioContext = window.AudioContext || window.webkitAudioContext;
    let audioCtx = null;

    function initAudio(){
      if(!audioCtx) audioCtx = new AudioContext();
      if(audioCtx.state === 'suspended') audioCtx.resume();
    }

    /***********************
     * SETTINGS (NEW #1, #4-ish)
     ***********************/
    const SETTINGS_KEY = "ict_master_omega_settings_v1";
    const defaultSettings = {
      sound: true,
      vibe: true,
      rmotion: false,
      toasts: true
    };
    let settings = loadSettings();

    function loadSettings(){
      try{
        const raw = localStorage.getItem(SETTINGS_KEY);
        if(!raw) return {...defaultSettings};
        const parsed = JSON.parse(raw);
        return {...defaultSettings, ...(parsed||{})};
      }catch(e){
        return {...defaultSettings};
      }
    }
    function saveSettings(){
      localStorage.setItem(SETTINGS_KEY, JSON.stringify(settings));
    }

    function applySettings(){
      // UI labels
      const sLabel = document.getElementById('set-sound-label');
      const vLabel = document.getElementById('set-vibe-label');
      const rLabel = document.getElementById('set-rmotion-label');
      const tLabel = document.getElementById('set-toasts-label');

      if(sLabel) sLabel.innerText = settings.sound ? "ON" : "OFF";
      if(vLabel) vLabel.innerText = settings.vibe ? "ON" : "OFF";
      if(rLabel) rLabel.innerText = settings.rmotion ? "ON" : "OFF";
      if(tLabel) tLabel.innerText = settings.toasts ? "ON" : "OFF";

      // Reduced motion: we can disable animations by setting a class
      document.documentElement.style.scrollBehavior = settings.rmotion ? "auto" : "";
      if(settings.rmotion){
        document.body.style.animation = "none";
      }
    }

    function toggleSetting(key){
      if(key in settings){
        settings[key] = !settings[key];
        saveSettings();
        applySettings();
        toast(`Settings updated`, key, settings.toasts);
      }
    }
    function resetSettings(){
      settings = {...defaultSettings};
      saveSettings();
      applySettings();
      toast(`Settings reset`, `All defaults restored`, settings.toasts);
    }

    /***********************
     * Toast system (NEW #2)
     ***********************/
    function toast(title, meta, enabled = true){
      if(!enabled) return;
      if(!settings.toasts) return;

      const wrap = document.getElementById('toast-wrap');
      if(!wrap) return;

      const el = document.createElement('div');
      el.className = 'toast ' + (title && String(title).toLowerCase().includes('unlocked') ? 'win' : 'warn');
      el.innerHTML = `<strong>${escapeHtml(String(title || ''))}</strong><div class="meta">${escapeHtml(String(meta || ''))}</div>`;
      wrap.appendChild(el);
      setTimeout(()=>{ try{ el.remove(); }catch(_){} }, 3200);
    }

    function vibrate(ms){
      if(!settings.vibe) return;
      if(navigator.vibrate) navigator.vibrate(ms);
    }

    function playSound(type){
      if(!settings.sound) return;
      if(!audioCtx) return;

      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.connect(gain);
      gain.connect(audioCtx.destination);

      const t = audioCtx.currentTime;

      gain.gain.setValueAtTime(0.0001, t);

      if(type === 'win'){
        osc.type = 'sine';
        osc.frequency.setValueAtTime(420, t);
        osc.frequency.exponentialRampToValueAtTime(880, t + 0.12);
        gain.gain.setValueAtTime(0.28, t);
        gain.gain.exponentialRampToValueAtTime(0.01, t + 0.22);
        osc.start(t); osc.stop(t + 0.23);
      } else if(type === 'lose'){
        osc.type = 'sawtooth';
        osc.frequency.setValueAtTime(190, t);
        osc.frequency.exponentialRampToValueAtTime(110, t + 0.25);
        gain.gain.setValueAtTime(0.25, t);
        gain.gain.exponentialRampToValueAtTime(0.01, t + 0.25);
        osc.start(t); osc.stop(t + 0.26);
      } else if(type === 'click' || type === 'type'){
        osc.type = 'square';
        osc.frequency.setValueAtTime(620, t);
        gain.gain.setValueAtTime(0.12, t);
        gain.gain.exponentialRampToValueAtTime(0.01, t + 0.06);
