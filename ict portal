    // Matching selections
    let selA = null, selB = null;
    function renderMatching(){
      const area = document.getElementById('q-options');
      let html = `<div class="match-area"><div class="match-box">`;

      const pool = [ictData[state.idx]];
      while(pool.length < 3){
        const rand = ictData[Math.floor(Math.random()*ictData.length)];
        if(!pool.includes(rand)) pool.push(rand);
      }
      pool.sort(()=>Math.random()-0.5);

      pool.forEach(item=>{
        html += `<div class="match-item" data-val="${escapeHtmlAttr(item.t)}" tabindex="0" onclick="matchSelect('A', '${escapeHtmlAttr(item.t)}', this); playSound('click');">${escapeHtml(item.t)}</div>`;
      });

      html += `</div><div class="match-box">`;

      const poolB = [...pool].sort(()=>Math.random()-0.5);
      poolB.forEach(item=>{
        const short = item.d.length>52 ? item.d.substring(0,52)+'...' : item.d;
        html += `<div class="match-item" data-val="${escapeHtmlAttr(item.t)}" tabindex="0" onclick="matchSelect('B', '${escapeHtmlAttr(item.t)}', this); playSound('click');">${escapeHtml(short)}</div>`;
      });

      html += `</div></div>`;
      area.innerHTML = html;
      selA = null; selB = null;
      stateLock = false;

      // keyboard for matching
      area.querySelectorAll('.match-item').forEach(el=>{
        el.addEventListener('keydown', (e)=>{
          if(e.key === 'Enter' || e.key === ' '){
            e.preventDefault();
            el.click();
          }
        });
      });
    }

    function matchSelect(side, keyVal, el){
      if(stateLock) return;

      if(side === 'A'){
        if(selA && selA.el) selA.el.classList.remove('selected');
        selA = { val:keyVal, el };
      }else{
        if(selB && selB.el) selB.el.classList.remove('selected');
        selB = { val:keyVal, el };
      }

      el.classList.add('selected');

      if(selA && selB){
        const correct = (selA.val === selB.val);
        if(correct){
          playSound('win');
          selA.el.classList.add('correct');
          selB.el.classList.add('correct');
          selA.el.classList.remove('selected');
          selB.el.classList.remove('selected');
          selA = null; selB = null;

          const locked = document.querySelectorAll('.match-item.correct').length;
          if(locked === 6){
            stateLock = true;
            handleQuizResult(true, false);
          }
        }else{
          playSound('lose');
          triggerShake();
          safeLoseLife();
          state.combo = 1;
          updateHUD();
          selA.el.classList.remove('selected');
          selB.el.classList.remove('selected');
          selA = null; selB = null;
        }
      }
    }

