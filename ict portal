      <h2 id="list-title" class="section-title">Module</h2>
      <input type="text" id="list-search" class="input-box" placeholder="Search content..." onkeyup="filterList()" />
      <div id="list-content" class="item-list"></div>
    </div>

    <!-- QUIZ ENGINE -->
    <div id="scr-quiz" class="screen">
