<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-select=none"/>
  <title>ICT Master Omega: Ethiopia | Ultimate Edition (Upgraded + 20 New Things)</title>

  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;500;700&family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

  <style>
    :root{
      --primary:#00d2ff;
      --secondary:#0984e3;
      --success:#00cec9;
      --danger:#d63031;
      --warning:#fdcb6e;
      --dark:#0f172a;
      --eth-green:#138808;
      --eth-yellow:#f1c40f;
      --eth-red:#e74c3c;
      --glass:rgba(30,41,59,.78);
      --text-light:#f8fafc;

      --card-bg: rgba(255,255,255,0.04);
      --card-brd: rgba(255,255,255,0.12);

      --shadow: 0 25px 50px rgba(0,0,0,0.45);
      --glow: 0 0 25px rgba(0,210,255,0.18);
    }

    *{ box-sizing:border-box; transition: all .2s ease; }

    body{
      font-family:'Poppins',sans-serif;
      background-color:#0f172a;
      color:var(--text-light);
      margin:0;
      min-height:100vh;
      display:flex;
      flex-direction:column;
      align-items:center;
      overflow-x:hidden;
    }

    #bg-canvas{
      position:fixed; top:0; left:0;
      width:100vw; height:100vh;
      z-index:-1; opacity:.62;
    }

    #top-bar{
      width:100%;
      background:var(--glass);
      backdrop-filter: blur(15px);
      padding:12px 5%;
      position:sticky; top:0;
      z-index:1000;
      border-bottom:1px solid rgba(255,255,255,0.1);
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:10px;
      flex-wrap:wrap;
    }

    .stat-pill{
      background:rgba(255,255,255,0.05);
      padding:6px 15px;
      border-radius:20px;
      border:1px solid rgba(255,255,255,0.1);
      font-size:.85rem;
      font-family:'Space Grotesk';
      display:flex; align-items:center; gap:8px;
      font-weight:bold;
      user-select:none;
      white-space:nowrap;
    }

    .combo-active{
      color:var(--eth-yellow);
      text-shadow:0 0 10px var(--eth-yellow);
      border-color:var(--eth-yellow);
    }

    #app-container{
      width:95%;
      max-width:1120px;
      margin:26px 0 50px;
      background: rgba(255,255,255,0.05);
      backdrop-filter: blur(10px);
      border-radius:30px;
      border:1px solid rgba(255,255,255,0.1);
      padding:28px;
      box-shadow: var(--shadow), inset 0 0 20px rgba(0, 210, 255, 0.05);
      position:relative;
      min-height:600px;
      overflow:hidden;
    }

    .screen{ display:none; animation: fadeIn .35s ease; }
    .active{ display:block; }
    @keyframes fadeIn{
      from{ opacity:0; transform: translateY(12px); }
      to{ opacity:1; transform: translateY(0); }
    }

    .shake{ animation:shake .42s cubic-bezier(.36,.07,.19,.97) both; border-color:var(--eth-red) !important; }
    @keyframes shake{
      10%,90%{ transform: translate3d(-2px,0,0); }
      20%,80%{ transform: translate3d(4px,0,0); }
      30%,50%,70%{ transform: translate3d(-6px,0,0); }
      40%,60%{ transform: translate3d(6px,0,0); }
    }

    .branding-header{ text-align:center; margin-bottom:24px; }
    .dev-tag{
      font-size:.75rem; color:var(--eth-green);
      font-weight:900; letter-spacing:4px;
      text-transform:uppercase;
    }

    .grid{
      display:grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap:14px;
      margin-top:18px;
    }

    .card{
      background: var(--card-bg);
      padding:20px;
      border-radius:20px;
      text-align:center;
      border:1px solid var(--card-brd);
      cursor:pointer;
      position:relative;
      overflow:hidden;
      user-select:none;
    }

    .card::before{
      content:'';
      position:absolute; top:0; left:-100%;
      width:55%; height:100%;
      background:linear-gradient(to right, transparent, rgba(255,255,255,0.12), transparent);
      transform:skewX(-20deg);
      transition:.5s;
      pointer-events:none;
    }
    .card:hover::before{ left:150%; }
    .card:hover{
      transform: translateY(-5px);
      border-color: var(--primary);
      background: rgba(255,255,255,0.08);
      box-shadow: 0 10px 20px rgba(0,210,255,0.12);
    }

    .card h3{
      margin:10px 0 6px;
      color:var(--primary);
      font-size:1.12rem;
    }
    .card p{ margin:0; font-size:.82rem; opacity:.72; }

    .btn{
      padding:12px 22px;
      border:none;
      border-radius:12px;
      font-weight:800;
      cursor:pointer;
      text-transform:uppercase;
      font-family:'Space Grotesk';
      color:white;
      background: linear-gradient(135deg, var(--secondary), var(--primary));
      box-shadow: 0 4px 15px rgba(0,210,255,0.3);
      user-select:none;
    }
    .btn:hover{ filter:brightness(1.15); transform:scale(1.03); }

    .btn-market{
      background: var(--eth-yellow);
      color: var(--dark);
      box-shadow: 0 4px 15px rgba(241,196,15,0.25);
    }

    .btn-danger{
      background: linear-gradient(135deg, #b91c1c, #ef4444);
      box-shadow: 0 4px 15px rgba(239,68,68,0.2);
    }

    .input-box{
      width:100%;
      padding:14px;
      border-radius:12px;
      border:1px solid rgba(255,255,255,0.18);
      background: rgba(0,0,0,0.35);
      color:white;
      font-size:1.05rem;
      margin-bottom:14px;
      font-family:'Space Grotesk';
      outline:none;
    }
    .input-box:focus{
      border-color:var(--primary);
      box-shadow: 0 0 10px rgba(0,210,255,0.28);
    }

    .progress-container{
      width:100%; height:10px;
      background:rgba(0,0,0,0.5);
      border-radius:10px;
      margin:16px 0;
      overflow:hidden;
      border:1px solid rgba(255,255,255,0.1);
    }
    .progress-bar{
      height:100%; width:0%;
      background: linear-gradient(90deg, var(--eth-green), var(--primary));
      transition: width .35s cubic-bezier(.4,0,.2,1);
    }

    #q-options{
      display:flex; flex-direction:column;
      gap:10px; align-items:center;
      margin-top:14px;
    }
    #quiz-area{ text-align:center; margin-top:26px; }

    .match-area{ display:flex; gap:20px; flex-wrap:wrap; justify-content:center; }
    .match-box{ flex:1; display:flex; flex-direction:column; gap:10px; min-width:250px; }
    .match-item{
      padding:14px;
      background: rgba(0,0,0,0.3);
      border-radius:12px;
      cursor:pointer;
      border:1px solid rgba(255,255,255,0.2);
      font-size:.95rem;
      text-align:center;
      transition:.2s;
      user-select:none;
    }
    .match-item:hover{ background: rgba(255,255,255,0.1); }
    .match-item.selected{
      background: var(--secondary);
      border-color: var(--primary);
      transform: scale(1.02);
      box-shadow: 0 0 15px rgba(0,210,255,0.32);
    }
    .match-item.correct{
      background: var(--eth-green);
      opacity:.55;
      pointer-events:none;
      border-color: var(--success);
    }

    #ws-grid{
      display:grid;
      background:rgba(0,0,0,0.3);
      padding:15px;
      border-radius:12px;
      margin:15px auto;
      user-select:none;
      border:1px solid rgba(255,255,255,0.1);
      width:fit-content;
    }
    .ws-cell{
      width:40px; height:40px;
      display:flex; align-items:center; justify-content:center;
      font-weight:800;
      cursor:pointer;
      border-radius:10px;
      font-size:1.2rem;
      user-select:none;
    }
    .ws-cell:hover{ background: rgba(255,255,255,0.08); }
    .ws-cell.highlighted{
      background: var(--eth-yellow);
      color: var(--dark);
      transform: scale(1.08);
      box-shadow: 0 0 10px var(--eth-yellow);
    }
    .ws-cell.found{
      background: var(--eth-green);
      color:white;
      animation: fadeIn .25s ease;
      pointer-events:none;
    }

    #ws-bank{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      justify-content:center;
      margin-top:16px;
      padding:10px;
    }
    .bank-chip{
      padding:8px 12px;
      background:rgba(0,0,0,0.45);
      border:1px solid rgba(255,255,255,0.2);
      border-radius:10px;
      font-weight:900;
      font-family:'Space Grotesk';
      letter-spacing:.4px;
    }

    #skill-display{
      font-size:3.2rem;
      font-weight:900;
      margin:22px 0;
      font-family:'Space Grotesk';
      letter-spacing:5px;
    }

    .item-list{ max-height:420px; overflow-y:auto; padding:10px; }
    .item-list::-webkit-scrollbar{ width:10px; }
    .item-list::-webkit-scrollbar-thumb{
      background: var(--primary);
      border-radius:8px;
    }

    .tutorial-item{
      background: rgba(0,0,0,0.18);
      padding:16px;
      border-radius:14px;
      margin-bottom:12px;
      border-left:4px solid var(--eth-green);
      border:1px solid rgba(255,255,255,0.08);
    }

    .modal{
      position:fixed;
      top:0; left:0;
      width:100%; height:100%;
      background: rgba(15,23,42,0.92);
      backdrop-filter: blur(6px);
      display:none;
      justify-content:center;
      align-items:center;
      z-index:2000;
      padding:18px;
    }

    .modal-content{
      background:#1e293b;
      padding:28px;
      border-radius:22px;
      max-width:560px;
      width: 96%;
      text-align:center;
      border:1px solid rgba(0,210,255,0.35);
      box-shadow: 0 0 30px rgba(0, 210, 255, 0.18);
      animation: fadeIn .25s ease;
      position:relative;
    }

    .cert-paper{
      background:#fff;
      color:#000;
      padding:38px 32px;
      border:15px solid #f1c40f;
      font-family: 'Georgia', serif;
      box-shadow: 0 0 50px rgba(241,196,15,0.45);
      max-width:760px;
    }

    .modal-close-x{
      float:right;
      cursor:pointer;
      font-size:1.4rem;
      opacity:.9;
      user-select:none;
    }

    .row{
      display:flex; gap:12px; flex-wrap:wrap;
      align-items:center; justify-content:center;
    }
    .pill{
      display:inline-flex; align-items:center; gap:8px;
      padding:8px 14px;
      border:1px solid rgba(255,255,255,0.12);
      background: rgba(255,255,255,0.05);
      border-radius:999px;
      font-family:'Space Grotesk';
      font-weight:800;
      user-select:none;
    }

    .section-title{
      font-family:'Space Grotesk';
      margin:6px 0 10px;
      color: var(--primary);
      letter-spacing:.5px;
    }

    .kpi-grid{
      display:grid;
      grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
      gap:12px;
      margin-top:14px;
    }

    .kpi{
      background: rgba(0,0,0,0.25);
      border:1px solid rgba(255,255,255,0.12);
      border-radius:16px;
      padding:14px;
      text-align:left;
      box-shadow: 0 0 18px rgba(0,210,255,0.06);
    }
    .kpi b{ font-size:1.1rem; font-family:'Space Grotesk'; }
    .kpi div{ opacity:.75; font-size:.85rem; margin-top:4px; }

    @media (max-width: 520px){
      .ws-cell{ width:34px; height:34px; font-size:1.05rem; border-radius:9px; }
      #skill-display{ font-size:2.6rem; letter-spacing:4px; }
    }

    /* NEW: Toast system (Achievement notifications & general feedback) */
    #toast-wrap{
      position:fixed;
      right:14px;
      bottom:14px;
      z-index:3000;
      display:flex;
      flex-direction:column;
      gap:10px;
      pointer-events:none;
      width:min(360px, calc(100vw - 28px));
    }
    .toast{
      pointer-events:none;
      padding:14px 14px;
      border-radius:16px;
      background: rgba(30,41,59,0.95);
      border:1px solid rgba(0,210,255,0.25);
      box-shadow: 0 10px 35px rgba(0,0,0,0.35);
      animation: toastIn .22s ease both;
    }
    @keyframes toastIn{
      from{ opacity:0; transform: translateY(10px) scale(.98); }
      to{ opacity:1; transform: translateY(0) scale(1); }
    }
    .toast strong{ font-family:'Space Grotesk'; }
    .toast .meta{ opacity:.8; margin-top:6px; font-size:.92rem; }
    .toast.win{ border-color: rgba(0,206,201,0.35); }
    .toast.warn{ border-color: rgba(241,196,15,0.35); }

    /* NEW: Player Card / Settings minor UI helpers */
    .two-col{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap:12px;
      margin-top:12px;
    }
    @media (max-width: 680px){
      .two-col{ grid-template-columns: 1fr; }
    }

    /* NEW: Accessibility focus rings */
    button:focus-visible, input:focus-visible, .card:focus-visible{
      outline: 3px solid rgba(0,210,255,0.55);
      outline-offset: 3px;
      border-radius: 12px;
    }

    /* NEW: Reduced motion support */
    @media (prefers-reduced-motion: reduce){
      *{ transition:none !important; animation:none !important; }
    }
  </style>
</head>

