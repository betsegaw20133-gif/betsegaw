      <div class="branding-header">
        <div class="dev-tag">ENGINEERED BY BETSEGAW TEKA</div>
        <h1 style="font-family:'Space Grotesk'; font-size:3.3rem; margin:10px 0; background:linear-gradient(to right,#2ecc71,#f1c40f,#e74c3c,#00d2ff); -webkit-background-clip:text; -webkit-text-fill-color:transparent; animation:pulse 2s infinite;">
          ICT MASTER OMEGA
        </h1>
        <p style="font-size:1.05rem; opacity:.85; letter-spacing:1px;">
          National Portal • SOS Children's Villages Ethiopia • Grade 7-12
        </p>
      </div>

      <input type="text" id="player-input" class="input-box" style="max-width:420px; text-align:center;" placeholder="Enter Student Full Name..." />
      <div class="row" style="margin-top:8px;">
        <button class="btn" style="font-size:1.15rem; padding:15px 50px;" onclick="initPlayer()">Access Portal</button>
