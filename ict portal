        <div class="row" style="gap:10px;">
          <button class="btn" style="padding:10px 16px;" onclick="showScreen('scr-missions'); playSound('click');">📅 MISSIONS</button>
          <button class="btn" style="padding:10px 16px;" onclick="showScreen('scr-achievements'); playSound('click');">🏅 BADGES</button>
        </div>
      </div>

      <div class="progress-container">
        <div id="mastery-bar" class="progress-bar"></div>
      </div>

      <div class="kpi-grid" style="margin-top:8px;">
