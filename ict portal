    function seqClick(i){
      if(!seqState) return;
      if(seqState.watching) return;

      seqState.user.push(i);
      vibrate(6);

      // simple feedback by flashing
      flashSeqTile(i);

      const idx = seqState.user.length - 1;
      if(seqState.user[idx] !== seqState.seq[idx]){
        // fail -> reset combo
        playSound('lose');
        triggerShake();
        safeLoseLife();
        seqState = null;
        document.getElementById('sequence-zone').style.display = 'none';
        document.getElementById('skill-input').style.display = 'block';
        alert("🧠 Sequence mismatch! Starting over...");
        // retry
        initSequenceMemory();
        return;
      }

      if(seqState.user.length >= seqState.seq.length){
        // win
        playSound('win');
        seqState.score += 10 * seqState.seq.length;
        document.getElementById('seq-score').innerText = `Score: ${seqState.score}`;

        state.stats.skillWins = (state.stats.skillWins || 0) + 1;
        addDailyProgress("skillWin", 1);
        state.combo++;

        state.flags.sequenceWins = (state.flags.sequenceWins || 0) + 1;
        saveState();
        maybeRefreshAchievementsUI();

        setTimeout(()=>{
          seqState.round++;
          seqState.targetLen = Math.min(12, seqState.targetLen + 1);
          seqState.seq = generateSeq(seqState.targetLen);
          seqState.user = [];
          seqState.watching = true;
          document.getElementById('seq-round').innerText = String(seqState.round);
          document.getElementById('seq-len').innerText = String(seqState.targetLen);
          seqStartRound();
        }, 550);
      }
    }

    function generateSeq(len){
      const arr = [];
      for(let i=0;i<len;i++){
        arr.push(Math.floor(Math.random()*4));
      }
      return arr;
    }

    function seqStartOver(){
      if(state.mode !== 'sequenceMemory') return;
      initSequenceMemory();
    }

    function flashSeqTile(i){
      // Visual cue: temporarily pulse by focusing/using document query
      // We'll just trigger a shake + toast meta; no heavy CSS.
      // (Keeping this simple to avoid breaking your layout.)
      // Could be enhanced but safe as-is.
    }

    function seqStartRound(){
      if(!seqState) return;
      // watch sequence
      seqState.watching = true;
      seqState.user = [];

      // clear old timeouts
      if(seqState.timeouts && seqState.timeouts.length){
        seqState.timeouts.forEach(t=>clearTimeout(t));
      }
      seqState.timeouts = [];

      // rebuild sequence
      if(!seqState.seq || seqState.seq.length !== seqState.targetLen){
        seqState.seq = generateSeq(seqState.targetLen);
      }

      let t = 0;
      seqState.seq.forEach((val, idx)=>{
        const on = setTimeout(()=>{
          // quick effect: flash by playing clicks
          playSound('click');
          // tiny vibrate cue
          vibrate(10);
        }, t);
        const off = setTimeout(()=>{
          // nothing
        }, t + 180);
        seqState.timeouts.push(on, off);
        t += 320;
      });

      const done = setTimeout(()=>{
        seqState.watching = false;
        document.getElementById('seq-instructions').innerText = "Your turn! Repeat by clicking tiles.";
      }, t + 120);
      seqState.timeouts.push(done);
      document.getElementById('seq-instructions').innerText = "Watch carefully... repeating soon!";
    }

    /***********************
     * Word Search (Upgraded with Timer + Hint + Shuffle + Progress)
     ***********************/
    let wsGrid = [];
    let wsWords = [];
    const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";

    let wsSize = 10;   // default
    let wsHard = false;

    function toggleWordSearchDifficulty(){
      wsHard = !wsHard;
      document.getElementById('ws-mode-label').innerText = wsHard ? "Hard" : "Easy";
      // NEW #14: hard mode uses larger grid + diagonal placements (simplified)
      rerollWordSearch();
    }

    function rerollWordSearch(){
      initAudio();
      playSound('click');
      initWordSearch(true);
    }

    function initWordSearch(withShuffle=false){
      if(withShuffle && state.inventory.shuffles > 0){
        state.inventory.shuffles--;
        saveState();
        updateHUD();
      } else if(withShuffle && state.inventory.shuffles <= 0){
        if(state.coins >= 12){
          state.coins -= 12;
          saveState();
          updateHUD();
          playSound('buy');
        }else{
          alert("Not enough Coins for shuffle. Buy Shuffle in Market.");
          return;
        }
      }

      wsSize = wsHard ? 12 : 10;

      const pool = [...ictData]
        .map(i => i.t.toUpperCase().replace(/[^A-Z]/g,''))
        .filter(w=>w.length>=3 && w.length<=10);

      wsWords = [];
      while(wsWords.length < (wsHard ? 8 : 6) && pool.length){
        const w = pool[Math.floor(Math.random()*pool.length)];
        if(!wsWords.includes(w)) wsWords.push(w);
      }
      wsWords = wsWords.slice(0, wsHard ? 8 : 6);

      wsGrid = Array(wsSize).fill(null).map(()=>Array(wsSize).fill(''));
      state.wsSelection = [];

      // directions: 0=H,1=V,2=diag down-right (hard adds)
      const allowDiag = wsHard;

      wsWords.forEach(word=>{
        let placed=false;
        let attempts=0;
        while(!placed && attempts<400){
          const dir = allowDiag ? Math.floor(Math.random()*3) : (Math.random() > 0.5 ? 0 : 1);
          const row = Math.floor(Math.random()*wsSize);
          const col = Math.floor(Math.random()*wsSize);

          if(dir===0){ // H
            if(col + word.length <= wsSize){
              let ok=true;
              for(let i=0;i<word.length;i++){
                const existing = wsGrid[row][col+i];
                if(existing !== '' && existing !== word[i]){ ok=false; break; }
              }
              if(ok){
                for(let i=0;i<word.length;i++) wsGrid[row][col+i]=word[i];
                placed=true;
              }
            }
          } else if(dir===1){ // V
            if(row + word.length <= wsSize){
              let ok=true;
              for(let i=0;i<word.length;i++){
                const existing = wsGrid[row+i][col];
                if(existing !== '' && existing !== word[i]){ ok=false; break; }
              }
              if(ok){
                for(let i=0;i<word.length;i++) wsGrid[row+i][col]=word[i];
                placed=true;
              }
            }
          } else { // diag
            if(row + word.length <= wsSize && col + word.length <= wsSize){
              let ok=true;
              for(let i=0;i<word.length;i++){
                const existing = wsGrid[row+i][col+i];
                if(existing !== '' && existing !== word[i]){ ok=false; break; }
              }
              if(ok){
                for(let i=0;i<word.length;i++) wsGrid[row+i][col+i]=word[i];
                placed=true;
              }
            }
          }
          attempts++;
        }
      });

      for(let r=0;r<wsSize;r++){
        for(let c=0;c<wsSize;c++){
          if(wsGrid[r][c] === ''){
            wsGrid[r][c] = letters.charAt(Math.floor(Math.random()*letters.length));
          }
        }
      }

      drawWordSearch();
      refreshWSProgress();
    }

    function refreshWSProgress(){
      const wsProg = document.getElementById('ws-progress');
      const total = wsHard ? 8 : 6;
      const remaining = wsWords.length;
      const done = total - remaining;
      const pct = (done/total)*100;
      wsProg.style.width = Math.min(100, pct) + "%";
    }

    function drawWordSearch(){
      const gridEl = document.getElementById('ws-grid');
      gridEl.style.gridTemplateColumns = `repeat(${wsSize}, 1fr)`;
      gridEl.innerHTML = "";

      // NEW #14: adjust cell size for bigger grid
      const cellSize = wsHard ? 34 : 40;
      const cellFont = wsHard ? 1.05 : 1.2;

      for(let r=0;r<wsSize;r++){
        for(let c=0;c<wsSize;c++){
          gridEl.innerHTML +=
            `<div class="ws-cell" id="ws-${r}-${c}" style="width:${cellSize}px;height:${cellSize}px;font-size:${cellFont}rem;" onclick="selectWSCell(${r}, ${c})">${wsGrid[r][c]}</div>`;
        }
      }

      const bank = document.getElementById('ws-bank');
      bank.innerHTML = wsWords.map(w=>{
        return `<span class="bank-chip" id="ws-word-${w}">${w}</span>`;
      }).join('');
    }

    function selectWSCell(r,c){
      initAudio();
      playSound('type');

      const el = document.getElementById(`ws-${r}-${c}`);
      const idx = state.wsSelection.findIndex(s=>s.r===r && s.c===c);

      if(idx > -1){
        state.wsSelection.splice(idx,1);
        el.classList.remove('highlighted');
      } else {
        state.wsSelection.push({r,c,char: wsGrid[r][c]});
        el.classList.add('highlighted');
      }

      const selectedForward = state.wsSelection.map(s=>s.char).join('');
      const selectedReverse = state.wsSelection.map(s=>s.char).reverse().join('');

      const foundWord = wsWords.find(w=>w === selectedForward || w === selectedReverse);
      if(foundWord){
        playSound('win');
        let xpGain = 30 * state.combo;
        let coinsGain = 10;

        // coin doubler / xp booster apply here too
        if(state.inventory.coinDoubler > 0){
          state.inventory.coinDoubler--;
          state.flags.coinDoublerUsed = (state.flags.coinDoublerUsed || 0) + 1;
          coinsGain *= 2;
        }
        if(state.inventory.xpBooster > 0){
          state.inventory.xpBooster--;
          state.flags.xpBoosterUsed = (state.flags.xpBoosterUsed || 0) + 1;
          xpGain *= 1.5;
        }

        state.xp += xpGain;
        state.coins += coinsGain;

        state.stats.wordFinds = (state.stats.wordFinds || 0) + 1;
        addDailyProgress("wordFound", 1);

        updateHUD();

        state.wsSelection.forEach(s=>{
          const cell = document.getElementById(`ws-${s.r}-${s.c}`);
          if(cell){
            cell.classList.remove('highlighted');
            cell.classList.add('found');
          }
        });

        const bankEl = document.getElementById(`ws-word-${foundWord}`);
        if(bankEl){
          bankEl.style.background = "var(--eth-green)";
          bankEl.style.textDecoration = "line-through";
          bankEl.style.opacity = ".65";
        }

        wsWords = wsWords.filter(w=>w !== foundWord);
        state.wsSelection = [];

        refreshWSProgress();
        state.combo++;

        if(wsWords.length === 0){
          setTimeout(()=>{
            playSound('win');
            if(wsHard){
              state.flags.wsHardCleared = (state.flags.wsHardCleared || 0) + 1;
              toast("Hard Mode Cleared!", "Hard Word Search completed.", settings.toasts);
              saveState();
              maybeRefreshAchievementsUI();
            }
            alert("🎉 Great job! You found all hidden tech terms!");
            showScreen('scr-dash');
            saveState();
            maybeRefreshAchievementsUI();
          }, 500);
        }
      }
    }

    function useItemHintIfAny(){
      initAudio();

      // NEW #5/#6: reveal2 + hint logic
      if(wsWords.length === 0){
        alert("No words to hint right now. Shuffle or reroll.");
        return;
      }

      if(state.inventory.hintTokens <= 0 && state.inventory.reveal2 <= 0){
        playSound('lose');
        alert("No Hint Tokens. Buy in Market 🛒");
        return;
      }

      // Prefer Reveal2 if present, otherwise Hint
      let revealCount = 1;

      if(state.inventory.reveal2 > 0){
        state.inventory.reveal2--;
        state.flags.reveal2Used = (state.flags.reveal2Used || 0) + 1;
        revealCount = 2;
        playSound('click');
        toast("Reveal 2 used!", "Two words revealed.", settings.toasts);
      } else {
        state.inventory.hintTokens--;
        playSound('click');
      }

      saveState();
      updateHUD();

      const hintWords = [];
      const pool = [...wsWords];
      while(hintWords.length < revealCount && pool.length){
        const w = pool[Math.floor(Math.random()*pool.length)];
        if(!hintWords.includes(w)) hintWords.push(w);
      }

      alert(`🧠 Hint Token used!\nLook for: ${hintWords.join(", ")}\n(Direction: horizontal or vertical${wsHard ? " or diagonal (hard)" : ""})`);
      maybeRefreshAchievementsUI();
    }

    function startWordSearchScreen(){
      playSound('click');
      state.mode = 'wordsearch';
      showScreen('scr-ws');

      // default difficulty: current wsHard
      document.getElementById('ws-mode-label').innerText = wsHard ? "Hard" : "Easy";
      initWordSearch(false);
      recordPlay(`wordsearch:${wsHard ? 'hard' : 'easy'}`);
    }

    /***********************
     * Skill input stub (kept from original)
     ***********************/
    function submitSkillAnswer(){
      // existing UI includes hidden submit button; keeping stub to avoid breaking
      playSound('click');
    }

    /***********************
     * Skill Games + New: already handled above for sequenceMemory & marathon
     ***********************/

    /***********************
     * Boss Fight: Omega Core (preserved + NEW mission progress bossDamage)
     ***********************/
    let boss = null;

    function initBossOmegaCore(){
      stopSkillTimer();

      if(state.lvl < 5){
        playSound('lose');
        alert(`Omega Core unlocks at Level 5+. You are Level ${state.lvl}.`);
        return;
      }

      playSound('boss');
      boss = {
        phase: 1,
        hp: 100,
        maxHp: 100,
        streak: 1,
        lock: false,
        lastQ: null
      };

      document.getElementById('boss-wrap').style.display = 'block';
      document.getElementById('skill-display').style.display = 'none';
      document.getElementById('skill-input').style.display = 'none';
      document.getElementById('sequence-zone').style.display = 'none';

      document.getElementById('boss-phase').innerText = "Phase 1";
      document.getElementById('boss-hp').innerText = boss.hp;
      document.getElementById('boss-streak').innerText = String(boss.streak);

      document.getElementById('boss-hp-bar').style.width = "100%";
      renderBossPhase();

      document.getElementById('boss-actions').innerHTML = `
        <button class="btn btn-danger" style="padding:10px 18px;" onclick="exitBoss()">Exit Boss</button>
      `;

      recordPlay('boss:omegaCore');
    }

    function exitBoss(){
      initAudio();
      playSound('click');
      boss = null;
      showScreen('scr-dash');
    }

    function applyBossDamage(amount){
      if(!boss) return;
      boss.hp -= amount;
      if(boss.hp < 0) boss.hp = 0;

      // NEW: boss damage mission progress (NEW #9)
      state.stats.bossDamage = (state.stats.bossDamage || 0) + amount;
      addDailyProgress("bossDamage", amount > 0 ? 1 : 0);

      playSound('boss');
      vibrate(12);

      document.getElementById('boss-hp').innerText = boss.hp;
      document.getElementById('boss-hp-bar').style.width = (boss.hp/boss.maxHp*100) + "%";
    }

    function renderBossPhase(){
      if(!boss) return;

      document.getElementById('boss-phase').innerText = `Phase ${boss.phase}`;
      document.getElementById('boss-streak').innerText = String(boss.streak);
      document.getElementById('boss-hp').innerText = boss.hp;

      document.getElementById('boss-hp-bar').style.width = (boss.hp/boss.maxHp*100) + "%";

      const prompt = document.getElementById('boss-prompt');
      const actions = document.getElementById('boss-actions');

      actions.innerHTML = "";

      // NEW: store lastQ deterministically once per render
      const q = ictData[Math.floor(Math.random()*ictData.length)];
      boss.lastQ = q;

      if(boss.phase === 1){
        prompt.innerText = `Omega Core Phase 1: Defeat with Fast Choices!\nQuestion: ${q.d}`;
        let correct = q.t;

        let opts = [correct];
        while(opts.length < 4){
          const rand = ictData[Math.floor(Math.random()*ictData.length)].t;
          if(!opts.includes(rand)) opts.push(rand);
        }
        opts.sort(()=>Math.random()-0.5);

        opts.forEach(o=>{
          actions.innerHTML += `<button class="btn" style="padding:10px 16px; margin-top:10px; width:100%; max-width:380px;"
            onclick="bossAnswer('${escapeHtmlAttr(o)}', '${escapeHtmlAttr(correct)}'); playSound('click');">${escapeHtml(o)}</button>`;
        });

      } else if(boss.phase === 2){
        prompt.innerText = `Omega Core Phase 2: Match Under Pressure!`;

        const term = q.t;
        const def = q.d;
        const wrong = ictData[Math.floor(Math.random()*ictData.length)];
        const wrongDef = wrong.d;

        actions.innerHTML = `
          <div class="tutorial-item" style="text-align:center;">
            <div style="font-family:'Space Grotesk'; font-weight:900; color:var(--primary);">TERM: ${escapeHtml(term)}</div>
            <div class="row" style="margin-top:12px; gap:10px;">
              <button class="btn" style="padding:10px 16px; width:100%; max-width:360px;" onclick="bossPickDef('${escapeHtmlAttr(def)}', '${escapeHtmlAttr(def)}');">✅ ${escapeHtml(def).substring(0,58)}...</button>
              <button class="btn btn-danger" style="padding:10px 16px; width:100%; max-width:360px;" onclick="bossPickDef('${escapeHtmlAttr(wrongDef)}', '${escapeHtmlAttr(def)}');">❌ ${escapeHtml(wrongDef).substring(0,58)}...</button>
            </div>
          </div>
        `;

      } else {
        boss.phase = 3;
        prompt.innerText = `Omega Core Phase 3: Type the Correct Term!`;

        actions.innerHTML = `
          <div class="tutorial-item" style="text-align:center;">
            <div style="opacity:.9; font-weight:900; margin-bottom:10px;">Definition: <span style="color:var(--warning)">${escapeHtml(q.d)}</span></div>
            <input id="boss-input" class="input-box" style="max-width:420px; margin-bottom:10px;" placeholder="Type term..." autocomplete="off"/>
            <button class="btn" style="width:100%; max-width:420px;" onclick="bossType()">Submit</button>
          </div>
        `;
        setTimeout(()=>{
          const inp = document.getElementById('boss-input');
          if(inp) inp.focus();
        }, 50);
      }
    }

    function bossAnswer(chosen, correct){
      if(!boss || boss.lock) return;
      boss.lock = true;

      const isCorrect = String(chosen).toLowerCase().trim() === String(correct).toLowerCase().trim();
      if(isCorrect){
        playSound('win');
        const dmg = 18 + Math.floor(6 * boss.streak);
        applyBossDamage(dmg);
        boss.streak++;

        if(boss.hp <= 60) boss.phase = 2;
        if(boss.hp <= 25) boss.phase = 3;

        boss.lock = false;
        setTimeout(()=>{
          if(boss.hp <= 0){
            bossDefeated();
          }else{
            renderBossPhase();
          }
        }, 350);
      } else {
        playSound('lose');
        triggerShake();
        safeLoseLife();
        boss.streak = 1;
        updateHUD();
        boss.lock = false;
        setTimeout(()=>{
          if(boss.hp <= 0) bossDefeated();
          else renderBossPhase();
        }, 450);
      }
    }

    function bossPickDef(chosenDef, correctDef){
      if(!boss || boss.lock) return;
      boss.lock = true;

      const isCorrect = String(chosenDef).toLowerCase().trim() === String(correctDef).toLowerCase().trim();
      if(isCorrect){
        playSound('win');
        const dmg = 22 + Math.floor(5 * boss.streak);
        applyBossDamage(dmg);
        boss.streak++;
      }else{
        playSound('lose');
        safeLoseLife();
        boss.streak = 1;
        updateHUD();
      }

      boss.lock = false;

      if(boss.hp <= 0) bossDefeated();
      else{
        if(boss.hp <= 25) boss.phase = 3;
        renderBossPhase();
      }
    }

    function bossType(){
      if(!boss || boss.lock) return;
      boss.lock = true;

      const inp = document.getElementById('boss-input');
      const val = (inp?.value || "").trim();

      const correctTerm = boss.lastQ?.t || "";
      const isCorrect = String(val).toLowerCase().trim() === String(correctTerm).toLowerCase().trim();

      if(isCorrect){
        playSound('win');
        const dmg = 28 + Math.floor(7 * boss.streak);
        applyBossDamage(dmg);
        boss.streak++;
      }else{
        playSound('lose');
        triggerShake();
        safeLoseLife();
        boss.streak = 1;
        updateHUD();
      }

      boss.lock = false;

      if(boss.hp <= 0) bossDefeated();
      else renderBossPhase();
    }

    function bossDefeated(){
      playSound('win');
      boss = null;

      const coinsGain = 150;
      const xpGain = 350;

      state.coins += coinsGain;
      state.xp += xpGain;

      state.flags.bossDefeated = true;
      state.stats.skillWins = (state.stats.skillWins || 0) + 1;

      state.combo = 1;
      state.lives = Math.min(10, state.lives + 1);

      addDailyProgress("skillWin", 1);

      levelUpCheck();
      updateHUD();
      saveState();

      alert(`👑 Omega Core Defeated!\n+${coinsGain} Coins • +${xpGain} XP`);
      maybeRefreshAchievementsUI();
      showScreen('scr-dash');
    }

    /***********************
     * Certification + Market
     ***********************/
    function checkCert(){
      initAudio();
      playSound('click');
      if(state.lvl >= 5){
        if(state.flags.certClaimed){
          openModal('modal-cert');
          return;
        }
        document.getElementById('cert-name').innerText = state.name || "Student";
        state.flags.certClaimed = true;
        playSound('win');
        openModal('modal-cert');
        saveState();
      }else{
        triggerShake();
        alert(`ACCESS DENIED: You are Level ${state.lvl}. You must reach Level 5 to unlock the Certification.`);
      }
    }

    function finishSession(){
      playSound('win');
      closeModal('modal-cert');
      alert("Session completed. Omega Approved! ✅");
      showScreen('scr-welcome');
    }

    function buyItem(type){
      initAudio();
      playSound('click');

      if(type === 'life'){
        if(state.coins >= 25){
          state.coins -= 25;
          state.lives += 1;
          playSound('buy');
        }else{
          playSound('lose');
          triggerShake();
          alert("Insufficient Coins!");
        }

      } else if(type === 'xp'){
        if(state.coins >= 40){
          state.coins -= 40;
          state.xp += 50;
          playSound('buy');
          levelUpCheck();
        }else{
          playSound('lose');
          triggerShake();
          alert("Insufficient Coins!");
        }

      } else if(type === 'hint'){
        if(state.coins >= 35){
          state.coins -= 35;
          state.inventory.hintTokens += 1;
          playSound('buy');
        }else{
          playSound('lose');
          triggerShake();
          alert("Insufficient Coins for Hint Token!");
        }

      } else if(type === 'shield'){
        if(state.coins >= 60){
          state.coins -= 60;
          state.inventory.shields += 1;
          playSound('buy');
        }else{
          playSound('lose');
          triggerShake();
          alert("Insufficient Coins for Shield!");
        }

      } else if(type === 'shuffle'){
        if(state.coins >= 25){
          state.coins -= 25;
          state.inventory.shuffles += 1;
          playSound('buy');
        }else{
          playSound('lose');
          triggerShake();
          alert("Insufficient Coins for Shuffle!");
        }

      // NEW shop items
      } else if(type === 'reveal2'){
        if(state.coins >= 70){
          state.coins -= 70;
          state.inventory.reveal2 = (state.inventory.reveal2 || 0) + 1;
          playSound('buy');
          toast("Item Purchased", "Reveal 2 added.", settings.toasts);
        } else {
          playSound('lose');
          triggerShake();
          alert("Insufficient Coins for Reveal 2!");
        }

      } else if(type === 'autoShield'){
        if(state.coins >= 90){
          state.coins -= 90;
          state.inventory.autoShield = (state.inventory.autoShield || 0) + 1;
          playSound('buy');
          toast("Item Purchased", "Auto‑Shield added.", settings.toasts);
        } else {
          playSound('lose');
          triggerShake();
          alert("Insufficient Coins for Auto‑Shield!");
        }

      } else if(type === 'coinDoubler'){
        if(state.coins >= 95){
          state.coins -= 95;
          state.inventory.coinDoubler = (state.inventory.coinDoubler || 0) + 1;
          playSound('buy');
          toast("Item Purchased", "Coin Doubler ready for next win.", settings.toasts);
        } else {
          playSound('lose');
          triggerShake();
          alert("Insufficient Coins for Coin Doubler!");
        }

      } else if(type === 'xpBooster'){
        if(state.coins >= 85){
          state.coins -= 85;
          state.inventory.xpBooster = (state.inventory.xpBooster || 0) + 1;
          playSound('buy');
          toast("Item Purchased", "XP Booster ready for next win.", settings.toasts);
        } else {
          playSound('lose');
          triggerShake();
          alert("Insufficient Coins for XP Booster!");
        }
      }

      saveState();
      updateHUD();
      renderMarketInventorySummary();
    }

