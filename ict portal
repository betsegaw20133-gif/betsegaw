        setTimeout(()=>{ focusFirstQuizOption(); }, 50);

      } else if(state.mode === 'timedChoose'){
        const timer = getQuizTimerForMode('timedChoose') || 10;

        // NEW #18: dynamic difficulty scaling
        const extra = state.lvl >= 8 ? -2 : 0;
        const scaled = Math.max(6, timer + extra);

        startQuizTimer(scaled);

        document.getElementById('q-text').innerText = q.d;
        subtitle.innerText = `Timed! Answer within ${scaled}s.`;

        let opts = [q.t];
        while(opts.length < 4){
          const rand = ictData[Math.floor(Math.random()*ictData.length)].t;
          if(!opts.includes(rand)) opts.push(rand);
        }
        opts.sort(()=>Math.random()-0.5);

        area.innerHTML = "";
        opts.forEach(o=>{
          area.innerHTML += `<button class="btn" style="width:100%; max-width:420px;" onclick="checkQuizAns('${escapeHtmlAttr(o)}')">${escapeHtml(o)}</button>`;
        });

      } else if(state.mode === 'writing' || state.mode === 'fillblank'){
