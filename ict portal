        </div>
        <div class="kpi">
          <b>Omega Gear</b>
          <div>Use items like hints, shields, and shuffles.</div>
        </div>
        <div class="kpi">
          <b>Boss Fight</b>
          <div>Face the Omega Core when you reach mastery.</div>
        </div>
      </div>
    </div>

    <!-- DASHBOARD -->
    <div id="scr-dash" class="screen">
      <div class="row" style="justify-content:space-between; margin-bottom:10px;">
        <div>
          <h2 style="font-family:'Space Grotesk'; margin:0;">Welcome to the Academy</h2>
          <div style="opacity:.65; margin-top:6px; font-size:.9rem;">
            Learn • Play • Master • Claim Your Diploma
          </div>

          <!-- NEW: Quest Streak + Difficulty hint -->
          <div style="opacity:.75; margin-top:10px; font-family:'Space Grotesk'; font-weight:900; letter-spacing:.3px;">
            🔥 Quest Streak: <span id="hud-streak">0</span> days
          </div>
          <div style="opacity:.6; margin-top:4px; font-size:.88rem;" id="hud-difficulty-label">
