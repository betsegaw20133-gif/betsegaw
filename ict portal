    // NEW: Perfect combo check helper
    function checkPerfectComboForDaily(){
      // Daily mission: perfect combo win (NEW #9/#10)
      // Condition: quiz round won and no life lost + combo >= 3 (approx rule)
      // We approximate by checking last result - used inside handleQuizResult with safeLoseLife tracking.
    }

    function handleQuizResult(isCorrect, timedOut){
      stopQuizTimer();

      if(stateLock === false) stateLock = true;

      const q = ictData[state.idx];
      const fbTitle = document.getElementById('fb-title');
      const fbText = document.getElementById('fb-text');
      const fbCombo = document.getElementById('fb-combo-msg');

      // Track life-loss for perfect-combo mission:
      const livesBefore = state.lives;

      if(isCorrect){
        playSound('win');
        vibrate(18);

        // Apply XP booster (NEW #7/#8)
        let coinGain = 5;
        let xpGain = 20 * state.combo;

        if(state.inventory && state.inventory.coinDoubler > 0){
          // Coin doubler doubles coin gain once
          state.inventory.coinDoubler = Math.max(0, state.inventory.coinDoubler - 1);
          state.flags.coinDoublerUsed = (state.flags.coinDoublerUsed || 0) + 1;
          coinGain *= 2;
          toast("Coin Doubler!", "Coins doubled for this win.", settings.toasts);
        }

        if(state.inventory && state.inventory.xpBooster > 0){
          state.inventory.xpBooster = Math.max(0, state.inventory.xpBooster - 1);
          state.flags.xpBoosterUsed = (state.flags.xpBoosterUsed || 0) + 1;
          xpGain *= 1.5;
          toast("XP Booster!", "XP boosted for this win.", settings.toasts);
        }

        state.xp += xpGain;
        state.coins += coinGain;

        fbTitle.innerText = timedOut ? "ACCESS GRANTED" : "ACCESS GRANTED";
        fbTitle.style.color = "var(--success)";
        fbText.innerText = q.d;
        fbCombo.innerText = `+${Math.floor(xpGain)} XP (Combo x${state.combo})`;

        state.stats.quizCorrect = (state.stats.quizCorrect || 0) + 1;
        addDailyProgress("quizCorrect", 1);

        state.combo++;
        state.maxCombo = Math.max(state.maxCombo || 1, state.combo);
        state.stats.maxCombo = Math.max(state.stats.maxCombo || 1, state.maxCombo);

        // Perfect combo mission check (NEW #10)
        const livesAfter = state.lives;
        if(livesAfter === livesBefore && state.combo >= 4){
          state.stats.perfectComboWins = (state.stats.perfectComboWins || 0) + 1;
          addDailyProgress("perfectCombo", 1);
          toast("Perfect Combo!", "Daily mission progress: +1", settings.toasts);
        }

      }else{
        playSound('lose');
        triggerShake();

        safeLoseLife();
        state.combo = 1;

        fbTitle.innerText = timedOut ? "TIMEOUT ACCESS DENIED" : "ACCESS DENIED";
        fbTitle.style.color = "var(--eth-red)";

        fbText.innerText = `The correct core concept was: ${q.t}`;
        fbCombo.innerText = timedOut ? "Combo Reset! (Timer)" : "Combo Reset!";
      }

      levelUpCheck();
      updateHUD();

      if(state.lives <= 0){
        playSound('lose');
        alert("Game Over! You ran out of lives. Restarting session...");
        wipeProgress();
        return;
      }

      openModal('modal-feedback');
      stateLock = false;
      maybeRefreshAchievementsUI();

      // NEW: record play
      recordPlay(`quiz:${state.mode}`);
    }

    function escapeHtml(str){
      return String(str).replace(/[&<>"']/g, s=>{
        const map = { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' };
        return map[s] || s;
      });
    }
    function escapeHtmlAttr(str){
      return String(str).replace(/'/g,"&#39;").replace(/"/g,'&quot;');
    }

    function checkQuizAns(val){
      initAudio();
      if(stateLock) return;

      const q = ictData[state.idx];
      if(!q) return;

      let isCorrect = false;

      if(state.mode === 'choosing' || state.mode === 'timedChoose'){
        isCorrect = String(val).toLowerCase().trim() === String(q.t).toLowerCase().trim();
      }else{
        isCorrect = String(val).toLowerCase().trim() === String(q.t).toLowerCase().trim();
      }

      stateLock = true;
      closeModal('modal-feedback');
      handleQuizResult(isCorrect, false);
      stateLock = false;

      vibrate(6);
    }

