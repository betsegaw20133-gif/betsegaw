<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-select=none">
    <title>Ethiopia National ICT Portal - Master Edition | by Betsegaw Teka</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #00b894;
            --secondary: #0984e3;
            --success: #00cec9;
            --danger: #d63031;
            --warning: #fdcb6e;
            --dark: #2d3436;
            --gold: #f1c40f;
            --ethiopia-green: #138808;
            --glass-bg: rgba(255, 255, 255, 0.15);
            --glass-border: rgba(255, 255, 255, 0.3);
            --glass-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%, #00cec9 200%);
            background-attachment: fixed;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            color: #fff;
        }

        /* Header UI */
        #top-bar {
            width: 100%;
            background: rgba(45, 52, 54, 0.8);
            backdrop-filter: blur(10px);
            padding: 12px 0;
            position: sticky;
            top: 0;
            z-index: 100;
            border-bottom: 1px solid var(--glass-border);
        }

        .container-hud {
            width: 90%;
            max-width: 1100px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 1.1rem;
        }

        .stat-item {
            display: flex; align-items: center; gap: 8px; font-weight: 600; text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
        }

        /* Main Game Box */
        #app-container {
            width: 90%;
            max-width: 1000px;
            margin: 40px 0;
            border-radius: 25px;
            padding: 40px;
            min-height: 550px;
            position: relative;
            overflow: hidden;
            color: var(--dark);
            background: rgba(255, 255, 255, 0.95);
            box-shadow: 0 20px 50px rgba(0,0,0,0.3);
        }

        .screen { display: none; }
        .active { display: block; animation: fadeIn 0.5s ease; }

        @keyframes fadeIn {
            from { opacity: 0; transform: scale(0.95); }
            to { opacity: 1; transform: scale(1); }
        }

        /* Branding Elements */
        .branding-header { text-align: center; margin-bottom: 30px; }
        .logo { width: 90px; height: 90px; object-fit: contain; border-radius: 50%; margin-bottom: 10px; border: 4px solid var(--ethiopia-green); box-shadow: 0 5px 15px rgba(0,0,0,0.2);}
        .dev-tag { font-size: 0.85rem; color: var(--ethiopia-green); font-weight: 900; letter-spacing: 3px; margin-bottom: 5px;}
        h1, h2 { text-align: center; color: var(--dark); margin-bottom: 5px; }
        .subtitle { text-align: center; color: #636e72; margin-bottom: 30px; font-weight: 600; }
        
        .btn {
            padding: 12px 25px; border: none; border-radius: 12px; font-weight: 700;
            cursor: pointer; transition: all 0.3s ease; text-transform: uppercase;
            letter-spacing: 1px; font-family: 'Poppins', sans-serif; box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        .btn-main { background: linear-gradient(45deg, var(--secondary), #00cec9); color: white; }
        .btn-main:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(9, 132, 227, 0.4); }
        .btn-hint { background: linear-gradient(45deg, var(--warning), #e1b12c); color: var(--dark); }
        .btn-outline { background: white; color: var(--secondary); border: 2px solid var(--secondary); }
        .btn-outline.selected { background: var(--secondary); color: white; }

        /* Resources Links */
        .book-section { display: flex; gap: 15px; margin-bottom: 25px; width: 100%; justify-content: center; flex-wrap: wrap; }
        .dl-btn { 
            padding: 12px 20px; background: #e8f4f8; color: var(--secondary); border-radius: 10px; 
            text-decoration: none; font-size: 0.95rem; font-weight: bold; display: flex; align-items: center; gap: 8px;
            border: 2px solid var(--secondary); transition: 0.3s;
        }
        .dl-btn:hover { background: var(--secondary); color: white; }

        /* Game Grid */
        .grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 25px; margin-top: 20px;
        }
        .card {
            background: white; padding: 25px; border-radius: 20px; text-align: center;
            border: 2px solid #ecf0f1; transition: 0.3s; cursor: pointer; box-shadow: 0 10px 20px rgba(0,0,0,0.05);
        }
        .card:hover { border-color: var(--secondary); transform: translateY(-8px); box-shadow: 0 15px 30px rgba(9, 132, 227, 0.2); }

        .level-badge {
            background: var(--dark); color: var(--gold); padding: 6px 18px; border-radius: 20px;
            font-size: 0.9rem; font-weight: bold; display: inline-block; box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }

        /* Progress Bar */
        .progress-container {
            width: 100%; height: 12px; background: #dfe6e9; border-radius: 10px; margin: 25px 0; overflow: hidden; box-shadow: inset 0 2px 5px rgba(0,0,0,0.1);
        }
        #progress-bar {
            height: 100%; width: 0%; background: linear-gradient(90deg, var(--primary), var(--success)); transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Matching Specifics */
        .match-area { display: flex; justify-content: space-between; gap: 20px; }
        .match-box { flex: 1; display: flex; flex-direction: column; gap: 12px; }
        .match-item { 
            padding: 18px; background: #f1f2f6; border-radius: 12px; cursor: pointer; 
            border: 2px solid #dfe4ea; text-align: center; font-weight: bold; transition: 0.2s;
        }
        .match-item:hover { background: #eccc68; }
        .match-item.selected { background: var(--secondary); border-color: var(--secondary); color: white; transform: scale(1.05); }
        .match-item.correct { background: var(--success); color: white; opacity: 0.5; pointer-events: none; }

        input[type="text"] {
            width: 100%; padding: 18px; border-radius: 12px; border: 2px solid #dfe6e9;
            font-size: 1.2rem; margin-bottom: 20px; box-sizing: border-box; font-family: 'Poppins';
        }
        input[type="text"]:focus { outline: none; border-color: var(--secondary); }

        /* --- WORD SEARCH SPECIFICS --- */
        #ws-container {
            display: flex; flex-direction: column; align-items: center; margin-top: 20px;
        }
        #ws-grid {
            display: grid; background: #f8f9fa; padding: 10px; border-radius: 12px;
            box-shadow: inset 0 4px 10px rgba(0,0,0,0.05); border: 3px solid var(--secondary);
            user-select: none; touch-action: none; margin: 15px auto;
        }
        .ws-cell {
            width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;
            font-weight: 900; font-size: 1.2rem; cursor: pointer; border-radius: 6px; color: var(--dark);
            transition: 0.1s;
        }
        .ws-cell.highlighted { background: var(--warning); color: var(--dark); transform: scale(1.1); box-shadow: 0 4px 10px rgba(0,0,0,0.2);}
        .ws-cell.found { background: var(--success) !important; color: white !important; }

        .word-bank {
            margin-top: 15px; background: white; padding: 15px; border-radius: 12px;
            width: 100%; display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;
            border: 2px solid #ecf0f1;
        }
        .word-tag { padding: 6px 15px; background: #f1f2f6; border-radius: 50px; font-size: 0.9rem; font-weight: 700; color: var(--dark); border: 1px solid #ddd; transition: 0.3s;}
        .word-tag.found { background: var(--success); color: white; text-decoration: line-through; border-color: var(--success); }

        /* Modals */
        .modal {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.8); backdrop-filter: blur(5px);
            display: none; justify-content: center; align-items: center; z-index: 1000;
        }
        .modal-content {
            background: white; padding: 40px; border-radius: 25px;
            max-width: 500px; width: 90%; text-align: center; color: var(--dark);
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        }

        /* Certificate */
        .cert-paper {
            border: 20px solid #fff; outline: 10px solid var(--gold); padding: 50px 40px;
            background: url('https://www.transparenttextures.com/patterns/cream-paper.png'), #fffaf0;
            font-family: 'Georgia', serif; position: relative; max-width: 700px;
        }
        .cert-header { font-size: 1.2rem; color: var(--secondary); text-transform: uppercase; letter-spacing: 2px; margin-bottom: 20px;}
        .cert-paper h2 { font-size: 3.5rem; margin: 0; color: #b8860b; font-weight: normal; letter-spacing: 5px; }
        .cert-name { font-size: 2.8rem; border-bottom: 2px solid var(--dark); display: inline-block; padding: 0 40px; margin: 25px 0; color: var(--dark); font-style: italic;}
        .signature-line { margin-top: 40px; display: flex; justify-content: space-between; font-size: 0.9rem; font-family: 'Poppins', sans-serif;}
        .sig-box { border-top: 1px solid var(--dark); padding-top: 5px; width: 40%; text-align: center; }
    </style>
</head>
<body>

    <div id="top-bar">
        <div class="container-hud">
            <div class="stat-item">👤 <span id="hud-name">Guest</span></div>
            <div class="stat-item">❤️ <span id="hud-lives">3</span></div>
            <div class="stat-item">🪙 <span id="hud-coins">0</span></div>
            <div class="stat-item">⏱️ <span id="hud-timer">00:00</span></div>
            <button class="btn btn-hint" style="padding: 8px 15px; font-size: 0.9rem;" onclick="openMarket()">🛒 Market</button>
        </div>
    </div>

    <div id="app-container">
        
        <div id="screen-welcome" class="screen active">
            <div class="branding-header">
                <img src="https://tse1.mm.bing.net/th/id/OIP.fG7NxAje_24iai2j6IQR_gAAAA?rs=1&pid=ImgDetMain&o=7&rm=3" alt="Logo" class="logo">
                <div class="dev-tag">ENGINEERED BY BETSEGAW TEKA</div>
                <h1 style="color: var(--ethiopia-green); font-size: 2.2rem; margin-top: 10px;">ICT MASTER: ETHIOPIA</h1>
            </div>
            <p class="subtitle">SOS Pro Edition • Grade 7 & 8 Curriculum Mastery</p>
            <div style="text-align: center; margin-top: 30px;">
                <input type="text" id="player-input" placeholder="Enter your full name to begin..." style="max-width: 400px; text-align: center;">
                <br>
                <button class="btn btn-main" style="font-size: 1.2rem; padding: 15px 40px;" onclick="initPlayer()">Join the Academy</button>
            </div>
        </div>

        <div id="screen-menu" class="screen">
            <h2>National ICT Challenge</h2>
            <p class="subtitle">Select your game mode to earn your certificate</p>
            
            <div class="book-section">
                <a href="https://camaraethiopia.org.et/OromiaPrimary/CEE_MoE_Plasma/content/ICT/Primary/ICTSBG7.pdf" class="dl-btn" target="_blank">📥 Grade 7 Textbook</a>
                <a href="https://camaraethiopia.org.et/OromiaPrimary/CEE_MoE_Plasma/content/ICT/Primary/ICTSBG8.pdf" class="dl-btn" target="_blank">📥 Grade 8 Textbook</a>
            </div>

            <div class="grid">
                <div class="card" onclick="startMode('choosing')">
                    <div class="level-badge">30 Levels</div>
                    <h3 style="color: var(--secondary)">Choosing Game</h3>
                    <p>Multiple Choice</p>
                </div>
                <div class="card" onclick="startMode('writing')">
                    <div class="level-badge">30 Levels</div>
                    <h3 style="color: var(--secondary)">Writing Game</h3>
                    <p>Vocabulary & Defs</p>
                </div>
                <div class="card" onclick="startMode('matching')">
                    <div class="level-badge">30 Levels</div>
                    <h3 style="color: var(--secondary)">Matching Game</h3>
                    <p>Logic Connections</p>
                </div>
                <div class="card" onclick="startMode('fillblank')">
                    <div class="level-badge">30 Levels</div>
                    <h3 style="color: var(--secondary)">Fill in Blank</h3>
                    <p>Sentence Gaps</p>
                </div>
                <div class="card" onclick="startMode('wordsearch')" style="border-color: var(--ethiopia-green); background: #f0fdf4;">
                    <div class="level-badge" style="background: var(--ethiopia-green);">10 Levels</div>
                    <h3 style="color: var(--ethiopia-green)">Word Search</h3>
                    <p>Find the Concepts</p>
                </div>
            </div>
        </div>

        <div id="screen-game" class="screen">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <button class="btn" style="background: #dfe6e9; color: var(--dark);" onclick="goHome()">🏠 Menu</button>
                <div id="game-level-tag" class="level-badge">Level 1/30</div>
            </div>
            <div class="progress-container"><div id="progress-bar"></div></div>

            <div id="question-area" style="text-align: center; margin: 30px 0; min-height: 100px;">
                <h2 id="q-text" style="font-size: 1.8rem; margin-bottom: 20px;">Question loading...</h2>
                <button class="btn" style="background:var(--success); color:white; padding: 8px 20px;" onclick="speakText()">🔊 Listen</button>
            </div>
            <div id="answer-container"></div>

            <div style="margin-top: 40px; display: flex; justify-content: center; gap: 20px; align-items: center;">
                <button class="btn btn-hint" onclick="useHint()">💡 Hint (10 🪙)</button>
                <div id="hint-box" style="display:none; color: var(--secondary); font-style: italic; font-weight: bold;"></div>
            </div>
        </div>

        <div id="screen-wordsearch" class="screen">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <button class="btn" style="background: #dfe6e9; color: var(--dark);" onclick="goHome()">🏠 Menu</button>
                <div id="ws-level-tag" class="level-badge" style="background: var(--ethiopia-green);">Level 1/10</div>
            </div>
            <div class="progress-container"><div id="ws-progress-bar" style="background: var(--ethiopia-green);"></div></div>

            <div id="ws-container">
                <div style="display: flex; gap: 10px; margin-bottom: 10px;">
                    <button class="btn btn-outline" id="btn-easy" onclick="setWSDiff('easy')">Easy</button>
                    <button class="btn btn-outline" id="btn-medium" onclick="setWSDiff('medium')">Medium</button>
                    <button class="btn btn-outline" id="btn-hard" onclick="setWSDiff('hard')">Hard</button>
                </div>
                
                <div id="ws-grid"></div>
                <div class="word-bank" id="ws-bank"></div>
            </div>
        </div>

    </div>

    <div id="modal-feedback" class="modal">
        <div class="modal-content">
            <h2 id="feedback-title">Result</h2>
            <p id="feedback-text" style="font-size: 1.2rem; margin: 20px 0;"></p>
            <button class="btn btn-main" style="width: 100%;" onclick="closeFeedback()">Next Challenge</button>
        </div>
    </div>

    <div id="modal-market" class="modal">
        <div class="modal-content">
            <span style="float:right; cursor:pointer; font-size: 1.5rem;" onclick="closeMarket()">✖</span>
            <h2>🛒 ICT Market</h2>
            <p>Your Balance: <span id="market-balance" style="font-weight: bold; color: var(--warning);">0</span> 🪙</p>
            <hr style="border: 1px solid #eee; margin: 20px 0;">
            <div style="display:flex; flex-direction:column; gap:15px;">
                <button class="btn btn-main" onclick="buyItem('life')">Buy 1 ❤️ (25 Coins)</button>
                <button class="btn btn-main" style="background: var(--dark);" onclick="buyItem('time')">Freeze Timer ⏱️ (15 Coins)</button>
            </div>
        </div>
    </div>

    <div id="modal-cert" class="modal">
        <div class="modal-content cert-paper">
            <div class="cert-header">SOS Children's Villages • Ethiopia</div>
            <h2>CERTIFICATE</h2>
            <p style="font-size: 1.2rem; letter-spacing: 2px;">OF ACADEMIC EXCELLENCE</p>
            <p style="margin-top: 30px;">This proudly certifies that</p>
            <div class="cert-name" id="cert-user-name">Student Name</div>
            <p>has successfully mastered the</p>
            <h3 id="cert-game-mode" style="color:var(--secondary); font-size: 1.8rem; margin: 10px 0;">CHOOSING GAME</h3>
            <p>demonstrating outstanding knowledge of the Grade 7 & 8 ICT National Syllabus.</p>
            
            <div class="signature-line">
                <div class="sig-box">
                    <strong>National ICT Portal</strong><br>System Assessment
                </div>
                <div class="sig-box">
                    <strong>Betsegaw Teka</strong><br>Lead Developer & Educator
                </div>
            </div>
            <button class="btn btn-main" style="margin-top: 40px;" onclick="location.reload()">Claim Certificate & Finish</button>
        </div>
    </div>

    <script>
        // --- GLOBAL STATE ---
        let state = {
            name: "", coins: 50, lives: 3, timer: 0,
            currentMode: "", currentIndex: 0, timerActive: false, timerFrozen: false
        };

        // --- MASTER DICTIONARY (Quiz Modes) ---
        const ictConcepts = [
            { term: "CPU", def: "The main brain of the computer that processes instructions.", blank: "The ___ is considered the brain of the computer.", category: "Hardware" },
            { term: "RAM", def: "Temporary memory used by the computer while it is running.", blank: "___ is volatile memory that loses data when power is off.", category: "Hardware" },
            { term: "ROM", def: "Permanent memory that holds startup instructions.", blank: "___ contains the BIOS and cannot be easily modified.", category: "Hardware" },
            { term: "Motherboard", def: "The main circuit board connecting all components.", blank: "Every component inside a computer connects to the ___.", category: "Hardware" },
            { term: "Software", def: "Programs and instructions that tell the computer what to do.", blank: "Apps and Operating Systems are examples of ___.", category: "Software" },
            { term: "Hardware", def: "The physical parts of a computer you can touch.", blank: "Monitors, keyboards, and mice are classified as ___.", category: "Hardware" },
            { term: "Operating System", def: "System software that manages computer hardware and software.", blank: "Windows, Linux, and Android are types of ___.", category: "Software" },
            { term: "Network", def: "Two or more computers connected together to share resources.", blank: "A ___ allows computers in a school lab to share a printer.", category: "Networking" },
            { term: "Internet", def: "A global network of connected computers.", blank: "The ___ connects millions of networks worldwide.", category: "Networking" },
            { term: "Browser", def: "Software used to view websites on the Internet.", blank: "Chrome, Firefox, and Edge are examples of a web ___.", category: "Software" },
            { term: "Search Engine", def: "A website used to look for information on the Internet.", blank: "Google and Bing are examples of a ___.", category: "Internet" },
            { term: "URL", def: "The web address of a specific page or file on the Internet.", blank: "A web address like www.google.com is called a ___.", category: "Internet" },
            { term: "HTML", def: "The standard language used to create web pages.", blank: "Websites are built using a markup language called ___.", category: "Coding" },
            { term: "Virus", def: "A malicious program designed to harm a computer.", blank: "A computer ___ can delete your files or slow down your PC.", category: "Security" },
            { term: "Antivirus", def: "Software designed to detect and remove malicious programs.", blank: "You should install an ___ to protect your computer from malware.", category: "Security" },
            { term: "Password", def: "A secret combination of characters used to access an account.", blank: "Always keep your ___ secret to prevent unauthorized access.", category: "Security" },
            { term: "Firewall", def: "A security system that monitors network traffic.", blank: "A ___ blocks unauthorized access from hackers on the internet.", category: "Security" },
            { term: "Server", def: "A powerful computer that provides data to other computers.", blank: "Websites are stored on a powerful computer called a ___.", category: "Networking" },
            { term: "Router", def: "A device that forwards data packets between computer networks.", blank: "A ___ is used to connect your home network to the internet.", category: "Networking" },
            { term: "Word Processor", def: "Software used to create, edit, and print text documents.", blank: "Microsoft Word is the most popular ___ application.", category: "Software" },
            { term: "Spreadsheet", def: "Software used to organize and analyze data in rows and columns.", blank: "Microsoft Excel is an example of a ___ program.", category: "Software" },
            { term: "Database", def: "An organized collection of data, generally stored electronically.", blank: "A school uses a ___ to store all student records securely.", category: "Software" },
            { term: "Input Device", def: "Hardware used to send data into the computer.", blank: "A keyboard and mouse are examples of an ___.", category: "Hardware" },
            { term: "Output Device", def: "Hardware used to receive data from the computer.", blank: "A monitor and printer are examples of an ___.", category: "Hardware" },
            { term: "Storage Device", def: "Hardware used to save data permanently.", blank: "A USB Flash Drive is a portable ___.", category: "Hardware" },
            { term: "Algorithm", def: "A step-by-step set of instructions to solve a problem.", blank: "Programmers write an ___ before writing the actual code.", category: "Coding" },
            { term: "Debugging", def: "The process of finding and fixing errors in a computer program.", blank: "Fixing errors in your code is called ___.", category: "Coding" },
            { term: "ISP", def: "A company that provides access to the internet.", blank: "Ethio Telecom is an example of an ___ in Ethiopia.", category: "Networking" },
            { term: "Email", def: "Electronic messages sent over a network.", blank: "Gmail and Outlook are used for sending ___.", category: "Internet" },
            { term: "Cloud Computing", def: "Storing and accessing data over the internet instead of a hard drive.", blank: "Google Drive is an example of ___ storage.", category: "Internet" }
        ];

        // --- WORD SEARCH DICTIONARY ---
        const WS_WORDS = {
            easy: ["MOUSE", "WIFI", "CLICK", "DATA", "ICON", "FILE", "RAM", "WEB", "MODEM", "USER", "LOGO", "DISK", "KEY", "LINK", "CHIP"],
            medium: ["MONITOR", "BATTERY", "TABLET", "ROUTER", "MEMORY", "WINDOWS", "BROWSER", "HARDWARE", "SOFTWARE", "PRINTER", "SERVER", "CAMERA", "FOLDER", "GOOGLE"],
            hard: ["PROCESSOR", "DATABASE", "SECURITY", "NETWORK", "FIREWALL", "GRAPHICS", "INTERNET", "PROTOCOL", "COMPILER", "CHIPSET", "PROGRAM", "STORAGE", "SCANNER"]
        };

        const gameData = { choosing: [], writing: [], matching: [], fillblank: [] };

        function generateDatabase() {
            for(let i=0; i<30; i++) {
                const concept = ictConcepts[i];
                let wrongOptions = ictConcepts.filter(c => c.term !== concept.term).sort(() => 0.5 - Math.random()).slice(0, 3).map(c => c.term);
                let options = [concept.term, ...wrongOptions].sort(() => 0.5 - Math.random());
                gameData.choosing.push({ q: `What is the correct term for: "${concept.def}"`, options: options, answer: concept.term, hint: `Starts with ${concept.term.charAt(0)}...`, explain: concept.def });
                gameData.writing.push({ q: `Type the exact term for: "${concept.def}"`, answer: concept.term, hint: `It has ${concept.term.length} letters.`, explain: concept.def });
                gameData.fillblank.push({ q: concept.blank, answer: concept.term, hint: `Category: ${concept.category}`, explain: concept.def });
                let extraPairs = ictConcepts.filter(c => c.term !== concept.term).sort(() => 0.5 - Math.random()).slice(0, 2);
                gameData.matching.push({
                    pairs: [
                        {a: concept.def.substring(0, 25) + "...", b: concept.term},
                        {a: extraPairs[0].def.substring(0, 25) + "...", b: extraPairs[0].term},
                        {a: extraPairs[1].def.substring(0, 25) + "...", b: extraPairs[1].term}
                    ],
                    explain: `Correct! ${concept.term} matched successfully.`
                });
            }
        }
        generateDatabase();

        // --- CORE LOGIC ---
        function initPlayer() {
            let n = document.getElementById('player-input').value;
            if(!n) return alert("Please enter your name to generate your certificate.");
            state.name = n;
            document.getElementById('hud-name').innerText = n;
            showScreen('screen-menu');
            startGlobalTimer();
        }

        function showScreen(id) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById(id).classList.add('active');
        }

        function startGlobalTimer() {
            if(state.timerActive) return;
            state.timerActive = true;
            setInterval(() => {
                if(!state.timerFrozen) state.timer++;
                let m = Math.floor(state.timer/60).toString().padStart(2,'0');
                let s = (state.timer%60).toString().padStart(2,'0');
                document.getElementById('hud-timer').innerText = `${m}:${s}`;
            }, 1000);
        }

        function updateHUD() {
            document.getElementById('hud-coins').innerText = state.coins;
            document.getElementById('hud-lives').innerText = state.lives;
            document.getElementById('market-balance').innerText = state.coins;
            if(state.lives <= 0) {
                alert("Game Over! Your lives have run out. Academy reset.");
                location.reload();
            }
        }

        function startMode(mode) {
            state.currentMode = mode;
            state.currentIndex = 0;
            state.timerFrozen = false;
            if(mode === 'wordsearch') {
                showScreen('screen-wordsearch');
                setWSDiff('easy');
            } else {
                showScreen('screen-game');
                loadQuestion();
            }
        }

        function goHome() {
            if(confirm("Return to menu? Your progress in this mode will be lost.")) {
                showScreen('screen-menu');
            }
        }

        // --- QUIZ & MATCHING LOGIC ---
        function loadQuestion() {
            updateHUD();
            document.getElementById('hint-box').style.display = "none";
            const q = gameData[state.currentMode][state.currentIndex];
            const area = document.getElementById('answer-container');
            document.getElementById('progress-bar').style.width = ((state.currentIndex) / 30) * 100 + "%";
            document.getElementById('game-level-tag').innerText = `Level ${state.currentIndex + 1} of 30`;
            area.innerHTML = "";
            
            if(state.currentMode === 'choosing') {
                document.getElementById('q-text').innerText = q.q;
                q.options.forEach(opt => {
                    area.innerHTML += `<button class="btn btn-main" style="width:100%; margin-bottom:15px; font-size: 1.1rem;" onclick="checkAnswer('${opt}')">${opt}</button>`;
                });
            } else if(state.currentMode === 'writing' || state.currentMode === 'fillblank') {
                document.getElementById('q-text').innerText = q.q;
                area.innerHTML = `<input type="text" id="text-ans" placeholder="Type your answer here..." autocomplete="off" onkeypress="if(event.key==='Enter') checkTextAnswer()"><br>
                                  <button class="btn btn-main" style="width: 100%; font-size: 1.2rem;" onclick="checkTextAnswer()">Submit Answer</button>`;
                setTimeout(() => document.getElementById('text-ans').focus(), 100);
            } else if(state.currentMode === 'matching') {
                document.getElementById('q-text').innerText = "Match the Definitions to the Terms!";
                renderMatching();
            }
        }

        let selA = null, selB = null;
        function renderMatching() {
            const q = gameData.matching[state.currentIndex];
            const area = document.getElementById('answer-container');
            let html = `<div class="match-area"><div class="match-box">`;
            q.pairs.forEach((p, i) => html += `<div class="match-item" onclick="selectMatch('A', ${i}, this)">${p.a}</div>`);
            html += `</div><div class="match-box">`;
            let shuffledB = [...q.pairs].sort(() => Math.random() - 0.5);
            shuffledB.forEach((p, i) => html += `<div class="match-item" onclick="selectMatch('B', '${p.b}', this)">${p.b}</div>`);
            html += `</div></div>`;
            area.innerHTML = html;
        }

        function selectMatch(side, val, el) {
            if(side === 'A') {
                if(selA) selA.el.classList.remove('selected');
                selA = {val: val, el: el};
            } else {
                if(selB) selB.el.classList.remove('selected');
                selB = {val: val, el: el};
            }
            el.classList.add('selected');
            if(selA && selB) {
                const q = gameData.matching[state.currentIndex];
                if(q.pairs[selA.val].b === selB.val) {
                    selA.el.classList.add('correct'); selB.el.classList.add('correct');
                    selA = null; selB = null;
                    if(document.querySelectorAll('.match-item.correct').length === q.pairs.length * 2) {
                        setTimeout(() => checkAnswer(true), 500);
                    }
                } else {
                    state.lives--; updateHUD();
                    selA.el.classList.remove('selected'); selB.el.classList.remove('selected');
                    selA = null; selB = null;
                }
            }
        }

        function checkTextAnswer() {
            const val = document.getElementById('text-ans').value.toLowerCase().trim();
            const correct = gameData[state.currentMode][state.currentIndex].answer.toLowerCase();
            checkAnswer(val === correct);
        }

        function checkAnswer(isCorrect) {
            const q = gameData[state.currentMode][state.currentIndex];
            const modal = document.getElementById('modal-feedback');
            const title = document.getElementById('feedback-title');
            const text = document.getElementById('feedback-text');

            if(typeof isCorrect === 'string') isCorrect = (isCorrect.toLowerCase() === q.answer.toLowerCase());

            if(isCorrect) {
                state.coins += 10; title.innerText = "🌟 CORRECT!"; title.style.color = "var(--success)"; text.innerText = q.explain;
            } else {
                state.lives--; title.innerText = "❌ INCORRECT!"; title.style.color = "var(--danger)"; text.innerText = "The correct answer was: " + (q.answer || "Correct Match");
            }
            updateHUD(); modal.style.display = "flex";
        }

        function closeFeedback() {
            document.getElementById('modal-feedback').style.display = "none";
            state.currentIndex++;
            if(state.currentIndex >= 30) showCertificate(state.currentMode.toUpperCase() + " MASTERY");
            else loadQuestion();
        }

        // --- WORD SEARCH LOGIC ---
        let wsDiff = 'easy', wsLevel = 1, wsTarget = [], wsFound = [], wsSelected = [], wsIsDown = false, wsStartPos = null;
        
        function setWSDiff(val) {
            wsDiff = val; wsLevel = 1;
            document.querySelectorAll('#ws-container .btn-outline').forEach(b => b.classList.remove('selected'));
            document.getElementById('btn-'+val).classList.add('selected');
            initWordSearch();
        }

        function initWordSearch() {
            updateHUD();
            document.getElementById('ws-level-tag').innerText = `Level ${wsLevel}/10`;
            document.getElementById('ws-progress-bar').style.width = ((wsLevel-1)/10)*100 + "%";
            
            const size = wsDiff === 'easy' ? 10 : (wsDiff === 'medium' ? 12 : 14);
            wsTarget = [...WS_WORDS[wsDiff]].sort(() => 0.5 - Math.random()).slice(0, 5);
            wsFound = [];
            
            let grid = Array(size).fill().map(() => Array(size).fill(''));
            wsTarget.forEach(word => {
                let placed = false;
                while (!placed) {
                    let dir = Math.floor(Math.random() * (wsDiff === 'easy' ? 2 : (wsDiff === 'medium' ? 3 : 4))); 
                    let r = Math.floor(Math.random() * size), c = Math.floor(Math.random() * size);
                    let dr = 0, dc = 0; let w = word;

                    if (dir === 0) dc = 1;
                    if (dir === 1) dr = 1;
                    if (dir === 2) { dr = 1; dc = 1; }
                    if (dir === 3) { w = w.split('').reverse().join(''); dc = 1; }

                    if (r + dr * w.length <= size && c + dc * w.length <= size) {
                        let ok = true;
                        for (let i=0; i<w.length; i++) if (grid[r+i*dr][c+i*dc] !== '' && grid[r+i*dr][c+i*dc] !== w[i]) ok = false;
                        if (ok) { for (let i=0; i<w.length; i++) grid[r+i*dr][c+i*dc] = w[i]; placed = true; }
                    }
                }
            });

            const gridEl = document.getElementById('ws-grid');
            gridEl.innerHTML = ''; gridEl.style.gridTemplateColumns = `repeat(${size}, 1fr)`;
            for (let r=0; r<size; r++) {
                for (let c=0; c<size; c++) {
                    const el = document.createElement('div');
                    el.className = 'ws-cell'; el.innerText = grid[r][c] || "ABCDEFGHIJKLMNOPQRSTUVWXYZ"[Math.floor(Math.random()*26)];
                    el.dataset.r = r; el.dataset.c = c;
                    el.onmousedown = () => wsStartSelection(r, c);
                    el.onmouseenter = () => wsMoveSelection(r, c);
                    el.ontouchstart = (e) => { e.preventDefault(); wsStartSelection(r, c); };
                    el.ontouchmove = (e) => {
                        let t = e.touches[0];
                        let target = document.elementFromPoint(t.clientX, t.clientY);
                        if (target && target.dataset.r) wsMoveSelection(parseInt(target.dataset.r), parseInt(target.dataset.c));
                    };
                    gridEl.appendChild(el);
                }
            }
            const bank = document.getElementById('ws-bank'); bank.innerHTML = '';
            wsTarget.forEach(w => bank.innerHTML += `<span class="word-tag" id="w-${w}">${w}</span>`);
        }

        function wsStartSelection(r, c) { wsIsDown = true; wsStartPos = {r, c}; wsSelected = [{r, c}]; wsHighlight(); }
        function wsMoveSelection(r, c) {
            if (!wsIsDown) return;
            let dr = r - wsStartPos.r, dc = c - wsStartPos.c;
            if (dr === 0 || dc === 0 || Math.abs(dr) === Math.abs(dc)) {
                wsSelected = [];
                let steps = Math.max(Math.abs(dr), Math.abs(dc));
                let rStep = dr === 0 ? 0 : dr/steps, cStep = dc === 0 ? 0 : dc/steps;
                for(let i=0; i<=steps; i++) wsSelected.push({r: wsStartPos.r + i*rStep, c: wsStartPos.c + i*cStep});
                wsHighlight();
            }
        }
        function wsHighlight() {
            document.querySelectorAll('.ws-cell').forEach(c => c.classList.remove('highlighted'));
            wsSelected.forEach(p => document.querySelector(`.ws-cell[data-r="${p.r}"][data-c="${p.c}"]`)?.classList.add('highlighted'));
        }
        function wsEndSelection() {
            if (!wsIsDown) return;
            wsIsDown = false;
            let cells = wsSelected.map(p => document.querySelector(`.ws-cell[data-r="${p.r}"][data-c="${p.c}"]`));
            let str = cells.filter(c => c).map(c => c.innerText).join('');
            let rev = str.split('').reverse().join('');
            let match = wsTarget.find(w => w === str || w === rev);
            
            if (match && !wsFound.includes(match)) {
                wsFound.push(match); state.coins += 5; updateHUD();
                document.getElementById('w-'+match).classList.add('found');
                cells.forEach(c => c && c.classList.add('found'));
                if (wsFound.length === 5) {
                    if(wsLevel < 10) { 
                        wsLevel++; setTimeout(() => { alert(`Level ${wsLevel-1} Complete! +25 Bonus Coins`); state.coins += 25; initWordSearch(); }, 300); 
                    } else {
                        showCertificate("WORD SEARCH MASTERY");
                    }
                }
            } else if (wsSelected.length > 2) {
                state.lives--; updateHUD();
                if(state.lives <= 0) return; // Handled by updateHUD
            }
            document.querySelectorAll('.ws-cell').forEach(c => c.classList.remove('highlighted'));
        }
        window.onmouseup = wsEndSelection; window.ontouchend = wsEndSelection;

        // --- GLOBAL UTILS ---
        function showCertificate(modeTitle) {
            document.getElementById('cert-user-name').innerText = state.name;
            document.getElementById('cert-game-mode').innerText = modeTitle;
            document.getElementById('modal-cert').style.display = "flex";
        }
        function openMarket() { document.getElementById('modal-market').style.display = "flex"; }
        function closeMarket() { document.getElementById('modal-market').style.display = "none"; }
        function buyItem(type) {
            if(type === 'life' && state.coins >= 25) { state.coins -= 25; state.lives++; } 
            else if(type === 'time' && state.coins >= 15) { state.coins -= 15; state.timerFrozen = true; alert("Timer frozen!"); } 
            else { alert("Not enough coins!"); }
            updateHUD();
        }
        function useHint() {
            if(state.coins >= 10) {
                state.coins -= 10; updateHUD();
                const q = gameData[state.currentMode][state.currentIndex];
                const box = document.getElementById('hint-box');
                box.innerText = "Hint: " + q.hint; box.style.display = "block";
            } else { alert("You need 10 coins for a hint!"); }
        }
        function speakText() {
            let textToSpeak = document.getElementById('q-text').innerText;
            if(textToSpeak.includes("___")) textToSpeak = textToSpeak.replace("___", "blank");
            const speech = new SpeechSynthesisUtterance(textToSpeak);
            speech.rate = 0.9; window.speechSynthesis.speak(speech);
        }
    </script>
</body>
