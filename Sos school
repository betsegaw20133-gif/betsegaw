            buy: function(item, cost) {
                if(this.coins < cost){
                    alert("Not enough coins!");
                    return;
                }
                this.coins -= cost;

                if(item === 'life') this.lives++;
                if(item === 'freeze') this.freezeAvailable++;
                if(item === 'hint') this.hintAvailable++;

                // If freeze is bought during play, extend current timer
                if(item === 'freeze' && this.currentScreen === 'play'){
                    this.timeLeft = Math.min(this.baseSec + 5, this.timeLeft + 5);
                    this.startTimer(this.timeLeft);
                }

                this.playSfx('correct');
                this.updateUI();
            },

