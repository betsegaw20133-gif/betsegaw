        function renderTimetable() {
            const data = timetableData[picker.value];
            let html = `<table><thead><tr><th>Day</th>`;
            for (let i = 1; i <= 7; i++) html += `<th>${i}</th>`;
            html += `</tr></thead><tbody>`;

            const days = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"];
            days.forEach(day => {
                html += `<tr><td style="background:#f1f5f9; font-weight:1000;">${day}</td>`;
                const subs = data[day] || [];
                for (let i = 0; i < 7; i++) {
                    html += `<td>${subs[i] || '-'}</td>`;
                }
                html += `</tr>`;
            });

            html += `</tbody></table>`;
            tableBox.innerHTML = html;
        }

