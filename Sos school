            normalizeEnglishAnswer: function(input){
                return (input || '').toUpperCase().trim().replace(/\s+/g,' ');
            },

            startTimer: function(sec) {
                if(this.timerId) clearInterval(this.timerId);
                let bar = document.getElementById('gym-timer-bar');
                let width = 100;

                this.timeLeft = sec;

                this.timerId = setInterval(() => {
                    if(this.paused) return;
                    this.timeLeft -= 1;

                    // width based on remaining time
                    width = (this.timeLeft / sec) * 100;
                    bar.style.width = Math.max(width, 0) + "%";

                    if(this.timeLeft <= 0) {
                        clearInterval(this.timerId);
                        this.timerId = null;
                        this.lives--;
                        this.updateUI();
                        if(this.lives <= 0) this.reset();
                        else this.nextTask();
                    }
                }, 1000);
            },

            checkAnswer: function() {
                if(this.paused) return;
                if(this.lives <= 0) return this.reset();

                let input = document.getElementById('gym-answer-input').value;
                let val = (input || '').toUpperCase().trim().replace(/\s+/g,' ');

                let isCorrect = false;

                if(this.mode === 'math'){
                    isCorrect = (val === this.answer);
                } else if(this.mode === 'english'){
                    // this.answer may contain "/" accepted variants
                    const answers = this.answer.split('/').map(x=>x.trim());
                    isCorrect = answers.includes(val) || answers.some(a=>a.includes(val)) || answers.some(a=>val.includes(a));
                }

                if(isCorrect) {
                    const bonus = this.difficulty === 'Hard' ? 25 : this.difficulty === 'Easy' ? 10 : 15;
                    this.coins += (this.timeLeft > 7 ? 15 : 10) + bonus/5; // small extra feel
                    this.playSfx('correct');
                    this.nextTask();
                } else {
                    this.playSfx('wrong');
                    this.lives--;
                    this.updateUI();
                    if(this.lives <= 0) this.reset();
                    else this.nextTask();
                }
                this.updateUI();
            },

            playSfx: function(kind){
                try{
                    if(!this.soundEnabled) return;
                    // simple beep using WebAudio (no external assets)
                    const AudioCtx = window.AudioContext || window.webkitAudioContext;
                    if(!AudioCtx) return;
                    const ctx = new AudioCtx();
                    const o = ctx.createOscillator();
                    const g = ctx.createGain();
                    o.connect(g);
                    g.connect(ctx.destination);

                    const now = ctx.currentTime;
                    if(kind === 'correct'){
                        o.type = 'triangle';
                        o.frequency.setValueAtTime(740, now);
                        g.gain.setValueAtTime(0.0001, now);
                        g.gain.exponentialRampToValueAtTime(0.08, now+0.01);
                        g.gain.exponentialRampToValueAtTime(0.0001, now+0.12);
                        o.start(now);
                        o.stop(now+0.13);
                    }else{
                        o.type = 'sawtooth';
                        o.frequency.setValueAtTime(220, now);
                        g.gain.setValueAtTime(0.0001, now);
                        g.gain.exponentialRampToValueAtTime(0.08, now+0.01);
                        g.gain.exponentialRampToValueAtTime(0.0001, now+0.12);
                        o.start(now);
                        o.stop(now+0.13);
                    }
                    setTimeout(()=>{ ctx.close && ctx.close(); }, 250);
                }catch(err){
                    // ignore
                }
            },

            initMemory: function() {
                const board = document.getElementById('mem-board');
                board.innerHTML = '';

                // Difficulty affects memory grid size
                const pairs = this.difficulty === 'Easy' ? 6 : this.difficulty === 'Hard' ? 10 : 8; // pairs
                const iconsPool = ['🍎','🍎','🚀','🚀','⚡','⚡','⚽','⚽','💎','💎','🌈','🌈','🎵','🎵','📚','📚','🏆','🏆','🧠','🧠','🎯','🎯','🍀','🍀'];

                const icons = iconsPool.slice(0, pairs*2).sort(() => 0.5 - Math.random());

                // Adjust grid columns for many cards
                const cols = this.difficulty === 'Hard' ? 5 : 4;
                board.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;

                let flipped = [];
                let lock = false;

                icons.forEach(icon => {
                    let card = document.createElement('div');
                    card.className = 'gym-card-btn';
                    card.style.fontSize = "2.1rem";
                    card.style.minHeight = "78px";
                    card.style.background = "rgba(255,255,255,0.05)";
                    card.style.borderColor = "rgba(255,255,255,0.1)";

                    card.onclick = () => {
                        if(lock) return;
                        if(card.innerText || flipped.length >= 2) return;

                        card.innerText = icon;
                        card.style.background = "white";
                        flipped.push(card);

                        if(flipped.length === 2) {
                            lock = true;

                            if(flipped[0].innerText === flipped[1].innerText) {
                                this.coins += 18;
                                this.playSfx('correct');
                                setTimeout(()=>{
                                    flipped.forEach(c=>{
                                        c.style.opacity = '0.7';
                                        c.style.pointerEvents = 'none';
                                    });
                                    flipped = [];
                                    lock = false;

                                    // Win condition: no face-down cards left
                                    const remaining = Array.from(board.children).some(c=>!c.innerText || c.innerText==='');
                                    if(!remaining){
                                        alert("Memory complete! Coins: " + this.coins);
                                        this.goHome();
                                    }
                                    this.updateUI();
                                }, 450);
                            } else {
                                this.playSfx('wrong');
                                setTimeout(()=>{
                                    flipped.forEach(c => {
                                        c.innerText = '';
                                        c.style.background = "rgba(255,255,255,0.05)";
                                    });
                                    flipped = [];
                                    lock = false;
                                }, 700);
                            }
                        }
                    };

                    board.appendChild(card);
                });
            },

            toggleShop: function() {
