        /* HEADER DECORATION */
        header {
            background: var(--glass);
            backdrop-filter: blur(10px);
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            position: sticky; top: 0; z-index: 1000;
            border-bottom: 3px solid var(--primary);
        }
        .header-container {
            max-width: 1300px; margin: auto;
            display: flex; justify-content: space-between; align-items: center;
            padding: 12px 25px;
            gap: 15px;
        }
        .logo-area { display: flex; align-items: center; gap: 15px; }
        .logo-area img { height: 70px; width: auto; border-radius: 10px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
        .logo-text h1 { font-size: 1.5rem; color: var(--primary); margin: 0; font-weight: 800; line-height: 1.1; }
        .logo-text span { font-size: 0.85rem; color: #64748b; display: block; margin-top: 4px; font-weight: 500; }

        nav ul { display: flex; gap: 25px; align-items: center; list-style: none; padding: 0; margin: 0; }
        nav a { color: #334155; font-weight: 600; transition: 0.3s; font-size: 0.95rem; text-decoration: none; position: relative; white-space: nowrap; }
        nav a:hover { color: var(--primary); }
