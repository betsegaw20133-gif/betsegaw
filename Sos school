        function getTimetableText(){
            const section = picker.value;
            const data = timetableData[section];
            const days = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"];
            let lines = [];
            lines.push("SOS Jimma Primary School - Timetable");
            lines.push("Section: " + section);
            lines.push("--------------------------------------");
            days.forEach(day=>{
                lines.push(day + ":");
                const subs = data[day] || [];
                for(let i=0;i<7;i++){
                    lines.push("  Period " + (i+1) + ": " + (subs[i] || "-"));
                }
                lines.push("");
            });
            return lines.join("\n");
        }

        function downloadTimetableAsText(){
