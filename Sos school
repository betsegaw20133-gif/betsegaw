        .news-card .meta { color: #64748b; font-weight: 700; font-size: 0.95rem; }
        .news-card p { margin: 0; color: #475569; }

        .faq-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        details {
            background: white; border-radius: 18px; padding: 16px 18px;
            border: 1px solid #e2e8f0; box-shadow: 0 15px 40px rgba(0,0,0,0.03);
