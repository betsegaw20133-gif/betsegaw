            reset: function() {
                alert("Game Over! Total Coins: " + this.coins);
                this.lives = 3;
                this.coins = 0;
                this.hintAvailable = 0;
                this.freezeAvailable = 0;
                this.updateUI();
                this.goHome();
            }
        };

        /* Sound toggle */
        const gymSoundToggle = document.getElementById('gymSoundToggle');
        if(gymSoundToggle){
            gymSoundToggle.addEventListener('change', (e)=>{
                gym.soundEnabled = !!e.target.checked;
                try{ gymSoundToggle.blur(); }catch(_){}
            });
        }

        /* Pause/resume button in modal should show correct icon */
        document.getElementById('gymPauseBtn')?.addEventListener('keydown', (e)=>{
            if(e.key === 'Enter') e.target.click();
        });

        /* Input listener for Enter key */
        document.getElementById('gym-answer-input')
            .addEventListener('keypress', (e) => {
                if(e.key === 'Enter') gym.checkAnswer();
            });

        /* Close modal on click outside container (nice UX) */
        document.getElementById('gym-modal').addEventListener('click', (ev)=>{
            if(ev.target && ev.target.id === 'gym-modal') closeGame();
        });

        /* Ensure game modal can be closed with Escape */
        document.addEventListener('keydown', (e)=>{
            if(e.key === 'Escape'){
                const modal = document.getElementById('gym-modal');
                if(modal && modal.style.display === 'flex') closeGame();
            }
        });

        /* Set default difficulty timers */
        gym.setDifficulty('Normal');
        gym.updateDifficultyLabel();
    </script>
</body>
</html>
