<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>SOS Jimma Primary school | ኤስኦኤስ ጅማ ትምህርት ቤት</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Outfit:wght@300;500;700;900&display=swap" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        /* =========================================
           1. PREMIUM DESIGN & DECORATION
           ========================================= */
        :root {
            --primary: #1e40af;
            --secondary: #3b82f6;
            --accent: #f59e0b;
            --success: #10b981;
            --danger: #ef4444;
            --dark: #0f172a;
            --light: #f8fafc;
            --glass: rgba(255, 255, 255, 0.95);
        }

        html { scroll-behavior: smooth; }
        body {
            font-family: 'Poppins', sans-serif;
            margin: 0; padding: 0;
            background-color: #f1f5f9;
            color: #334155;
            line-height: 1.7;
        }
        body.game-active { overflow: hidden; }

        /* Accessibility */
        .skip-link{
            position:absolute; left:-9999px; top:10px;
            background:#fff; color:var(--primary);
            padding:10px 14px; border-radius:12px;
            z-index:999999;
            font-weight:900;
            box-shadow:0 12px 30px rgba(0,0,0,0.12);
        }
        .skip-link:focus{ left:10px; }

        /* HEADER DECORATION */
        header {
            background: var(--glass);
            backdrop-filter: blur(10px);
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            position: sticky; top: 0; z-index: 1000;
            border-bottom: 3px solid var(--primary);
        }
        .header-container {
            max-width: 1300px; margin: auto;
            display: flex; justify-content: space-between; align-items: center;
            padding: 12px 25px;
            gap: 15px;
        }
        .logo-area { display: flex; align-items: center; gap: 15px; min-width: 0; }
        .logo-area img { height: 70px; width: auto; border-radius: 10px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); flex: 0 0 auto; }
        .logo-text { min-width: 0; }
        .logo-text h1 { font-size: 1.5rem; color: var(--primary); margin: 0; font-weight: 800; line-height: 1.1; }
        .logo-text span { font-size: 0.85rem; color: #64748b; display: block; margin-top: 4px; font-weight: 500; white-space: nowrap; overflow:hidden; text-overflow: ellipsis; }

        nav ul { display: flex; gap: 25px; align-items: center; list-style: none; padding: 0; margin: 0; }
        nav a { color: #334155; font-weight: 600; transition: 0.3s; font-size: 0.95rem; text-decoration: none; position: relative; white-space: nowrap; }
        nav a:hover { color: var(--primary); }

        .nav-game-link {
            background: linear-gradient(135deg, #00d2ff, #3a7bd5);
            color: white !important;
            padding: 10px 22px;
            border-radius: 50px;
            box-shadow: 0 4px 15px rgba(58, 123, 213, 0.4);
            display: flex; align-items: center; gap: 8px;
        }
        .nav-game-link:hover { transform: scale(1.05); }

        /* Mobile menu button */
        .menu-btn{
            display:none;
            background:transparent;
            border:1px solid rgba(30,64,175,0.25);
            border-radius:12px;
            padding:10px 12px;
            color:var(--primary);
            cursor:pointer;
            font-weight:900;
        }
        .mobile-nav{
            display:none;
            padding: 0 25px 14px;
        }
        .mobile-nav.open{
            display:block;
        }
        .mobile-nav a{
            display:block;
            padding: 12px 14px;
            border-radius: 14px;
            background: rgba(255,255,255,0.75);
            margin-top: 10px;
            border:1px solid rgba(30,64,175,0.12);
            font-weight:900;
            color:var(--primary);
        }

        /* HERO SECTION DECORATION */
        .hero {
            background: linear-gradient(rgba(30, 64, 175, 0.8), rgba(30, 64, 175, 0.8)), url('https://images.unsplash.com/photo-1523050854058-8df90110c9f1?auto=format&fit=crop&q=80');
            background-size: cover; background-position: center;
            color: white; text-align: center; padding: 120px 20px;
            border-bottom-left-radius: 50% 20px; border-bottom-right-radius: 50% 20px;
            position: relative;
            overflow:hidden;
        }
        .hero::after{
            content:"";
            position:absolute; inset:-60px;
            background: radial-gradient(circle at 20% 20%, rgba(245,158,11,0.25), transparent 55%),
                        radial-gradient(circle at 70% 30%, rgba(59,130,246,0.22), transparent 55%);
            pointer-events:none;
        }
        .hero h2 { font-size: 3.2rem; margin-bottom: 15px; font-weight: 800; text-shadow: 0 4px 10px rgba(0,0,0,0.3); position: relative; }
        .hero p { font-size: 1.3rem; opacity: 0.95; max-width: 800px; margin: 0 auto 18px auto; position: relative; }
        .hero-btn {
            background: white; color: var(--primary); padding: 16px 35px;
            border-radius: 50px; font-weight: 800; transition: 0.3s;
            display: inline-block; cursor: pointer; border: none; font-size: 1.1rem; margin: 10px;
            text-decoration: none; box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            position: relative;
        }
        .hero-btn:hover { transform: translateY(-5px); background: #f8fafc; }
        .hero-btn.game-btn { background: #ff0076; color: white; box-shadow: 0 10px 25px rgba(255, 0, 118, 0.3); }

        /* SECTION DECORATION */
        .section-container { max-width: 1150px; margin: 80px auto; padding: 0 25px; scroll-margin-top: 100px; }
        .section-title { text-align: center; margin-bottom: 50px; }
        .section-title h2 { color: var(--primary); font-size: 2.6rem; font-weight: 800; margin-bottom: 10px; }
        .section-title p { font-size: 1.1rem; color: #64748b; font-weight: 500; }

        /* HISTORY BOX */
        .about-box {
            background: white; padding: 50px; border-radius: 25px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.05);
            border-left: 10px solid var(--primary);
            text-align: justify;
        }

        /* GRADES GRID */
        .grades-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px; }
        .grade-card {
            background: white; border-radius: 20px; padding: 35px; text-align: center;
            transition: 0.4s; border: 1px solid #e2e8f0;
            position: relative; overflow: hidden;
        }
        .grade-card::before { content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 6px; background: var(--secondary); }
        .grade-card:hover { transform: translateY(-12px); box-shadow: 0 20px 40px rgba(0,0,0,0.1); }
        .grade-number { font-size: 2.5rem; font-weight: 900; color: var(--primary); margin-bottom: 15px; }
        .grade-links a {
            display: flex; align-items: center; justify-content: center; gap: 10px;
            margin-top: 15px; padding: 12px; border-radius: 12px; font-weight: 700; text-decoration: none; font-size: 0.9rem;
        }
        .btn-blue { background: #eff6ff; color: #1e40af; border: 1px solid rgba(30,64,175,0.08); }
        .btn-green { background: #ecfdf5; color: #059669; border: 1px solid rgba(5,150,105,0.08); }

        /* TIMETABLE DECORATION */
        .timetable-card { background: white; border-radius: 25px; padding: 40px; box-shadow: 0 15px 40px rgba(0,0,0,0.05); }
        .selection-area { margin-bottom: 30px; display: flex; flex-direction: column; align-items: center; }
        select {
            padding: 15px 25px; border-radius: 15px; border: 2px solid var(--primary);
            font-size: 1.1rem; font-weight: 600; outline: none; cursor: pointer; color: var(--primary);
            background: white; width: 100%; max-width: 400px;
        }
        .timetable-container { overflow-x: auto; margin-top: 20px; border-radius: 15px; border: 1px solid #e2e8f0; }
        table { width: 100%; border-collapse: collapse; min-width: 800px; }
        th { background: var(--primary); color: white; padding: 20px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; }
        td { padding: 18px; border: 1px solid #f1f5f9; text-align: center; font-weight: 500; }
        tr:nth-child(even) { background: #f8fafc; }
        tr:hover { background: #eff6ff; }

        /* CONTACT SECTION */
        .contact-wrapper { display: grid; grid-template-columns: 1fr 1.2fr; gap: 40px; }
        .contact-info { background: var(--primary); color: white; padding: 45px; border-radius: 25px; box-shadow: 0 10px 30px rgba(30,64,175,0.3); }
        .info-item { margin-bottom: 30px; display: flex; align-items: flex-start; gap: 20px; }
        .info-item i { font-size: 1.8rem; color: var(--accent); }
        .contact-form-box { background: white; padding: 45px; border-radius: 25px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
        input, textarea { width: 100%; padding: 18px; margin-bottom: 20px; border: 2px solid #e2e8f0; border-radius: 12px; font-size: 1rem; box-sizing: border-box; outline: none; transition: 0.3s; }
        input:focus, textarea:focus { border-color: var(--primary); }
        button[type="submit"] { background: var(--primary); color: white; border: none; padding: 18px; border-radius: 12px; cursor: pointer; font-weight: 800; font-size: 1.1rem; width: 100%; transition: 0.3s; }
        button[type="submit"]:hover { background: var(--dark); }
        .status-hint{
            font-weight:800; color:#64748b;
            display:flex; align-items:center; gap:10px;
        }
        .spinner{
            width:18px; height:18px;
            border:3px solid rgba(255,255,255,0.35);
            border-top-color:#fff;
            border-radius:50%;
            display:inline-block;
            animation: spin 0.9s linear infinite;
        }
        @keyframes spin{ to{ transform: rotate(360deg); } }

        footer { background: var(--dark); color: #94a3b8; text-align: center; padding: 80px 20px; margin-top: 100px; }

        /* =========================================
           2. NEON ARCADE BRAIN GYM
           ========================================= */
        #gym-modal {
            display: none; position: fixed; inset: 0; z-index: 9999;
            background: radial-gradient(circle at center, #1e293b, #020617);
            justify-content: center; align-items: center; font-family: 'Outfit', sans-serif;
            padding: 16px;
        }
        .gym-container {
            width: 100%; max-width: 640px; background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px); border: 2px solid rgba(255, 255, 255, 0.1);
            border-radius: 35px; padding: 35px; position: relative; color: white;
            box-shadow: 0 0 50px rgba(0,0,0,0.8);
        }
        .hud { display: flex; justify-content: space-between; margin-bottom: 18px; background: rgba(255,255,255,0.05); padding: 16px 22px; border-radius: 100px; border: 1px solid rgba(255,255,255,0.1); gap: 10px; }
        .heart-icon { color: #ff0076; filter: drop-shadow(0 0 8px #ff0076); }
        .coin-icon { color: #fbbf24; filter: drop-shadow(0 0 8px #fbbf24); }

        .hud-right{
            display:flex; align-items:center; gap:14px; flex-wrap: wrap; justify-content: flex-end;
        }

        .gym-top-controls{
            display:flex; justify-content: space-between; align-items:center; gap: 12px;
            margin-bottom: 18px;
        }
        .gym-pill{
            background: rgba(255,255,255,0.06);
            border:1px solid rgba(255,255,255,0.12);
            border-radius: 999px;
            padding: 10px 14px;
            font-weight: 900;
            color: rgba(255,255,255,0.92);
            display:inline-flex; align-items:center; gap:10px;
            user-select:none;
        }
        .gym-switch{
            display:flex; align-items:center; gap:12px;
            background: rgba(255,255,255,0.06);
            border:1px solid rgba(255,255,255,0.12);
            padding:10px 14px;
            border-radius: 999px;
        }
        .gym-switch label{
            font-weight: 900; color: rgba(255,255,255,0.9);
            font-size: 0.95rem;
        }
        .gym-switch input{
            width: 44px; height: 24px;
            appearance:none;
            background: rgba(255,255,255,0.15);
            border: 1px solid rgba(255,255,255,0.18);
            border-radius: 999px;
            position: relative;
            cursor:pointer;
            outline:none;
        }
        .gym-switch input::after{
            content:"";
            position:absolute; top:2px; left:2px;
            width: 18px; height: 18px; border-radius: 50%;
            background: rgba(255,255,255,0.9);
            transition: transform 0.2s ease, background 0.2s ease;
        }
        .gym-switch input:checked{
            background: rgba(16,185,129,0.25);
            border-color: rgba(16,185,129,0.5);
        }
        .gym-switch input:checked::after{
            transform: translateX(20px);
            background: #34d399;
        }

        .gym-screen { display: none; flex-direction: column; animation: slideUp 0.4s ease; }
        .gym-screen.active { display: flex; }
        @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }

        .gym-grid-menu { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .gym-card-btn {
            background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
            padding: 26px; border-radius: 25px; cursor: pointer; color: white; transition: 0.3s;
            display: flex; flex-direction: column; align-items: center; gap: 12px; font-weight: 800;
            text-align:center;
            user-select:none;
        }
        .gym-card-btn:hover { background: rgba(255,255,255,0.1); transform: scale(1.03); border-color: rgba(59,130,246,0.7); }
        .gym-card-btn i { font-size: 3rem; }

        .timer-track { width: 100%; height: 10px; background: rgba(255,255,255,0.1); border-radius: 20px; margin-bottom: 18px; overflow: hidden; }
        .timer-fill { height: 100%; width: 100%; background: linear-gradient(90deg, #00d2ff, #3a7bd5); transition: width 0.1s linear; }

        .question-display { background: rgba(0,0,0,0.4); padding: 44px; border-radius: 25px; text-align: center; margin-bottom: 18px; border: 1px solid rgba(255,255,255,0.1); }
        .big-text { font-size: 3.5rem; font-weight: 900; margin: 0; letter-spacing: 2px; }

        .gym-input-field { width: 100%; padding: 22px; border-radius: 18px; border: 2px solid rgba(255,255,255,0.2); background: rgba(255,255,255,0.1); color: white; font-size: 1.7rem; text-align: center; margin-bottom: 14px; outline: none; }
        .gym-input-field::placeholder{ color: rgba(255,255,255,0.55); }
        .submit-btn { background: linear-gradient(45deg, #00d2ff, #3a7bd5); color: white; border: none; padding: 18px; border-radius: 18px; font-weight: 900; cursor: pointer; font-size: 1.2rem; text-transform: uppercase; }
        .submit-btn.secondary { background: rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.18); text-transform:none; font-size:1rem; }
        .submit-btn:disabled{ opacity:0.6; cursor:not-allowed; }

        /* =========================================
           3. NEW SECTIONS (LOCATION, GALLERY, FAQ, NEWS)
           ========================================= */
        .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 25px; }
        .feature-card {
            background: white; border-radius: 22px; padding: 25px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.05); border: 1px solid #e2e8f0;
        }
        .feature-card i { color: var(--secondary); font-size: 1.8rem; }
        .feature-card h3 { margin: 12px 0 8px; color: var(--primary); font-size: 1.2rem; }
        .feature-card p { margin: 0; color: #475569; }

        .map-wrap {
            display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 30px; align-items: start;
        }
        .map-card {
            background: white; border-radius: 25px; padding: 25px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.05); border: 1px solid #e2e8f0;
        }
        .map-iframe {
            width: 100%; height: 420px; border: 0; border-radius: 18px;
        }
        .badge-row { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 14px; }
        .pill {
            background: #eff6ff; color: #1e40af; padding: 8px 12px;
            border-radius: 999px; font-weight: 900; font-size: 0.9rem; display:inline-flex; align-items:center; gap:8px;
        }
        .btn-secondary {
            display: inline-flex; align-items: center; gap: 10px;
            background: #eff6ff; color: #1e40af; padding: 12px 18px;
            border-radius: 14px; text-decoration: none; font-weight: 900;
            border: 1px solid rgba(30,64,175,0.2);
        }
        .btn-secondary:hover { background: #e0f2fe; }
        .gallery-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
        .gallery-item { border-radius: 20px; overflow: hidden; border: 1px solid #e2e8f0; background: white; cursor:pointer; }
        .gallery-item img { width: 100%; height: 220px; object-fit: cover; display: block; }
        .gallery-item .cap { padding: 12px 14px; color: #475569; font-weight: 900; }
        .gallery-item:hover{ transform: translateY(-6px); transition:0.25s; }
        .lightbox{
            display:none;
            position:fixed; inset:0; z-index:999999;
            background: rgba(0,0,0,0.72);
            align-items:center; justify-content:center;
            padding: 18px;
        }
        .lightbox.open{ display:flex; }
        .lightbox .box{
            width:100%; max-width: 880px;
            background: rgba(255,255,255,0.95);
            border-radius: 24px;
            overflow:hidden;
            box-shadow: 0 30px 80px rgba(0,0,0,0.35);
        }
        .lightbox .topbar{
            display:flex; justify-content:space-between; align-items:center;
            padding: 14px 16px; gap: 12px;
            border-bottom: 1px solid rgba(0,0,0,0.06);
            background: #ffffff;
        }
        .lightbox .topbar b{ color: var(--primary); font-weight: 1000; }
        .lightbox .topbar button{
            background: #111827; color:#fff;
            border:none; border-radius: 14px;
            padding: 10px 14px; cursor:pointer; font-weight: 1000;
        }
        .lightbox img{
            width:100%; height: 540px; object-fit: cover; display:block;
        }
        .lightbox .caption{
            padding: 14px 16px;
            color:#334155; font-weight: 900;
        }

        .news-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
        .news-card { background: white; border-radius: 22px; padding: 20px; border: 1px solid #e2e8f0; box-shadow: 0 15px 40px rgba(0,0,0,0.05); }
        .news-card h3 { margin: 12px 0 10px; color: var(--primary); font-size: 1.15rem; }
        .news-card .meta { color: #64748b; font-weight: 900; font-size: 0.95rem; display:flex; align-items:center; gap:10px; }
        .news-card p { margin: 0; color: #475569; }
        .news-card .actions{
            margin-top: 14px;
            display:flex; gap: 10px; flex-wrap: wrap;
        }
        .btn-small{
            border-radius: 14px; border:1px solid rgba(30,64,175,0.18);
            padding: 10px 14px; font-weight: 1000;
            background:#eff6ff; color: #1e40af;
            text-decoration:none; cursor:pointer;
        }
        .btn-small:hover{ background:#e0f2fe; }

        .faq-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        details {
            background: white; border-radius: 18px; padding: 16px 18px;
            border: 1px solid #e2e8f0; box-shadow: 0 15px 40px rgba(0,0,0,0.03);
        }
        summary { cursor: pointer; font-weight: 1000; color: var(--primary); font-size: 1.05rem; }
        details p { margin: 10px 0 0; color: #475569; }

        /* Additional upgraded sections */
        .hero-strip{
            max-width: 1150px; margin: -55px auto 0;
            padding: 0 25px;
            position: relative; z-index: 2;
        }
        .hero-strip .strip-grid{
            display:grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 14px;
        }
        .mini-stat{
            background: rgba(255,255,255,0.92);
            border: 1px solid rgba(30,64,175,0.12);
            border-radius: 18px;
            padding: 16px 14px;
            box-shadow: 0 18px 45px rgba(0,0,0,0.08);
            display:flex; flex-direction:column; gap: 6px;
        }
        .mini-stat i{ color: var(--secondary); font-size: 1.4rem; }
        .mini-stat b{ color: var(--primary); font-weight: 1000; font-size: 1.05rem; }
        .mini-stat span{ color:#475569; font-weight: 800; font-size: 0.95rem; }

        .cta-row{
            display:flex; gap: 12px; justify-content:center; flex-wrap: wrap;
        }

        .events-grid{
            display:grid; grid-template-columns: 1fr 1fr;
            gap: 20px;
            align-items:start;
        }
        .event-card{
            background:white; border:1px solid #e2e8f0;
            border-radius: 22px; padding: 20px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.05);
        }
        .event-card h3{ margin: 0 0 8px; color: var(--primary); font-size: 1.15rem; }
        .event-meta{
            display:flex; gap:10px; flex-wrap:wrap; margin-bottom: 10px;
            color:#64748b; font-weight: 900;
        }
        .chip{
            background:#eff6ff; color:#1e40af;
            border:1px solid rgba(30,64,175,0.18);
            padding: 8px 10px; border-radius:999px;
            font-weight: 1000; font-size: 0.9rem;
        }
        .event-desc{ color:#475569; margin:0 0 14px; font-weight: 800; }
        .rsvp-form{
            display:grid; gap: 12px;
        }
        .rsvp-form input{
            margin:0;
            border-radius: 14px;
        }
        .rsvp-form button{
            padding: 14px 16px;
            border-radius: 14px;
            font-weight: 1000;
        }

        /* Floating WhatsApp */
        .fab{
            position: fixed;
            right: 16px; bottom: 16px;
            z-index: 10000;
            display:flex; flex-direction:column; gap: 10px;
        }
        .fab a{
            text-decoration:none;
            width: 54px; height: 54px;
            border-radius: 18px;
            display:flex; align-items:center; justify-content:center;
            box-shadow: 0 18px 45px rgba(0,0,0,0.25);
            border:1px solid rgba(255,255,255,0.2);
        }
        .fab a.wa{ background:#22c55e; color:#fff; }
        .fab a.tg{ background:#3b82f6; color:#fff; }

        /* Responsive */
        @media (max-width: 1100px) {
            .map-wrap { grid-template-columns: 1fr; }
            .grid-3 { grid-template-columns: 1fr; }
            .news-grid { grid-template-columns: 1fr; }
            .gallery-grid { grid-template-columns: 1fr; }
            .faq-grid { grid-template-columns: 1fr; }
