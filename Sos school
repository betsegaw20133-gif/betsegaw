                        {q:"Antonym of GROW (verb)", a:"SHRINK/REDUCE"},
                        {q:"Opposite of BRIGHT", a:"DULL/DIM"},
                        {q:"Plural of CITY", a:"CITIES"},
                        {q:"Capital of KENYA", a:"NAIROBI"},
                        {q:"Synonym of START", a:"BEGIN"}
                    ];
                    const engNormal = [
                        {q:"Antonym of HARD", a:"SOFT"},
                        {q:"Plural of CHILD", a:"CHILDREN"},
                        {q:"Capital of ETHIOPIA", a:"ADDIS ABABA"},
                        {q:"Opposite of FAST", a:"SLOW"},
                        {q:"Plural of BOOK", a:"BOOKS"}
                    ];

                    let bank = engNormal;
                    if(this.difficulty === 'Easy') bank = engEasy;
                    if(this.difficulty === 'Hard') bank = engHard;

                    let p = bank[Math.floor(Math.random()*bank.length)];
