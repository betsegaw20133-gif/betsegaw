    /***********************
     * Daily Mission Logic
     ***********************/
    function ensureDailyMissionsSetup(){
      const tKey = todayKey();
      if(state.daily.date !== tKey){
        state.daily = { date: tKey, items: {} };
        // Initialize counters with 0; keep structure sparse
        dailyTemplate().forEach(m=>{
          state.daily.items[m.type] = state.daily.items[m.type] || { count:0, completed:false, claimed:false, goal: m.goal, reward:m.reward };
        });
        saveState();
      }
    }

    function addDailyProgress(type, inc=1){
      ensureDailyMissionsSetup();
      if(!state.daily.items[type]) return;

      state.daily.items[type].count += inc;

      const mission = state.daily.items[type];
      // mark completed per type when meets goal
      if(mission.count >= mission.goal){
        mission.completed = true;
      }
      saveState();
      refreshDailyUI(true);
      // Achievements might also be updated
      maybeRefreshAchievementsUI();
    }

