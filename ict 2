    /***********************
     * Word Search (Upgraded with Timer + Hint + Shuffle + Progress)
     ***********************/
    let wsGrid = [];
    let wsWords = [];
    const wsSize = 10;

    function rerollWordSearch(){
      initAudio();
      playSound('click');
      initWordSearch(true);
    }

    function initWordSearch(withShuffle=false){
      // If withShuffle: require item if available
      if(withShuffle && state.inventory.shuffles > 0){
        state.inventory.shuffles--;
        saveState();
        updateHUD();
      } else if(withShuffle && state.inventory.shuffles <= 0){
        // allow reroll anyway but consume coins instead (nice)
        if(state.coins >= 12){
          state.coins -= 12;
          saveState();
          updateHUD();
          playSound('buy');
        }else{
          alert("Not enough Coins for shuffle. Buy Shuffle in Market.");
          return;
        }
      }

      // Generate word list
      const pool = [...ictData].map(i => i.t.toUpperCase().replace(/[^A-Z]/g,'')).filter(w=>w.length>=3 && w.length<=10);
      // Choose 6 unique words
      wsWords = [];
      while(wsWords.length < 6 && pool.length){
        const w = pool[Math.floor(Math.random()*pool.length)];
        if(!wsWords.includes(w)) wsWords.push(w);
      }
      wsWords = wsWords.slice(0,6);

      wsGrid = Array(wsSize).fill(null).map(()=>Array(wsSize).fill(''));
      state.wsSelection = [];

      // Place words (allow horizontal/vertical)
      wsWords.forEach(word=>{
        let placed=false;
        let attempts=0;
        while(!placed && attempts<200){
          const dir = Math.random() > 0.5 ? 1 : 0; // 1=H,0=V
          const row = Math.floor(Math.random()*wsSize);
          const col = Math.floor(Math.random()*wsSize);

          if(dir===1){
            if(col + word.length <= wsSize){
              let ok=true;
              for(let i=0;i<word.length;i++){
                const existing = wsGrid[row][col+i];
                if(existing !== '' && existing !== word[i]){ ok=false; break; }
              }
              if(ok){
                for(let i=0;i<word.length;i++) wsGrid[row][col+i]=word[i];
                placed=true;
              }
            }
          } else {
            if(row + word.length <= wsSize){
              let ok=true;
              for(let i=0;i<word.length;i++){
                const existing = wsGrid[row+i][col];
                if(existing !== '' && existing !== word[i]){ ok=false; break; }
              }
              if(ok){
                for(let i=0;i<word.length;i++) wsGrid[row+i][col]=word[i];
                placed=true;
              }
            }
          }
          attempts++;
        }
      });

      // Fill empty with random letters
      const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
      for(let r=0;r<wsSize;r++){
        for(let c=0;c<wsSize;c++){
          if(wsGrid[r][c] === ''){
            wsGrid[r][c] = letters.charAt(Math.floor(Math.random()*letters.length));
          }
        }
      }

      drawWordSearch();

      // Update progress bar
      refreshWSProgress();
    }

    function refreshWSProgress(){
      const wsProg = document.getElementById('ws-progress');
      const total = 6;
      const remaining = wsWords.length;
      const done = total - remaining;
      const pct = (done/total)*100;
      wsProg.style.width = Math.min(100, pct) + "%";
    }

    function drawWordSearch(){
      const gridEl = document.getElementById('ws-grid');
      gridEl.style.gridTemplateColumns = `repeat(${wsSize}, 1fr)`;
      gridEl.innerHTML = "";

      for(let r=0;r<wsSize;r++){
        for(let c=0;c<wsSize;c++){
          gridEl.innerHTML += `<div class="ws-cell" id="ws-${r}-${c}" onclick="selectWSCell(${r}, ${c})">${wsGrid[r][c]}</div>`;
        }
      }

      const bank = document.getElementById('ws-bank');
      bank.innerHTML = wsWords.map(w=>{
        return `<span class="bank-chip" id="ws-word-${w}">${w}</span>`;
      }).join('');
    }

    function selectWSCell(r,c){
      initAudio();
      playSound('type');

      const el = document.getElementById(`ws-${r}-${c}`);

      // Toggle selection
      const idx = state.wsSelection.findIndex(s=>s.r===r && s.c===c);
      if(idx > -1){
        state.wsSelection.splice(idx,1);
        el.classList.remove('highlighted');
      } else {
        state.wsSelection.push({r,c,char: wsGrid[r][c]});
        el.classList.add('highlighted');
      }

      // Check selection forms a word (forward/back)
      const selectedForward = state.wsSelection.map(s=>s.char).join('');
      const selectedReverse = state.wsSelection.map(s=>s.char).reverse().join('');

      const foundWord = wsWords.find(w=>w === selectedForward || w === selectedReverse);
      if(foundWord){
        playSound('win');

        // Score
        const xpGain = 30 * state.combo;
        state.xp += xpGain;
        state.coins += 10;

        state.stats.wordFinds = (state.stats.wordFinds || 0) + 1;
        addDailyProgress("wordFound", 1);

        updateHUD();

        // Mark cells found
        state.wsSelection.forEach(s=>{
          const cell = document.getElementById(`ws-${s.r}-${s.c}`);
          if(cell){
            cell.classList.remove('highlighted');
            cell.classList.add('found');
          }
        });

        // Cross out in bank
        const bankEl = document.getElementById(`ws-word-${foundWord}`);
        if(bankEl){
          bankEl.style.background = "var(--eth-green)";
          bankEl.style.textDecoration = "line-through";
          bankEl.style.opacity = ".65";
        }

        // Remove word and reset selection
        wsWords = wsWords.filter(w=>w !== foundWord);
        state.wsSelection = [];

        refreshWSProgress();
        state.combo++;

        // If finished
        if(wsWords.length === 0){
          setTimeout(()=>{
            playSound('win');
            alert("🎉 Great job! You found all hidden tech terms!");
            showScreen('scr-dash');
            saveState();
            maybeRefreshAchievementsUI();
          }, 500);
        }
      }
    }

