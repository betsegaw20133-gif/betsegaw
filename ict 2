    function quickPracticeFromLesson(lessonTitle){
      // give a small bonus + open Choosing quiz starting at random index (shorter experience)
      initAudio();
      playSound('win');
      // Bonus: coins and XP
      state.coins += 8;
      state.xp += 15;
      updateHUD();

      // Start a short mini-quiz (use choosing mode but only 7 questions)
      // We'll temporarily reduce quiz length by choosing subset indices.
      const savedMode = state.mode;
      const mode = 'choosing';
      state.mode = mode;
      state.idx = 0;

      // We will store subset length by using a “virtual list”
      // Simple approach: run 7 questions by jumping idx and then exit.
      showScreen('scr-quiz');

      const subset = [];
      while(subset.length < 7){
        const r = ictData[Math.floor(Math.random()*ictData.length)];
        if(!subset.includes(r)) subset.push(r);
      }
      // Replace ictData reference used by quiz? We'll implement using state.quizPool.
      state.quizPool = subset;
