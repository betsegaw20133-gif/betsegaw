    function applyBossDamage(amount){
      boss.hp -= amount;
      if(boss.hp < 0) boss.hp = 0;
      playSound('boss');
      document.getElementById('boss-hp').innerText = boss.hp;
      document.getElementById('boss-hp-bar').style.width = (boss.hp/boss.maxHp*100) + "%";
    }

    function bossAnswer(chosen, correct){
      if(!boss || boss.lock) return;
      boss.lock = true;

      const isCorrect = String(chosen).toLowerCase().trim() === String(correct).toLowerCase().trim();
      if(isCorrect){
        playSound('win');
        const dmg = 18 + Math.floor(6 * boss.streak);
        applyBossDamage(dmg);
        boss.streak++;

        // advance phase thresholds
        if(boss.hp <= 60) boss.phase = 2;
        if(boss.hp <= 25) boss.phase = 3;

        boss.lock = false;
        setTimeout(()=>{
          if(boss.hp <= 0){
            bossDefeated();
          }else{
            renderBossPhase();
          }
        }, 350);

      } else {
        playSound('lose');
        triggerShake();
        safeLoseLife();
        boss.streak = 1;
        updateHUD();
        boss.lock = false;
        setTimeout(()=>{
          if(boss.hp <= 0) bossDefeated();
          else renderBossPhase();
        }, 450);
      }
    }

    function bossPickDef(chosenDef, correctDef){
      if(!boss || boss.lock) return;
      boss.lock = true;

      const isCorrect = String(chosenDef).toLowerCase().trim() === String(correctDef).toLowerCase().trim();
      if(isCorrect){
        playSound('win');
        const dmg = 22 + Math.floor(5 * boss.streak);
        applyBossDamage(dmg);
        boss.streak++;
      }else{
        playSound('lose');
        safeLoseLife();
        boss.streak = 1;
        updateHUD();
      }
      boss.lock = false;

      if(boss.hp <= 0) bossDefeated();
      else{
        if(boss.hp <= 25) boss.phase = 3;
        renderBossPhase();
      }
    }

    function bossType(){
      if(!boss || boss.lock) return;
      boss.lock = true;

      const inp = document.getElementById('boss-input');
      const val = (inp?.value || "").trim();
      const promptTerm = null;

      // Find correct term for displayed definition:
      // We used q from renderBossPhase; but we didn't store it globally.
      // So we infer: match the definition in the ictData by exact match on d.
      const defText = document.querySelector('#boss-prompt').innerText;
      // More robust: store lastBossQ when rendering
      // We'll do that:
      if(!boss.lastQ){
        boss.lastQ = ictData[Math.floor(Math.random()*ictData.length)];
      }

      // Instead, set boss.lastQ in renderBossPhase. We'll do it now:
      // (If missing, just compare against any q.d that matches the prompt line.)
      let correctTerm = null;
      // try by definition substring:
      const qFromPool = ictData.find(x => x.d === boss.lastQ.d);
      if(qFromPool) correctTerm = qFromPool.t;
      else correctTerm = boss.lastQ.t;

      const isCorrect = String(val).toLowerCase().trim() === String(correctTerm).toLowerCase().trim();

      if(isCorrect){
        playSound('win');
        const dmg = 28 + Math.floor(7 * boss.streak);
        applyBossDamage(dmg);
        boss.streak++;
      }else{
        playSound('lose');
        triggerShake();
        safeLoseLife();
        boss.streak = 1;
        updateHUD();
      }

      boss.lock = false;

      if(boss.hp <= 0) bossDefeated();
      else{
        if(boss.hp <= 0) bossDefeated();
        else renderBossPhase();
      }
    }

    // Ensure we store lastQ
    const _origRenderBossPhase = renderBossPhase;
    renderBossPhase = function(){
      const q = ictData[Math.floor(Math.random()*ictData.length)];
      // We'll call original by temporarily injecting q usage.
      // But since the original function already re-selects, easiest: implement a safe wrapper.
      // Instead, modify by setting boss.lastQ to whatever q renderBossPhase used:
      // We'll replicate quickly by selecting again and then invoking logic.
      boss.lastQ = q;
      // Now we run a custom render by temporarily monkeypatching ictData selection.
      // Simpler: re-run original but after it sets the q inside it would differ.
      // To fix properly, we re-implement a clean render below.

      const prompt = document.getElementById('boss-prompt');
      const actions = document.getElementById('boss-actions');

      actions.innerHTML = "";

      document.getElementById('boss-phase').innerText = `Phase ${boss.phase}`;
      document.getElementById('boss-streak').innerText = String(boss.streak);
      document.getElementById('boss-hp').innerText = boss.hp;
      document.getElementById('boss-hp-bar').style.width = (boss.hp/boss.maxHp*100) + "%";

      const qq = boss.lastQ;

      if(boss.phase === 1){
        prompt.innerText = `Omega Core Phase 1: Defeat with Fast Choices!\nQuestion: ${qq.d}`;
        let correct = qq.t;
        let opts = [correct];
        while(opts.length < 4){
          const rand = ictData[Math.floor(Math.random()*ictData.length)].t;
          if(!opts.includes(rand)) opts.push(rand);
        }
        opts.sort(()=>Math.random()-0.5);

        opts.forEach(o=>{
          actions.innerHTML += `<button class="btn" style="padding:10px 16px; margin-top:10px; width:100%; max-width:380px;"
            onclick="bossAnswer('${escapeHtmlAttr(o)}', '${escapeHtmlAttr(correct)}'); playSound('click');">${escapeHtml(o)}</button>`;
        });

      } else if(boss.phase === 2){
        prompt.innerText = `Omega Core Phase 2: Match Under Pressure!`;

        const term = qq.t;
        const def = qq.d;
        const wrong = ictData[Math.floor(Math.random()*ictData.length)];
        const wrongDef = wrong.d;

        actions.innerHTML = `
          <div class="tutorial-item" style="text-align:center;">
            <div style="font-family:'Space Grotesk'; font-weight:900; color:var(--primary);">TERM: ${escapeHtml(term)}</div>
            <div class="row" style="margin-top:12px; gap:10px;">
              <button class="btn" style="padding:10px 16px; width:100%; max-width:360px;" onclick="bossPickDef('${escapeHtmlAttr(def)}', '${escapeHtmlAttr(def)}');">✅ ${escapeHtml(def).substring(0,58)}...</button>
              <button class="btn btn-danger" style="padding:10px 16px; width:100%; max-width:360px;" onclick="bossPickDef('${escapeHtmlAttr(wrongDef)}', '${escapeHtmlAttr(def)}');">❌ ${escapeHtml(wrongDef).substring(0,58)}...</button>
            </div>
          </div>
        `;

      } else {
        boss.phase = 3;
        prompt.innerText = `Omega Core Phase 3: Type the Correct Term!`;
        actions.innerHTML = `
          <div class="tutorial-item" style="text-align:center;">
            <div style="opacity:.9; font-weight:900; margin-bottom:10px;">Definition: <span style="color:var(--warning)">${escapeHtml(qq.d)}</span></div>
            <input id="boss-input" class="input-box" style="max-width:420px; margin-bottom:10px;" placeholder="Type term..." autocomplete="off"/>
            <button class="btn" style="width:100%; max-width:420px;" onclick="bossType()">Submit</button>
          </div>
        `;
        setTimeout(()=>{
          const inp = document.getElementById('boss-input');
          if(inp) inp.focus();
        }, 50);
      }
    };

    function bossDefeated(){
      playSound('win');
      boss = null;

      // Reward
      const coinsGain = 150;
      const xpGain = 350;

      state.coins += coinsGain;
      state.xp += xpGain;

      state.flags.bossDefeated = true;
      state.stats.skillWins = (state.stats.skillWins || 0) + 1;

      state.combo = 1;
      state.lives = Math.min(10, state.lives + 1);

      addDailyProgress("skillWin", 1);

      levelUpCheck();
      updateHUD();
      saveState();

      alert(`👑 Omega Core Defeated!\n+${coinsGain} Coins • +${xpGain} XP`);
      maybeRefreshAchievementsUI();
      showScreen('scr-dash');
    }

    /***********************
     * Certification + Market
     ***********************/
    function checkCert(){
      initAudio();
      playSound('click');
      if(state.lvl >= 5){
        if(state.flags.certClaimed){
          openModal('modal-cert');
          return;
        }
        document.getElementById('cert-name').innerText = state.name || "Student";
        state.flags.certClaimed = true;
        playSound('win');
        openModal('modal-cert');
        saveState();
      }else{
        triggerShake();
        alert(`ACCESS DENIED: You are Level ${state.lvl}. You must reach Level 5 to unlock the Certification.`);
      }
    }

    function buyItem(type){
      initAudio();
      playSound('click');

      if(type === 'life'){
        if(state.coins >= 25){
          state.coins -= 25;
          state.lives += 1;
          playSound('buy');
          updateHUD();
        }else{
          playSound('lose');
          triggerShake();
          alert("Insufficient Coins!");
        }
      } else if(type === 'xp'){
        if(state.coins >= 40){
          state.coins -= 40;
          state.xp += 50;
          playSound('buy');
          levelUpCheck();
          updateHUD();
        }else{
          playSound('lose');
          triggerShake();
          alert("Insufficient Coins!");
        }
      } else if(type === 'hint'){
        if(state.coins >= 35){
          state.coins -= 35;
          state.inventory.hintTokens += 1;
          playSound('buy');
          updateHUD();
        }else{
          playSound('lose');
          triggerShake();
          alert("Insufficient Coins for Hint Token!");
        }
      } else if(type === 'shield'){
        if(state.coins >= 60){
          state.coins -= 60;
          state.inventory.shields += 1;
          playSound('buy');
          updateHUD();
        }else{
          playSound('lose');
          triggerShake();
          alert("Insufficient Coins for Shield!");
        }
      } else if(type === 'shuffle'){
        if(state.coins >= 25){
          state.coins -= 25;
          state.inventory.shuffles += 1;
          playSound('buy');
          updateHUD();
        }else{
          playSound('lose');
          triggerShake();
          alert("Insufficient Coins for Shuffle!");
        }
      }

      saveState();
    }

    function finishSession(){
      playSound('win');
      closeModal('modal-cert');
      alert("Session completed. Omega Approved! ✅");
      showScreen('scr-welcome');
    }

    /***********************
     * Compatibility: previous function references
     ***********************/
    // Your original code used startSpecial('wordsearch') which now routes properly.
    // We'll provide startSpecial('wordsearch') already above.

    // Ensure daily missions date and achievements UI refresh on load
    function initialSetup(){
      ensureDailyMissionsSetup();
      updateHUD();

      // Render daily UI only if the screen is open (optional)
      refreshDailyUI(false);
    }

    initialSetup();
    // Modal close on overlay click (optional)
    document.getElementById('modal-feedback').addEventListener('click', (e)=>{
      if(e.target.id === 'modal-feedback'){
        // Keep controlled by Continue.
      }
    });

  </script>
