    /***********************
     * Quiz Engine (Upgraded & Bug-fixed)
     ***********************/
    let stateLock = false;

    function startQuiz(mode){
      initAudio();
      playSound('click');

      state.mode = mode;
      state.idx = 0;
      state.currentAnswer = "";
      state.combo = Math.max(1, state.combo || 1);

      // close any quiz timer displays
      document.getElementById('quiz-timer-pill').style.display = 'none';

      // reset matching selection
      selA = null; selB = null;

      showScreen('scr-quiz');
      stateLock = false;
      loadQuizQuestion();
    }

    function getQuizTimerForMode(mode){
      if(mode === 'timedChoose') return 10;
      return null;
    }

    let quizTimerInterval = null;
    let quizTimerRemaining = 0;

    function stopQuizTimer(){
      if(quizTimerInterval){
        clearInterval(quizTimerInterval);
        quizTimerInterval = null;
      }
      quizTimerRemaining = 0;
      document.getElementById('quiz-timer-pill').style.display = 'none';
    }

    function startQuizTimer(sec){
      stopQuizTimer();
      quizTimerRemaining = sec;
      const pill = document.getElementById('quiz-timer-pill');
      const timerEl = document.getElementById('quiz-timer');
      pill.style.display = 'inline-flex';

      timerEl.innerText = String(quizTimerRemaining);

      quizTimerInterval = setInterval(()=>{
        quizTimerRemaining--;
        if(quizTimerRemaining < 0) quizTimerRemaining = 0;
        timerEl.innerText = String(quizTimerRemaining);

        if(quizTimerRemaining === 0){
          // time out counts as wrong
          stopQuizTimer();
          if(stateLock) return;
          stateLock = true;
          handleQuizResult(false, true);
        }
      }, 1000);
    }

    function loadQuizQuestion(){
      const q = ictData[state.idx];
      if(!q){
        // finished
        showScreen('scr-dash');
        return;
      }

      // Progress bar based on quiz length
      const total = ictData.length;
      document.getElementById('quiz-lvl-tag').innerText = `Challenge ${state.idx + 1}/${total}`;
      document.getElementById('quiz-progress').style.width = (state.idx / total * 100) + "%";

      stopQuizTimer();

      const area = document.getElementById('q-options');
      area.innerHTML = "";

      const subtitle = document.getElementById('q-subtitle');
      subtitle.innerText = "";

      // Modes
      if(state.mode === 'choosing'){
        document.getElementById('q-text').innerText = q.d;
        subtitle.innerText = "Pick the correct term.";

        // 4 options, random unique terms
        let opts = [q.t];
        while(opts.length < 4){
          const rand = ictData[Math.floor(Math.random()*ictData.length)].t;
          if(!opts.includes(rand)) opts.push(rand);
        }
        opts.sort(()=>Math.random()-0.5);

        opts.forEach(o=>{
          area.innerHTML += `<button class="btn" style="width:100%; max-width:420px;" onclick="checkQuizAns('${escapeHtmlAttr(o)}')">${escapeHtml(o)}</button>`;
        });

      } else if(state.mode === 'timedChoose'){
        const timer = getQuizTimerForMode('timedChoose') || 10;
        startQuizTimer(timer);

        document.getElementById('q-text').innerText = q.d;
        subtitle.innerText = `Timed! Answer within ${timer}s.`;

        let opts = [q.t];
        while(opts.length < 4){
          const rand = ictData[Math.floor(Math.random()*ictData.length)].t;
          if(!opts.includes(rand)) opts.push(rand);
        }
        opts.sort(()=>Math.random()-0.5);

        area.innerHTML = "";
        opts.forEach(o=>{
          area.innerHTML += `<button class="btn" style="width:100%; max-width:420px;" onclick="checkQuizAns('${escapeHtmlAttr(o)}')">${escapeHtml(o)}</button>`;
        });

      } else if(state.mode === 'writing' || state.mode === 'fillblank'){
        document.getElementById('q-text').innerText = (state.mode === 'writing') ? q.d : q.b;
        subtitle.innerText = "Type the correct core term (then press Enter).";

        area.innerHTML =
          `<input type="text" id="quiz-input" class="input-box" style="max-width:420px; margin-bottom:10px;" placeholder="Type answer here..." autocomplete="off"/>
           <button class="btn" style="width:100%; max-width:420px;" onclick="checkQuizAns(document.getElementById('quiz-input').value)">Submit Analysis</button>`;

        const input = document.getElementById('quiz-input');
        input.focus();
        input.addEventListener('keydown', (e)=>{
          if(e.key === 'Enter'){
            checkQuizAns(input.value);
          }
        }, { once:false });

      } else if(state.mode === 'matching'){
        document.getElementById('q-text').innerText = "Match the Term to its Definition";
        subtitle.innerText = "Select from A then B. Correct pairs lock in.";

        renderMatching();
      } else if(state.mode === 'flashcards'){
        // Flashcards: show term first or definition first (random each question)
        const flip = Math.random() > 0.5;
        if(flip){
          document.getElementById('q-text').innerText = `TERM: ${q.t}`;
          subtitle.innerText = "Type the matching definition keyword (answer = term).";
          area.innerHTML =
            `<input type="text" id="quiz-input" class="input-box" style="max-width:420px; margin-bottom:10px;" placeholder="Type the definition's term..." autocomplete="off"/>
             <button class="btn" style="width:100%; max-width:420px;" onclick="checkQuizAns(document.getElementById('quiz-input').value)">Reveal</button>`;
          const input = document.getElementById('quiz-input');
          input.focus();
          input.addEventListener('keydown', (e)=>{ if(e.key==='Enter') checkQuizAns(input.value); }, { once:false });
        }else{
          document.getElementById('q-text').innerText = q.d;
          subtitle.innerText = "Type the correct term for this definition.";
          area.innerHTML =
            `<input type="text" id="quiz-input" class="input-box" style="max-width:420px; margin-bottom:10px;" placeholder="Type the correct term..." autocomplete="off"/>
             <button class="btn" style="width:100%; max-width:420px;" onclick="checkQuizAns(document.getElementById('quiz-input').value)">Submit</button>`;
          const input = document.getElementById('quiz-input');
          input.focus();
          input.addEventListener('keydown', (e)=>{ if(e.key==='Enter') checkQuizAns(input.value); }, { once:false });
        }
      }
    }

    // Matching selections (bug-fixed completion condition)
    let selA = null, selB = null;
    function renderMatching(){
      const area = document.getElementById('q-options');
      let html = `<div class="match-area"><div class="match-box">`;

      // choose 3 terms deterministically around current q (increase variety)
      const pool = [ictData[state.idx]];
      while(pool.length < 3){
        const rand = ictData[Math.floor(Math.random()*ictData.length)];
        if(!pool.includes(rand)) pool.push(rand);
      }
      pool.sort(()=>Math.random()-0.5);

      pool.forEach(item=>{
        html += `<div class="match-item" data-val="${escapeHtmlAttr(item.t)}" onclick="matchSelect('A', '${escapeHtmlAttr(item.t)}', this); playSound('click');">${escapeHtml(item.t)}</div>`;
      });

      html += `</div><div class="match-box">`;

      // B list are the definitions (but store the same item.t as match key)
      const poolB = [...pool].sort(()=>Math.random()-0.5);
      poolB.forEach(item=>{
        const short = item.d.length>52 ? item.d.substring(0,52)+'...' : item.d;
        html += `<div class="match-item" data-val="${escapeHtmlAttr(item.t)}" onclick="matchSelect('B', '${escapeHtmlAttr(item.t)}', this); playSound('click');">${escapeHtml(short)}</div>`;
      });

      html += `</div></div>`;
      area.innerHTML = html;
      selA = null; selB = null;
      stateLock = false;
    }

    function matchSelect(side, keyVal, el){
      if(stateLock) return;

      if(side === 'A'){
        if(selA && selA.el) selA.el.classList.remove('selected');
        selA = { val:keyVal, el };
      }else{
        if(selB && selB.el) selB.el.classList.remove('selected');
        selB = { val:keyVal, el };
      }

      el.classList.add('selected');

      if(selA && selB){
        // verify pair
        const correct = (selA.val === selB.val);
        if(correct){
          // lock them
          playSound('win');
          selA.el.classList.add('correct');
          selB.el.classList.add('correct');
          selA.el.classList.remove('selected');
          selB.el.classList.remove('selected');
          selA = null; selB = null;

          // completion condition: all items locked (6 items total for 3 pairs)
          const locked = document.querySelectorAll('.match-item.correct').length;
          if(locked === 6){
            // count as correct answer for THIS quiz step
            stateLock = true;
            handleQuizResult(true, false);
          }
        }else{
          playSound('lose');
          triggerShake();
          safeLoseLife();
          state.combo = 1;
          updateHUD();
          selA.el.classList.remove('selected');
          selB.el.classList.remove('selected');
          selA = null; selB = null;

          // Allow continuing attempts; don't finish this step until a correct set happens.
        }
      }
    }

    function safeLoseLife(){
      // Shield prevents one life loss if available
      if(state.inventory && state.inventory.shields > 0){
        state.inventory.shields--;
        playSound('click');
        // show subtle message in feedback modal? We'll do small alert.
        state.lives = Math.max(0, state.lives); // no change
        alert("🛡️ Shield protected you! No life lost.");
        saveState();
        updateHUD();
        return;
      }
      state.lives--;
      if(state.lives < 0) state.lives = 0;
    }

    function triggerShake(){
      const app = document.getElementById('app-container');
      app.classList.remove('shake');
      void app.offsetWidth;
      app.classList.add('shake');
    }

    function handleQuizResult(isCorrect, timedOut){
      stopQuizTimer();

      if(stateLock === false) stateLock = true;
      const q = ictData[state.idx];

      // feedback
      const fbTitle = document.getElementById('fb-title');
      const fbText = document.getElementById('fb-text');
      const fbCombo = document.getElementById('fb-combo-msg');

      if(isCorrect){
        playSound('win');
        const xpGain = 20 * state.combo;
        state.xp += xpGain;
        state.coins += 5;
        fbTitle.innerText = timedOut ? "ACCESS GRANTED" : "ACCESS GRANTED";
        fbTitle.style.color = "var(--success)";
        fbText.innerText = q.d;
        fbCombo.innerText = `+${xpGain} XP (Combo x${state.combo})`;

        state.stats.quizCorrect = (state.stats.quizCorrect || 0) + 1;
        addDailyProgress("quizCorrect", 1);

        state.combo++;
        state.maxCombo = Math.max(state.maxCombo || 1, state.combo);
        state.stats.maxCombo = Math.max(state.stats.maxCombo || 1, state.maxCombo);

      }else{
        playSound('lose');
        triggerShake();

        safeLoseLife();
        state.combo = 1;
        fbTitle.innerText = timedOut ? "TIMEOUT ACCESS DENIED" : "ACCESS DENIED";
        fbTitle.style.color = "var(--eth-red)";

        fbText.innerText = `The correct core concept was: ${q.t}`;
        fbCombo.innerText = timedOut ? "Combo Reset! (Timer)" : "Combo Reset!";
      }

      levelUpCheck();
      updateHUD();

      // Lives game over
      if(state.lives <= 0){
        playSound('lose');
        alert("Game Over! You ran out of lives. Restarting session...");
        // reset session only? We'll reload full state to wipe
        wipeProgress();
        return;
      }

      openModal('modal-feedback');
      stateLock = false; // allow next step when modal continues
      maybeRefreshAchievementsUI();
    }

    // Escape helpers for option buttons
    function escapeHtml(str){
      return String(str).replace(/[&<>"']/g, s=>{
        const map = { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' };
        return map[s] || s;
      });
    }
    function escapeHtmlAttr(str){
      return String(str).replace(/'/g,"&#39;").replace(/"/g,'&quot;');
    }

    function checkQuizAns(val){
      initAudio();
      if(stateLock) return;

      const q = ictData[state.idx];
      if(!q) return;

      // For matching mode completion we handle separately, but if user hits flash input etc, we'll score.
      // Determine correctness
      let isCorrect = false;

      if(state.mode === 'choosing' || state.mode === 'timedChoose'){
        isCorrect = String(val).toLowerCase().trim() === String(q.t).toLowerCase().trim();
      }else{
        // For writing/fillblank/flashcards input, accept term match
        isCorrect = String(val).toLowerCase().trim() === String(q.t).toLowerCase().trim();
      }

      stateLock = true;
      // Immediately close matching attempts timer etc
      closeModal('modal-feedback');
      handleQuizResult(isCorrect, false);
      stateLock = false;
    }

    function nextQuizStep(){
      // called after modal close + Continue
      state.idx++;
      if(state.idx >= ictData.length){
        stopQuizTimer();
        playSound('buy');
        alert("MASTERY COMPLETE! You cleared this module (Quiz).");
        state.combo = 1;
        showScreen('scr-dash');
        saveState();
      }else{
        // reset lock
        stateLock = false;
        loadQuizQuestion();
      }
    }

