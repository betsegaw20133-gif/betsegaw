      // (certificate itself is checked in checkCert()).
      maybeRefreshAchievementsUI();
      saveState();
    }

    function levelUpCheck(){
      // Prevent multi level jumps in one update (but allow loops)
      let leveled = false;
      while(true){
        const xpLimit = state.lvl * 100;
        if(state.xp < xpLimit) break;
        state.xp -= xpLimit;
        state.lvl++;
        state.coins += 20;
        state.combo = 1;
        leveled = true;
        playSound('buy');
      }
      if(leveled){
        alert(`⭐ LEVEL UP! You are now Level ${state.lvl}! (+20 Coins)`);
      }
    }

