    <script>
        // --- AUDIO ENGINE (Web Audio API) ---
        const AudioContext = window.AudioContext || window.webkitAudioContext;
        let audioCtx;

        function initAudio() {
            if(!audioCtx) audioCtx = new AudioContext();
            if(audioCtx.state === 'suspended') audioCtx.resume();
        }

        function playSound(type) {
            if(!audioCtx) return;
            const osc = audioCtx.createOscillator();
            const gainNode = audioCtx.createGain();
            osc.connect(gainNode);
            gainNode.connect(audioCtx.destination);

            if(type === 'win') {
                osc.type = 'sine';
                osc.frequency.setValueAtTime(400, audioCtx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(800, audioCtx.currentTime + 0.1);
                gainNode.gain.setValueAtTime(0.3, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.3);
                osc.start(); osc.stop(audioCtx.currentTime + 0.3);
            } else if(type === 'lose') {
                osc.type = 'sawtooth';
                osc.frequency.setValueAtTime(200, audioCtx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(100, audioCtx.currentTime + 0.3);
                gainNode.gain.setValueAtTime(0.3, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.3);
                osc.start(); osc.stop(audioCtx.currentTime + 0.3);
            } else if(type === 'click' || type === 'type') {
                osc.type = 'square';
                osc.frequency.setValueAtTime(600, audioCtx.currentTime);
                gainNode.gain.setValueAtTime(0.1, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.05);
                osc.start(); osc.stop(audioCtx.currentTime + 0.05);
            } else if(type === 'buy') {
                osc.type = 'sine';
                osc.frequency.setValueAtTime(800, audioCtx.currentTime);
                osc.frequency.setValueAtTime(1200, audioCtx.currentTime + 0.1);
                gainNode.gain.setValueAtTime(0.2, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.3);
                osc.start(); osc.stop(audioCtx.currentTime + 0.3);
            }
        }

        // --- BACKGROUND CANVAS PARTICLES ---
        const canvas = document.getElementById('bg-canvas');
        const ctx = canvas.getContext('2d');
        let particles = [];
        function resizeCanvas() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
        window.addEventListener('resize', resizeCanvas);
        resizeCanvas();

        class Particle {
            constructor() {
                this.x = Math.random() * canvas.width;
                this.y = Math.random() * canvas.height;
                this.vx = (Math.random() - 0.5) * 0.5;
                this.vy = (Math.random() - 0.5) * 0.5;
            }
            update() {
                this.x += this.vx; this.y += this.vy;
                if(this.x < 0 || this.x > canvas.width) this.vx *= -1;
                if(this.y < 0 || this.y > canvas.height) this.vy *= -1;
            }
            draw() {
                ctx.beginPath(); ctx.arc(this.x, this.y, 2, 0, Math.PI*2);
                ctx.fillStyle = 'rgba(0, 210, 255, 0.5)'; ctx.fill();
            }
        }
        for(let i=0; i<70; i++) particles.push(new Particle());

        function animateCanvas() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach(p => {
                p.update(); p.draw();
                particles.forEach(p2 => {
                    let dx = p.x - p2.x, dy = p.y - p2.y;
                    let dist = Math.sqrt(dx*dx + dy*dy);
                    if(dist < 100) {
                        ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(p2.x, p2.y);
                        ctx.strokeStyle = `rgba(0, 210, 255, ${1 - dist/100})`;
                        ctx.lineWidth = 0.5; ctx.stroke();
                    }
                });
            });
            requestAnimationFrame(animateCanvas);
        }
        animateCanvas();

        // --- DATASET ---
        const ictData = [
            { t: "CPU", d: "Central Processing Unit - The brain of the computer.", b: "The ___ is the brain of the computer." },
            { t: "RAM", d: "Random Access Memory - Temporary volatile storage.", b: "___ loses its data when the power is turned off." },
            { t: "ROM", d: "Read Only Memory - Permanent startup instructions.", b: "The BIOS is stored in the ___ chip." },
            { t: "HTML", d: "HyperText Markup Language - Used for web pages.", b: "Websites are built using ___." },
            { t: "IP Address", d: "A unique identifier for devices on a network.", b: "Every device on the internet has a unique ___." },
            { t: "Firewall", d: "Security system that blocks unauthorized access.", b: "A ___ protects a network from hackers." },
            { t: "Algorithm", d: "A step-by-step procedure to solve a problem.", b: "A program starts with a logical ___." },
            { t: "Encryption", d: "Encoding data to keep it secret.", b: "___ makes data unreadable to unauthorized users." },
            { t: "Hardware", d: "Physical parts of a computer you can touch.", b: "The keyboard and mouse are examples of ___." },
            { t: "Software", d: "Instructions that tell hardware what to do.", b: "Apps and Operating Systems are ___." },
            { t: "Motherboard", d: "Main circuit board of a computer.", b: "The CPU and RAM are plugged into the ___." },
            { t: "Bit", d: "The smallest unit of data (0 or 1).", b: "8 ___ make 1 byte." },
            { t: "URL", d: "The address of a website on the internet.", b: "www.google.com is a ___." },
            { t: "Database", d: "A structured collection of data.", b: "A school uses a ___ to store student info." },
            { t: "Browser", d: "Software used to view websites.", b: "Chrome and Safari are web ___." },
            { t: "ISP", d: "Internet Service Provider like Ethio Telecom.", b: "You buy internet from an ___." },
            { t: "Virus", d: "Malicious software that replicates itself.", b: "An Antivirus removes a computer ___." },
            { t: "Cloud", d: "Storing and accessing data over the internet.", b: "Google Drive is a ___ storage service." },
            { t: "Modem", d: "Device that connects your network to the ISP.", b: "A ___ converts digital signals to analog." },
            { t: "CSS", d: "Cascading Style Sheets - Used for styling web pages.", b: "To make a website look beautiful, we use ___." },
            { t: "JavaScript", d: "Language used for web interactivity.", b: "___ makes web pages interactive." },
            { t: "Cache", d: "High speed memory for quick data access.", b: "A browser uses ___ to load pages faster." },
            { t: "Kernel", d: "The core of an operating system.", b: "The ___ manages communication between hardware and software." },
            { t: "Bandwidth", d: "The capacity of a network connection.", b: "High ___ means faster download speeds." },
            { t: "Protocol", d: "Rules for data communication.", b: "HTTP is a web transfer ___." },
            { t: "Fiber Optic", d: "Cables that use light to transmit data.", b: "___ cables are faster than copper wires." },
            { t: "Linux", d: "An open-source operating system.", b: "___ is a popular OS for servers." },
            { t: "Malware", d: "Any software intended to damage data.", b: "Spyware and Trojans are types of ___." }
        ];

        const tutorials = [
            {t: "History of Computing", c: "From Abacus to Eniac and modern AI systems."},
            {t: "Network Topologies", c: "Star, Ring, Bus, and Mesh physical layouts."},
            {t: "Binary Math", c: "How computers use base-2 (0 and 1) to calculate."},
            {t: "Python Basics", c: "High level language for AI and web backend."},
            {t: "Cyber Ethics", c: "Proper behavior and laws in the digital world."},
            {t: "Digital Ethiopia 2025", c: "National strategy for a digitized inclusive economy, focusing on telecom, ID, and e-commerce."},
            {t: "Ethio Telecom & 5G", c: "The evolution of telecom infrastructure in Ethiopia and the deployment of high-speed 5G networks."},
            {t: "AI & ML", c: "Machines learning from data to make decisions."}
        ];

        // --- STATE ---
        let state = {
            name: "Guest", lvl: 1, xp: 0, coins: 50, lives: 3, combo: 1,
            mode: "", idx: 0, currentAnswer: "", wsSelection: []
        };

        // --- CORE LOGIC ---
        function initPlayer() {
            let n = document.getElementById('player-input').value.trim();
            if(!n) return alert("Please enter your name.");
            initAudio(); // Initialize audio context on first user interaction
            playSound('win');
            state.name = n;
            updateHUD();
            showScreen('scr-dash');
        }

        function triggerShake() {
            const app = document.getElementById('app-container');
            app.classList.remove('shake'); void app.offsetWidth; app.classList.add('shake');
        }

        function updateHUD() {
            document.getElementById('hud-name').innerText = state.name;
            document.getElementById('hud-lvl').innerText = state.lvl;
            document.getElementById('hud-xp').innerText = state.xp;
            document.getElementById('hud-lives').innerText = state.lives;
            document.getElementById('hud-coins').innerText = state.coins;
            document.getElementById('mkt-coins').innerText = state.coins;
            document.getElementById('hud-combo').innerText = state.combo;

            const comboPill = document.getElementById('combo-pill');
            if(state.combo > 1) comboPill.classList.add('combo-active');
            else comboPill.classList.remove('combo-active');

            let xpLimit = state.lvl * 100;
            document.getElementById('mastery-bar').style.width = (state.xp / xpLimit * 100) + "%";

            if(state.xp >= xpLimit) {
                state.xp -= xpLimit; state.lvl++; state.coins += 20;
                playSound('buy');
                alert("⭐ LEVEL UP! You are now Level " + state.lvl + "! +20 Coins");
                updateHUD();
            }
            if(state.lives <= 0) {
                playSound('lose');
                alert("Game Over! You ran out of lives. Restarting session...");
                location.reload();
            }
        }

        function showScreen(id) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById(id).classList.add('active');
        }

        function openModal(id) { document.getElementById(id).style.display = "flex"; }
        function closeModal(id) { document.getElementById(id).style.display = "none"; }

        // --- ACADEMY / LEXICON ---
        function openModule(type) {
            playSound('click');
            showScreen('scr-list');
            const title = document.getElementById('list-title');
            const content = document.getElementById('list-content');
            content.innerHTML = "";
            
            if(type === 'academy') {
                title.innerText = "ICT Academy";
                ictData.concat(tutorials).forEach(item => {
                    content.innerHTML += `<div class="tutorial-item"><h3>${item.t || item.term}</h3><p>${item.d || item.c}</p></div>`;
                });
            } else {
                title.innerText = "Technical Lexicon";
                ictData.forEach(item => {
                    content.innerHTML += `<div class="tutorial-item" style="border-left-color:var(--primary)"><h3>${item.t}</h3><p>${item.d}</p></div>`;
                });
            }
        }

        // --- QUIZ ENGINE ---
        function startQuiz(mode) {
            playSound('click');
            state.mode = mode; state.idx = 0;
            showScreen('scr-quiz');
            loadQuizQuestion();
        }

        function loadQuizQuestion() {
            const q = ictData[state.idx];
            document.getElementById('quiz-lvl-tag').innerText = `Challenge ${state.idx + 1}/${ictData.length}`;
            document.getElementById('quiz-progress').style.width = (state.idx / ictData.length * 100) + "%";
            const area = document.getElementById('q-options');
            area.innerHTML = "";

            if(state.mode === 'choosing') {
                document.getElementById('q-text').innerText = q.d;
                let opts = [q.t];
                while(opts.length < 4) {
                    let rand = ictData[Math.floor(Math.random() * ictData.length)].t;
                    if(!opts.includes(rand)) opts.push(rand);
                }
                opts.sort(() => Math.random() - 0.5);
                opts.forEach(o => {
                    area.innerHTML += `<button class="btn" style="width:100%; max-width:400px; margin-bottom:10px;" onclick="checkQuizAns('${o}')">${o}</button>`;
                });
            } else if(state.mode === 'writing' || state.mode === 'fillblank') {
                document.getElementById('q-text').innerText = (state.mode === 'writing') ? q.d : q.b;
                area.innerHTML = `<input type="text" id="quiz-input" class="input-box" style="max-width:400px;" placeholder="Type answer here..." onkeypress="if(event.key==='Enter') checkQuizAns(this.value)">
                                  <button class="btn" style="width:100%; max-width:400px;" onclick="checkQuizAns(document.getElementById('quiz-input').value)">Submit Analysis</button>`;
                setTimeout(() => document.getElementById('quiz-input').focus(), 100);
            } else if(state.mode === 'matching') {
                document.getElementById('q-text').innerText = "Match the Term to its Definition";
                renderMatching();
            }
        }

        let selA = null, selB = null;
        function renderMatching() {
            const area = document.getElementById('q-options');
            let html = `<div class="match-area"><div class="match-box">`;
            let set = [ictData[state.idx]];
            while(set.length < 3) {
                let rand = ictData[Math.floor(Math.random() * ictData.length)];
                if(!set.includes(rand)) set.push(rand);
            }
            set.sort(() => Math.random()-0.5);
            set.forEach(item => html += `<div class="match-item" onclick="matchSelect('A','${item.t}', this); playSound('click');">${item.t}</div>`);
            html += `</div><div class="match-box">`;
            let setB = [...set].sort(() => Math.random()-0.5);
            setB.forEach(item => html += `<div class="match-item" onclick="matchSelect('B','${item.t}', this); playSound('click');">${item.d.substring(0,40)}...</div>`);
            area.innerHTML = html + `</div></div>`;
        }

        function matchSelect(side, val, el) {
            if(side === 'A') { 
                if(selA) selA.el.classList.remove('selected'); 
                selA = {val, el}; 
            } else { 
                if(selB) selB.el.classList.remove('selected'); 
                selB = {val, el}; 
            }
            el.classList.add('selected');
            if(selA && selB) {
                if(selA.val === selB.val) {
                    playSound('win');
                    selA.el.classList.add('correct'); selB.el.classList.add('correct');
                    selA.el.classList.remove('selected'); selB.el.classList.remove('selected');
                    selA = null; selB = null;
                    if(document.querySelectorAll('.match-item.correct').length === 6) {
                        setTimeout(() => checkQuizAns(true), 500);
                    }
                } else {
                    playSound('lose'); triggerShake();
                    state.lives--; state.combo = 1; updateHUD();
                    selA.el.classList.remove('selected'); selB.el.classList.remove('selected');
                    selA = null; selB = null;
                }
            }
        }

        function checkQuizAns(val) {
            const q = ictData[state.idx];
            let isCorrect = (val === true) || (val.toString().toLowerCase().trim() === q.t.toLowerCase());
            
            const fbTitle = document.getElementById('fb-title');
            const fbText = document.getElementById('fb-text');
            const fbCombo = document.getElementById('fb-combo-msg');

            if(isCorrect) {
                playSound('win');
                let xpGain = 20 * state.combo;
                state.xp += xpGain; state.coins += 5; 
                fbTitle.innerText = "ACCESS GRANTED"; fbTitle.style.color = "var(--success)";
                fbText.innerText = q.d;
                fbCombo.innerText = `+${xpGain} XP (Combo x${state.combo})`;
                state.combo++;
            } else {
                playSound('lose'); triggerShake();
                state.lives--; state.combo = 1;
                fbTitle.innerText = "ACCESS DENIED"; fbTitle.style.color = "var(--eth-red)";
                fbText.innerText = `The correct core concept was: ${q.t}`;
                fbCombo.innerText = "Combo Reset!";
            }
            updateHUD();
            openModal('modal-feedback');
        }

        function nextQuizStep() {
            state.idx++;
            if(state.idx >= ictData.length) {
                playSound('buy');
                alert("MASTERY COMPLETE! You have cleared this module.");
                showScreen('scr-dash');
            } else {
                loadQuizQuestion();
            }
        }

        // --- SKILL GAMES ---
        function startSpecial(game) {
            playSound('click');
            state.mode = game;
            if(game === 'wordsearch') { showScreen('scr-ws'); initWordSearch(); }
            else { 
                showScreen('scr-skill'); 
                if(game === 'typer') initTyper();
                else initPuzzle();
            }
        }

        function initTyper() {
            const item = ictData[Math.floor(Math.random()*ictData.length)];
            state.currentAnswer = item.t;
            document.getElementById('skill-hint').innerText = "TYPE THIS PROTOCOL FAST:";
            document.getElementById('skill-display').innerText = item.t;
            let inp = document.getElementById('skill-input');
            inp.value = ""; inp.focus();
        }

        function initPuzzle() {
            const item = ictData[Math.floor(Math.random()*ictData.length)];
            state.currentAnswer = item.t;
            document.getElementById('skill-hint').innerText = item.d;
            document.getElementById('skill-display').innerText = item.t.split('').sort(() => Math.random()-0.5).join('').toUpperCase();
            let inp = document.getElementById('skill-input');
            inp.value = ""; inp.focus();
        }

        document.getElementById('skill-input').addEventListener('input', (e) => {
            playSound('type');
            if(e.target.value.toLowerCase() === state.currentAnswer.toLowerCase()) {
                playSound('win');
                let xpGain = 15 * state.combo;
                state.xp += xpGain; state.coins += 5; state.combo++; updateHUD();
                
                // Visual feedback on the display
                let disp = document.getElementById('skill-display');
                disp.style.color = "var(--eth-green)";
                setTimeout(() => {
                    disp.style.color = "var(--text-light)";
                    if(state.mode === 'typer') initTyper(); else initPuzzle();
                }, 500);
            }
        });

        // --- FUNCTIONAL WORD SEARCH ---
        let wsGrid = [];
        let wsWords = [];
        const wsSize = 10;

        function initWordSearch() {
            wsWords = ictData.map(i => i.t.toUpperCase().replace(/[^A-Z]/g, '')).filter(w => w.length >= 3 && w.length <= 8).sort(() => 0.5 - Math.random()).slice(0, 6);
            
            wsGrid = Array(wsSize).fill(null).map(() => Array(wsSize).fill(''));
            state.wsSelection = [];
            
            // Place words
            wsWords.forEach(word => {
                let placed = false;
                let attempts = 0;
                while(!placed && attempts < 100) {
                    let dir = Math.random() > 0.5 ? 1 : 0; // 1 = horizontal, 0 = vertical
                    let row = Math.floor(Math.random() * wsSize);
                    let col = Math.floor(Math.random() * wsSize);
                    if(dir === 1 && col + word.length <= wsSize) {
                        let canPlace = true;
                        for(let i=0; i<word.length; i++) { if(wsGrid[row][col+i] !== '' && wsGrid[row][col+i] !== word[i]) canPlace = false; }
                        if(canPlace) { for(let i=0; i<word.length; i++) wsGrid[row][col+i] = word[i]; placed = true; }
                    } else if (dir === 0 && row + word.length <= wsSize) {
                        let canPlace = true;
                        for(let i=0; i<word.length; i++) { if(wsGrid[row+i][col] !== '' && wsGrid[row+i][col] !== word[i]) canPlace = false; }
                        if(canPlace) { for(let i=0; i<word.length; i++) wsGrid[row+i][col] = word[i]; placed = true; }
                    }
                    attempts++;
                }
            });

            // Fill empty spaces
            const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
            for(let r=0; r<wsSize; r++) {
                for(let c=0; c<wsSize; c++) {
                    if(wsGrid[r][c] === '') wsGrid[r][c] = letters.charAt(Math.floor(Math.random() * letters.length));
                }
            }

            drawWordSearch();
        }

        function drawWordSearch() {
            const gridEl = document.getElementById('ws-grid');
            gridEl.style.gridTemplateColumns = `repeat(${wsSize}, 1fr)`;
            gridEl.innerHTML = "";
            for(let r=0; r<wsSize; r++) {
                for(let c=0; c<wsSize; c++) {
                    gridEl.innerHTML += `<div class="ws-cell" id="ws-${r}-${c}" onclick="selectWSCell(${r}, ${c})">${wsGrid[r][c]}</div>`;
                }
            }
            
            let bankHtml = wsWords.map(w => `<span id="ws-word-${w}" style="padding:8px 15px; background:rgba(0,0,0,0.5); border: 1px solid rgba(255,255,255,0.2); border-radius:8px; font-weight:bold;">${w}</span>`).join('');
            document.getElementById('ws-bank').innerHTML = bankHtml;
        }

        function selectWSCell(r, c) {
            playSound('type');
            let el = document.getElementById(`ws-${r}-${c}`);
            
            // Toggle selection
            let idx = state.wsSelection.findIndex(s => s.r === r && s.c === c);
            if(idx > -1) {
                state.wsSelection.splice(idx, 1);
                el.classList.remove('highlighted');
            } else {
                state.wsSelection.push({r, c, char: wsGrid[r][c]});
                el.classList.add('highlighted');
            }

            // Check if selection forms a word
            let selectedWord = state.wsSelection.map(s => s.char).join('');
            let selectedWordRev = state.wsSelection.map(s => s.char).reverse().join('');
            
            let foundWord = wsWords.find(w => w === selectedWord || w === selectedWordRev);
            if(foundWord) {
                playSound('win');
                state.xp += 30; state.coins += 10; updateHUD();
                
                // Mark cells as found
                state.wsSelection.forEach(s => {
                    let cell = document.getElementById(`ws-${s.r}-${s.c}`);
                    cell.classList.remove('highlighted');
                    cell.classList.add('found');
                });
                
                // Cross out in bank
                let bankEl = document.getElementById(`ws-word-${foundWord}`);
                bankEl.style.background = "var(--eth-green)";
                bankEl.style.textDecoration = "line-through";
                
                // Remove from active list
                wsWords = wsWords.filter(w => w !== foundWord);
                state.wsSelection = []; // Reset selection

                if(wsWords.length === 0) {
                    setTimeout(() => {
                        alert("Great job! You found all the hidden tech terms!");
                        showScreen('scr-dash');
                    }, 1000);
                }
            }
        }

        // --- SHOP & MISC ---
        function buyItem(type) {
            if(type === 'life' && state.coins >= 25) { state.coins -= 25; state.lives++; playSound('buy'); }
            else if(type === 'xp' && state.coins >= 40) { state.coins -= 40; state.xp += 50; playSound('buy'); }
            else { playSound('lose'); triggerShake(); alert("Insufficient Coins!"); }
            updateHUD();
        }

        function checkCert() {
            playSound('click');
            if(state.lvl >= 5) {
                document.getElementById('cert-name').innerText = state.name;
                playSound('win');
                openModal('modal-cert');
            } else {
                triggerShake();
                alert(`ACCESS DENIED: You are Level ${state.lvl}. You must reach Level 5 to unlock the Certification.`);
            }
        }

        function filterList() {
            let val = document.getElementById('list-search').value.toLowerCase();
            document.querySelectorAll('.tutorial-item').forEach(item => {
                item.style.display = item.innerText.toLowerCase().includes(val) ? "block" : "none";
            });
        }
    </script>
</body>
