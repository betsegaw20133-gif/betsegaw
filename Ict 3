<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-select=none">
    <title>ICT Master Omega: Ethiopia | Ultimate Edition</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;500;700&family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #00d2ff;
            --secondary: #0984e3;
            --success: #00cec9;
            --danger: #d63031;
            --warning: #fdcb6e;
            --dark: #0f172a;
            --eth-green: #138808;
            --eth-yellow: #f1c40f;
            --eth-red: #e74c3c;
            --glass: rgba(30, 41, 59, 0.8);
            --text-light: #f8fafc;
        }

        * { box-sizing: border-box; transition: all 0.2s ease; }

        body {
            font-family: 'Poppins', sans-serif;
            background: radial-gradient(circle at top right, #1e293b, #0f172a);
            background-attachment: fixed;
            color: var(--text-light);
            margin: 0; min-height: 100vh;
            display: flex; flex-direction: column; align-items: center;
        }

        /* --- HUD BAR --- */
        #top-bar {
            width: 100%; background: var(--glass); backdrop-filter: blur(15px);
            padding: 12px 5%; position: sticky; top: 0; z-index: 1000;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            display: flex; justify-content: space-between; align-items: center;
        }

        .stat-pill { 
            background: rgba(255,255,255,0.05); padding: 6px 15px; border-radius: 20px; 
            border: 1px solid rgba(255,255,255,0.1); font-size: 0.85rem; font-family: 'Space Grotesk';
            display: flex; align-items: center; gap: 8px;
        }

        /* --- MAIN CONTAINER --- */
        #app-container {
            width: 95%; max-width: 1100px; margin: 30px 0;
            background: rgba(255, 255, 255, 0.03); border-radius: 30px;
            border: 1px solid rgba(255,255,255,0.1); padding: 40px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.5); position: relative;
            min-height: 600px;
        }

        .screen { display: none; animation: fadeIn 0.5s ease; }
        .active { display: block; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        /* --- UI ELEMENTS --- */
        .branding-header { text-align: center; margin-bottom: 30px; }
        .dev-tag { font-size: 0.7rem; color: var(--eth-green); font-weight: 900; letter-spacing: 4px; }
        
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 15px; margin-top: 20px; }
        .card {
            background: rgba(255,255,255,0.05); padding: 20px; border-radius: 20px; text-align: center;
            border: 1px solid rgba(255,255,255,0.1); cursor: pointer;
        }
        .card:hover { transform: translateY(-5px); background: rgba(255,255,255,0.1); border-color: var(--primary); }
        .card h3 { margin: 10px 0 5px; color: var(--primary); font-size: 1.1rem; }
        .card p { margin: 0; font-size: 0.8rem; opacity: 0.7; }

        .btn {
            padding: 12px 25px; border: none; border-radius: 12px; font-weight: 700;
            cursor: pointer; text-transform: uppercase; font-family: 'Space Grotesk';
            color: white; background: linear-gradient(135deg, var(--secondary), var(--primary));
        }
        .btn:hover { filter: brightness(1.2); transform: scale(1.02); }
        .btn-market { background: var(--eth-yellow); color: var(--dark); }

        .input-box {
            width: 100%; padding: 15px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.2);
            background: rgba(0,0,0,0.2); color: white; font-size: 1.1rem; margin-bottom: 20px;
        }

        /* --- GAME SPECIFICS --- */
        .progress-container { width: 100%; height: 8px; background: #334155; border-radius: 10px; margin: 20px 0; overflow: hidden; }
        .progress-bar { height: 100%; width: 0%; background: linear-gradient(90deg, var(--eth-green), var(--success)); }
        
        #ws-grid { display: grid; background: rgba(255,255,255,0.05); padding: 10px; border-radius: 12px; margin: 15px auto; user-select: none; }
        .ws-cell { width: 35px; height: 35px; display: flex; align-items: center; justify-content: center; font-weight: 700; cursor: pointer; border-radius: 4px; }
        .ws-cell.highlighted { background: var(--eth-yellow); color: var(--dark); }
        .ws-cell.found { background: var(--eth-green); color: white; }

        .match-area { display: flex; gap: 20px; }
        .match-box { flex: 1; display: flex; flex-direction: column; gap: 10px; }
        .match-item { padding: 15px; background: rgba(255,255,255,0.05); border-radius: 10px; cursor: pointer; border: 1px solid rgba(255,255,255,0.1); font-size: 0.9rem; text-align: center; }
        .match-item.selected { background: var(--secondary); border-color: var(--primary); }
        .match-item.correct { opacity: 0.3; pointer-events: none; border-color: var(--success); }

        .item-list { max-height: 400px; overflow-y: auto; padding: 10px; }
        .tutorial-item { background: rgba(255,255,255,0.03); padding: 15px; border-radius: 12px; margin-bottom: 10px; border-left: 4px solid var(--eth-green); }

        /* --- MODALS --- */
        .modal { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); display: none; justify-content: center; align-items: center; z-index: 2000; }
        .modal-content { background: #1e293b; padding: 40px; border-radius: 25px; max-width: 500px; width: 90%; text-align: center; border: 1px solid var(--primary); }

        /* --- CERTIFICATE --- */
        .cert-paper {
            background: #fff; color: #000; padding: 40px; border: 15px solid #f1c40f; font-family: 'Georgia', serif;
        }
    </style>
</head>
<body>

    <div id="top-bar">
        <div class="stat-pill">👤 <span id="hud-name">Guest</span></div>
        <div class="stat-pill">⭐ LVL <span id="hud-lvl">1</span></div>
        <div class="stat-pill">🔥 XP <span id="hud-xp">0</span></div>
        <div class="stat-pill">❤️ <span id="hud-lives">3</span></div>
        <div class="stat-pill">🪙 <span id="hud-coins">50</span></div>
        <button class="btn btn-market" onclick="openModal('modal-market')">🛒 SHOP</button>
    </div>

    <div id="app-container">
        
        <!-- SCREEN: WELCOME -->
        <div id="scr-welcome" class="screen active" style="text-align: center;">
            <div class="branding-header">
                <div class="dev-tag">ENGINEERED BY BETSEGAW TEKA</div>
                <h1 style="font-family: 'Space Grotesk'; font-size: 3rem; margin: 10px 0; background: linear-gradient(to right, #2ecc71, #f1c40f, #e74c3c); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">ICT MASTER OMEGA</h1>
                <p>National Portal • SOS Children's Villages Ethiopia • Grade 7-12 Mastery</p>
            </div>
            <input type="text" id="player-input" class="input-box" style="max-width: 400px; text-align: center;" placeholder="Enter Student Full Name...">
            <br>
            <button class="btn" style="font-size: 1.2rem; padding: 15px 50px;" onclick="initPlayer()">Access Portal</button>
        </div>

        <!-- SCREEN: DASHBOARD -->
        <div id="scr-dash" class="screen">
            <h2 style="font-family: 'Space Grotesk';">Welcome to the Academy</h2>
            <div class="progress-container"><div id="mastery-bar" class="progress-bar"></div></div>
            
            <p style="opacity: 0.6; font-size: 0.9rem;">LEARNING MODULES</p>
            <div class="grid">
                <div class="card" onclick="openModule('academy')"><h3>🎓 Academy</h3><p>50 Master Lessons</p></div>
                <div class="card" onclick="openModule('lexicon')"><h3>📖 Lexicon</h3><p>50 Technical Terms</p></div>
            </div>

            <p style="opacity: 0.6; font-size: 0.9rem; margin-top: 20px;">CHALLENGE ZONE</p>
            <div class="grid">
                <div class="card" onclick="startQuiz('choosing')"><h3>🔘 Choosing</h3><p>Multiple Choice</p></div>
                <div class="card" onclick="startQuiz('matching')"><h3>🔗 Matching</h3><p>Logic Links</p></div>
                <div class="card" onclick="startQuiz('writing')"><h3>⌨️ Writing</h3><p>Fill Definitions</p></div>
                <div class="card" onclick="startQuiz('fillblank')"><h3>📝 Blank Gaps</h3><p>Sentence Logic</p></div>
            </div>

            <p style="opacity: 0.6; font-size: 0.9rem; margin-top: 20px;">SKILL GAMES</p>
            <div class="grid">
                <div class="card" onclick="startSpecial('wordsearch')"><h3>🔍 Word Search</h3><p>Pattern Finding</p></div>
                <div class="card" onclick="startSpecial('typer')"><h3>⚡ Neural Typer</h3><p>Speed Training</p></div>
                <div class="card" onclick="startSpecial('puzzle')"><h3>🧩 Unscramble</h3><p>Code Decryption</p></div>
                <div class="card" style="border-color: var(--eth-yellow);" onclick="checkCert()"><h3>🏆 Certification</h3><p>Claim Diploma</p></div>
            </div>
        </div>

        <!-- SCREEN: ACADEMY/LEXICON -->
        <div id="scr-list" class="screen">
            <button class="btn" style="padding: 5px 15px; margin-bottom: 15px;" onclick="showScreen('scr-dash')">← Back</button>
            <h2 id="list-title">Module</h2>
            <input type="text" id="list-search" class="input-box" placeholder="Search content..." onkeyup="filterList()">
            <div id="list-content" class="item-list"></div>
        </div>

        <!-- SCREEN: QUIZ ENGINE -->
        <div id="scr-quiz" class="screen">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <button class="btn" style="padding: 5px 15px;" onclick="showScreen('scr-dash')">🏠 Menu</button>
                <div id="quiz-lvl-tag" style="font-weight: bold; color: var(--primary);">Level 1/30</div>
            </div>
            <div class="progress-container"><div id="quiz-progress" class="progress-bar"></div></div>
            <div id="quiz-area" style="text-align: center; margin-top: 30px;">
                <h2 id="q-text" style="font-size: 1.5rem; margin-bottom: 30px;">Question loading...</h2>
                <div id="q-options"></div>
            </div>
        </div>

        <!-- SCREEN: WORDSEARCH -->
        <div id="scr-ws" class="screen">
            <button class="btn" style="padding: 5px 15px;" onclick="showScreen('scr-dash')">🏠 Menu</button>
            <div id="ws-grid"></div>
            <div id="ws-bank" style="display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;"></div>
        </div>

        <!-- SCREEN: SKILL GAMES (TYPER/PUZZLE) -->
        <div id="scr-skill" class="screen" style="text-align: center;">
            <button class="btn" style="padding: 5px 15px;" onclick="showScreen('scr-dash')">🏠 Menu</button>
            <h2 id="skill-hint" style="margin-top: 20px; color: var(--primary);"></h2>
            <div id="skill-display" style="font-size: 3.5rem; font-weight: bold; margin: 30px 0; font-family: 'Space Grotesk';"></div>
            <input type="text" id="skill-input" class="input-box" style="max-width: 400px; text-align: center; font-size: 1.5rem;" autocomplete="off">
        </div>

    </div>

    <!-- MODAL: FEEDBACK -->
    <div id="modal-feedback" class="modal">
        <div class="modal-content">
            <h2 id="fb-title">Result</h2>
            <p id="fb-text"></p>
            <button class="btn" onclick="closeModal('modal-feedback'); nextQuizStep();">Continue</button>
        </div>
    </div>

    <!-- MODAL: MARKET -->
    <div id="modal-market" class="modal">
        <div class="modal-content">
            <span style="float:right; cursor:pointer;" onclick="closeModal('modal-market')">✖</span>
            <h2>🛒 ICT Market</h2>
            <p>Your Balance: <span id="mkt-coins" style="color:var(--eth-yellow)">0</span> 🪙</p>
            <div style="display: flex; flex-direction: column; gap: 10px; margin-top: 20px;">
                <button class="btn" onclick="buyItem('life')">Buy 1 Heart ❤️ (25 Coins)</button>
                <button class="btn" style="background:var(--eth-red)" onclick="buyItem('xp')">Buy 50 XP 🔥 (40 Coins)</button>
            </div>
        </div>
    </div>

    <!-- MODAL: CERTIFICATE -->
    <div id="modal-cert" class="modal">
        <div class="modal-content cert-paper">
            <h3 style="color:#138808; margin:0;">SOS Children's Villages Ethiopia</h3>
            <h1 style="border-bottom: 2px solid #000; padding-bottom: 10px;">CERTIFICATE OF COMPLETION</h1>
            <p>This is to certify that</p>
            <h2 id="cert-name" style="font-style: italic; color: #b8860b;">Student Name</h2>
            <p>has successfully mastered the National ICT Portal Assessment</p>
            <h3>OMEGA PRO LEVEL</h3>
            <div style="display:flex; justify-content: space-between; margin-top: 40px; font-size: 0.8rem;">
                <div>____________________<br>System Verification</div>
                <div>____________________<br>Betsegaw Teka (Developer)</div>
            </div>
            <button class="btn" style="margin-top: 20px;" onclick="location.reload()">Finish</button>
        </div>
    </div>

    <script>
        // --- DATASET MERGE ---
        const ictData = [
            { t: "CPU", d: "Central Processing Unit - The brain of the computer.", b: "The ___ is the brain of the computer." },
            { t: "RAM", d: "Random Access Memory - Temporary volatile storage.", b: "___ loses its data when the power is turned off." },
            { t: "ROM", d: "Read Only Memory - Permanent startup instructions.", b: "The BIOS is stored in the ___ chip." },
            { t: "HTML", d: "HyperText Markup Language - Used for web pages.", b: "Websites are built using ___." },
            { t: "IP Address", d: "A unique identifier for devices on a network.", b: "Every device on the internet has a unique ___." },
            { t: "Firewall", d: "Security system that blocks unauthorized access.", b: "A ___ protects a network from hackers." },
            { t: "Algorithm", d: "A step-by-step procedure to solve a problem.", b: "A program starts with a logical ___." },
            { t: "Encryption", d: "Encoding data to keep it secret.", b: "___ makes data unreadable to unauthorized users." },
            { t: "Hardware", d: "Physical parts of a computer you can touch.", b: "The keyboard and mouse are examples of ___." },
            { t: "Software", d: "Instructions that tell hardware what to do.", b: "Apps and Operating Systems are ___." },
            { t: "Motherboard", d: "Main circuit board of a computer.", b: "The CPU and RAM are plugged into the ___." },
            { t: "Bit", d: "The smallest unit of data (0 or 1).", b: "8 ___ make 1 byte." },
            { t: "URL", d: "The address of a website on the internet.", b: "www.google.com is a ___." },
            { t: "Database", d: "A structured collection of data.", b: "A school uses a ___ to store student info." },
            { t: "Browser", d: "Software used to view websites.", b: "Chrome and Safari are web ___." },
            { t: "ISP", d: "Internet Service Provider like Ethio Telecom.", b: "You buy internet from an ___." },
            { t: "Virus", d: "Malicious software that replicates itself.", b: "An Antivirus removes a computer ___." },
            { t: "Cloud", d: "Storing and accessing data over the internet.", b: "Google Drive is a ___ storage service." },
            { t: "Modem", d: "Device that connects your network to the ISP.", b: "A ___ converts digital signals to analog." },
            { t: "CSS", d: "Cascading Style Sheets - Used for styling web pages.", b: "To make a website look beautiful, we use ___." },
            { t: "JavaScript", d: "Language used for web interactivity.", b: "___ makes web pages interactive." },
            { t: "Cache", d: "High speed memory for quick data access.", b: "A browser uses ___ to load pages faster." },
            { t: "Kernel", d: "The core of an operating system.", b: "The ___ manages communication between hardware and software." },
            { t: "Bandwidth", d: "The capacity of a network connection.", b: "High ___ means faster download speeds." },
            { t: "Protocol", d: "Rules for data communication.", b: "HTTP is a web transfer ___." },
            { t: "Fiber Optic", d: "Cables that use light to transmit data.", b: "___ cables are faster than copper wires." },
            { t: "Linux", d: "An open-source operating system.", b: "___ is a popular OS for servers." },
            { t: "Input Device", d: "Hardware used to enter data.", b: "A scanner is an ___." },
            { t: "Output Device", d: "Hardware used to see/hear results.", b: "A printer is an ___." },
            { t: "Malware", d: "Any software intended to damage data.", b: "Spyware and Trojans are types of ___." }
        ];

        const tutorials = [
            {t: "History of Computing", c: "From Abacus to Eniac and modern AI systems."},
            {t: "Network Topologies", c: "Star, Ring, Bus, and Mesh physical layouts."},
            {t: "Binary Math", c: "How computers use base-2 (0 and 1) to calculate."},
            {t: "Python Basics", c: "High level language for AI and web backend."},
            {t: "Cyber Ethics", c: "Proper behavior and laws in the digital world."},
            {t: "IoT", c: "The Internet of Things - connected smart devices."},
            {t: "AI & ML", c: "Machines learning from data to make decisions."},
            {t: "Ethiopia 2025 Digital", c: "National strategy for a digitized economy."}
        ]; // Expanded by code later

        // --- STATE ---
        let state = {
            name: "Guest", lvl: 1, xp: 0, coins: 50, lives: 3,
            mode: "", idx: 0, currentAnswer: ""
        };

        // --- CORE LOGIC ---
        function initPlayer() {
            let n = document.getElementById('player-input').value;
            if(!n) return alert("Please enter your name.");
            state.name = n;
            updateHUD();
            showScreen('scr-dash');
        }

        function updateHUD() {
            document.getElementById('hud-name').innerText = state.name;
            document.getElementById('hud-lvl').innerText = state.lvl;
            document.getElementById('hud-xp').innerText = state.xp;
            document.getElementById('hud-lives').innerText = state.lives;
            document.getElementById('hud-coins').innerText = state.coins;
            document.getElementById('mkt-coins').innerText = state.coins;

            let xpLimit = state.lvl * 100;
            document.getElementById('mastery-bar').style.width = (state.xp / xpLimit * 100) + "%";

            if(state.xp >= xpLimit) {
                state.xp -= xpLimit;
                state.lvl++;
                alert("LEVEL UP! You are now Level " + state.lvl);
                updateHUD();
            }
            if(state.lives <= 0) {
                alert("Game Over! Restarting session...");
                location.reload();
            }
        }

        function showScreen(id) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById(id).classList.add('active');
        }

        function openModal(id) { document.getElementById(id).style.display = "flex"; }
        function closeModal(id) { document.getElementById(id).style.display = "none"; }

        // --- ACADEMY / LEXICON ---
        function openModule(type) {
            showScreen('scr-list');
            const title = document.getElementById('list-title');
            const content = document.getElementById('list-content');
            content.innerHTML = "";
            
            if(type === 'academy') {
                title.innerText = "ICT Academy";
                ictData.concat(tutorials).forEach(item => {
                    content.innerHTML += `<div class="tutorial-item"><h3>${item.t || item.term}</h3><p>${item.d || item.c}</p></div>`;
                });
            } else {
                title.innerText = "Technical Lexicon";
                ictData.forEach(item => {
                    content.innerHTML += `<div class="tutorial-item" style="border-color:var(--primary)"><h3>${item.t}</h3><p>${item.d}</p></div>`;
                });
            }
        }

        // --- QUIZ ENGINE ---
        function startQuiz(mode) {
            state.mode = mode;
            state.idx = 0;
            showScreen('scr-quiz');
            loadQuizQuestion();
        }

        function loadQuizQuestion() {
            const q = ictData[state.idx];
            document.getElementById('quiz-lvl-tag').innerText = `Level ${state.idx + 1}/30`;
            document.getElementById('quiz-progress').style.width = (state.idx / 30 * 100) + "%";
            const area = document.getElementById('q-options');
            area.innerHTML = "";

            if(state.mode === 'choosing') {
                document.getElementById('q-text').innerText = q.d;
                let opts = [q.t, ictData[(state.idx+1)%30].t, ictData[(state.idx+2)%30].t, ictData[(state.idx+3)%30].t];
                opts.sort(() => Math.random() - 0.5);
                opts.forEach(o => {
                    area.innerHTML += `<button class="btn" style="width:100%; margin-bottom:10px;" onclick="checkQuizAns('${o}')">${o}</button>`;
                });
            } else if(state.mode === 'writing' || state.mode === 'fillblank') {
                document.getElementById('q-text').innerText = (state.mode === 'writing') ? q.d : q.b;
                area.innerHTML = `<input type="text" id="quiz-input" class="input-box" placeholder="Answer..." onkeypress="if(event.key==='Enter') checkQuizAns(this.value)">
                                  <button class="btn" style="width:100%" onclick="checkQuizAns(document.getElementById('quiz-input').value)">Submit</button>`;
                setTimeout(() => document.getElementById('quiz-input').focus(), 100);
            } else if(state.mode === 'matching') {
                document.getElementById('q-text').innerText = "Match the Term to its Definition";
                renderMatching();
            }
        }

        let selA = null, selB = null;
        function renderMatching() {
            const q = ictData[state.idx];
            const area = document.getElementById('q-options');
            let html = `<div class="match-area"><div class="match-box">`;
            let set = [ictData[state.idx], ictData[(state.idx+1)%30], ictData[(state.idx+2)%30]].sort(() => Math.random()-0.5);
            set.forEach(item => html += `<div class="match-item" onclick="matchSelect('A','${item.t}', this)">${item.t}</div>`);
            html += `</div><div class="match-box">`;
            let setB = [...set].sort(() => Math.random()-0.5);
            setB.forEach(item => html += `<div class="match-item" onclick="matchSelect('B','${item.t}', this)">${item.d.substring(0,30)}...</div>`);
            area.innerHTML = html + `</div></div>`;
        }

        function matchSelect(side, val, el) {
            if(side === 'A') { 
                if(selA) selA.el.classList.remove('selected'); 
                selA = {val, el}; 
            } else { 
                if(selB) selB.el.classList.remove('selected'); 
                selB = {val, el}; 
            }
            el.classList.add('selected');
            if(selA && selB) {
                if(selA.val === selB.val) {
                    selA.el.classList.add('correct'); selB.el.classList.add('correct');
                    selA = null; selB = null;
                    if(document.querySelectorAll('.match-item.correct').length === 6) checkQuizAns(true);
                } else {
                    state.lives--; updateHUD();
                    selA.el.classList.remove('selected'); selB.el.classList.remove('selected');
                    selA = null; selB = null;
                }
            }
        }

        function checkQuizAns(val) {
            const q = ictData[state.idx];
            let isCorrect = (val === true) || (val.toLowerCase().trim() === q.t.toLowerCase());
            
            const fbTitle = document.getElementById('fb-title');
            const fbText = document.getElementById('fb-text');

            if(isCorrect) {
                state.xp += 20; state.coins += 10;
                fbTitle.innerText = "EXCELLENT!"; fbTitle.style.color = "var(--success)";
                fbText.innerText = q.d;
            } else {
                state.lives--;
                fbTitle.innerText = "INCORRECT"; fbTitle.style.color = "var(--eth-red)";
                fbText.innerText = "The correct answer was: " + q.t;
            }
            updateHUD();
            openModal('modal-feedback');
        }

        function nextQuizStep() {
            state.idx++;
            if(state.idx >= 30) {
                alert("Mastery Achievement! Level 30 Complete.");
                showScreen('scr-dash');
            } else {
                loadQuizQuestion();
            }
        }

        // --- SKILL GAMES ---
        function startSpecial(game) {
            state.mode = game;
            if(game === 'wordsearch') { showScreen('scr-ws'); initWordSearch(); }
            else { 
                showScreen('scr-skill'); 
                if(game === 'typer') initTyper();
                else initPuzzle();
            }
        }

        function initTyper() {
            const item = ictData[Math.floor(Math.random()*30)];
            state.currentAnswer = item.t;
            document.getElementById('skill-hint').innerText = "TYPE THIS WORD:";
            document.getElementById('skill-display').innerText = item.t;
            document.getElementById('skill-input').value = "";
            document.getElementById('skill-input').focus();
        }

        function initPuzzle() {
            const item = ictData[Math.floor(Math.random()*30)];
            state.currentAnswer = item.t;
            document.getElementById('skill-hint').innerText = item.d;
            document.getElementById('skill-display').innerText = item.t.split('').sort(() => Math.random()-0.5).join('');
            document.getElementById('skill-input').value = "";
            document.getElementById('skill-input').focus();
        }

        document.getElementById('skill-input').addEventListener('input', (e) => {
            if(e.target.value.toLowerCase() === state.currentAnswer.toLowerCase()) {
                state.xp += 15; state.coins += 5; updateHUD();
                if(state.mode === 'typer') initTyper(); else initPuzzle();
            }
        });

        // --- WORD SEARCH ---
        function initWordSearch() {
            const size = 10;
            const words = ictData.slice(0,10).map(i => i.t.toUpperCase()).filter(w => w.length < 9);
            const gridEl = document.getElementById('ws-grid');
            gridEl.style.gridTemplateColumns = `repeat(${size}, 1fr)`;
            gridEl.innerHTML = "";
            
            // Simplified grid for demo - fills with letters
            for(let i=0; i<size*size; i++) {
                gridEl.innerHTML += `<div class="ws-cell" onclick="this.classList.toggle('highlighted')">${"ABCDEFGHIJKLMNOPQRSTUVWXYZ"[Math.floor(Math.random()*26)]}</div>`;
            }
            document.getElementById('ws-bank').innerHTML = words.map(w => `<span style="padding:5px 10px; background:rgba(255,255,255,0.1); border-radius:5px;">${w}</span>`).join('');
        }

        // --- SHOP & MISC ---
        function buyItem(type) {
            if(type === 'life' && state.coins >= 25) { state.coins -= 25; state.lives++; }
            else if(type === 'xp' && state.coins >= 40) { state.coins -= 40; state.xp += 50; }
            else { alert("Not enough coins!"); }
            updateHUD();
        }

        function checkCert() {
            if(state.lvl >= 5) {
                document.getElementById('cert-name').innerText = state.name;
                openModal('modal-cert');
            } else {
                alert("ACCESS DENIED: You must reach Level 5 to unlock Certification.");
            }
        }

        function filterList() {
            let val = document.getElementById('list-search').value.toLowerCase();
            document.querySelectorAll('.tutorial-item').forEach(item => {
                item.style.display = item.innerText.toLowerCase().includes(val) ? "block" : "none";
            });
        }
    </script>
</body>
</html>
